@using Radzen
@using Radzen.Blazor
@inject NotificationService Notify
@inject DialogService DialogService

<RadzenStack Gap="1.25rem" Style="max-height:85vh;overflow:auto;padding:0.25rem">
    @* Centro Poblado *@
    <RadzenFieldSet Text="Centro Poblado" Icon="place">
        <RadzenStack Gap="0.75rem">
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Departamento" Variant="Variant.Outlined">
                        <RadzenDropDown Data="@departamentosConOpcion" TextProperty="Nombre" ValueProperty="Codigo" @bind-Value="codigoDepartamento" Style="width:100%" Change="@OnDepartamentoChange" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Provincia" Variant="Variant.Outlined">
                        <RadzenDropDown Data="@provinciasConOpcion" TextProperty="Nombre" ValueProperty="Codigo" @bind-Value="codigoProvincia" Style="width:100%" Change="@OnProvinciaChange" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Distrito" Variant="Variant.Outlined">
                        <RadzenDropDown Data="@distritosConOpcion" TextProperty="Nombre" ValueProperty="Ubigeo" @bind-Value="codigoDistrito" Style="width:100%" Change="@OnDistritoChange" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Ubigeo (autocompletado)" Variant="Variant.Outlined">
                        <RadzenTextBox Value="@Model.Ubigeo" ReadOnly="true" Style="width:100%;background:#f1f5f9" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Nombre centro poblado" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="Model.CentroPoblado" Style="width:100%" MaxLength="200" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Ubigeo CCP (numérico)" Variant="Variant.Outlined">
                        <RadzenNumeric Value="@ubigeoCcpNum" ValueChanged="@((decimal? v) => { ubigeoCcpNum = v; if (Model != null) Model.UbigeoCcp = v?.ToString("0"); })" Format="0" Style="width:100%" Placeholder="Código" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6">
                    <RadzenFormField Text="Establecimiento de salud" Variant="Variant.Outlined">
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.25rem">
                            <RadzenDropDown Data="@establecimientosConOpcion" TextProperty="Nombre" ValueProperty="Id" @bind-Value="Model.IdEstablecimiento" Style="flex:1" />
                            <RadzenButton Icon="info" ButtonStyle="ButtonStyle.Light" Size="ButtonSize.Small" Click="@AbrirModalEstablecimiento" Title="Ver información del establecimiento" Disabled="@(Model.IdEstablecimiento == null)" />
                        </RadzenStack>
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenFormField Text="Salud ámbito" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="Model.Ambito" Style="width:100%" MaxLength="50" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="3">
                    <RadzenFormField Text="Quintil" Variant="Variant.Outlined">
                        <RadzenDropDown Data="@quintilesConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="Model.Quintil" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldSet>

    @* Coordenadas *@
    <RadzenFieldSet Text="Coordenadas" Icon="map">
        <RadzenStack Gap="0.75rem">
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Este" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.Este" Format="0.00" Style="width:100%" /></RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Norte" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.Norte" Format="0.00" Style="width:100%" /></RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Huso" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.Huso" Format="0" Style="width:100%" /></RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Banda" Variant="Variant.Outlined"><RadzenTextBox @bind-Value="Model.Banda" Style="width:100%" MaxLength="5" /></RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Latitud" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.Latitud" Format="0.000000" Style="width:100%" /></RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Longitud" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.Longitud" Format="0.000000" Style="width:100%" /></RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Altitud (m.s.n.m.)" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.AltitudMsnm" Format="0" Style="width:100%" /></RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldSet>

    @* Población *@
    <RadzenFieldSet Text="Población" Icon="people">
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Población total" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.PoblacionTotal" Format="0" Style="width:100%" /></RadzenFormField></RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Población servida" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.PoblacionServida" Format="0" Style="width:100%" /></RadzenFormField></RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Población vigilada" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.PoblacionVigilada" Format="0" Style="width:100%" /></RadzenFormField></RadzenColumn>
        </RadzenRow>
    </RadzenFieldSet>

    @* Servicios básicos *@
    <RadzenFieldSet Text="Servicios básicos" Icon="build">
        <RadzenStack Gap="0.75rem">
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Electricidad (horas)" Variant="Variant.Outlined">
                        <RadzenDropDown Data="@horasElectricidadConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="Model.ElectricidadHrs" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Teléfono - Tipo" Variant="Variant.Outlined">
                        <RadzenDropDown Data="@tiposTelefonoConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="Model.TelefonoTipo" Style="width:100%" />
                    </RadzenFormField>
                </RadzenColumn>
                <RadzenColumn Size="12" SizeMD="4">
                    <RadzenFormField Text="Teléfono - Número" Variant="Variant.Outlined">
                        <RadzenTextBox @bind-Value="Model.TelefonoNumero" Style="width:100%" MaxLength="30" />
                    </RadzenFormField>
                </RadzenColumn>
            </RadzenRow>
            <RadzenFormField Text="Vertimientos" Variant="Variant.Outlined" Style="max-width:320px">
                <RadzenDropDown Data="@vertimientosConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="Model.Vertimientos" Style="width:100%" />
            </RadzenFormField>
            <RadzenText TextStyle="TextStyle.Caption" Style="margin-bottom:0.25rem">Servicios disponibles</RadzenText>
            <RadzenRow Gap="1rem">
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.RadioEmisora" Name="re" Text="Radio Emisora" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.RadioESS" Name="ress" Text="Radio ESS" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.SenalTV" Name="tv" Text="Señal de TV" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.Internet" Name="int" Text="Internet" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.LimpiezaPublica" Name="lp" Text="¿Limpieza pública?" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.Agua" Name="agua" Text="Agua" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.Letrinas" Name="let" Text="¿Letrinas?" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.DesagueAlcantarillado" Name="des" Text="Desagüe/Alcantarillado" /></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6" SizeLG="4"><RadzenCheckBox @bind-Value="Model.SistEliminacionExcretas" Name="sist" Text="¿Sist. eliminación de excretas?" /></RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldSet>

    @* Temperatura *@
    <RadzenFieldSet Text="Temperatura" Icon="thermostat">
        <RadzenRow Gap="1rem">
            <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Mínima" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.TempMinima" Format="0.00" Style="width:100%" /></RadzenFormField></RadzenColumn>
            <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Máxima" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="Model.TempMaxima" Format="0.00" Style="width:100%" /></RadzenFormField></RadzenColumn>
        </RadzenRow>
    </RadzenFieldSet>

    @* Accesibilidad *@
    <RadzenFieldSet Text="Accesibilidad" Icon="route">
        <RadzenStack Gap="0.75rem">
            <RadzenText TextStyle="TextStyle.Caption">Registrar, editar y eliminar filas. Agregar nueva fila abajo.</RadzenText>
            <IpressDataTable TItem="AccesibilidadItemDto" Data="@(Model.Accesibilidades ?? new())" AllowGrouping="false" AllowFiltering="false" PageSize="5" Style="width:100%">
                <Columns>
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Property="Desde" Title="Desde" Width="100px" />
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Property="Hasta" Title="Hasta" Width="100px" />
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Property="DistanciaKm" Title="Distancia (km)" Width="110px" FormatString="{0:N2}" />
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Property="TiempoMin" Title="Tiempo (min)" Width="110px" />
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Property="TipoVia" Title="Tipo vía" Width="160px" />
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Property="MedioTransporte" Title="Medio transporte" Width="140px" />
                    <RadzenDataGridColumn TItem="AccesibilidadItemDto" Title="" Width="80px" Sortable="false" Filterable="false">
                        <Template Context="a">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => QuitarAccesibilidad(a))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </IpressDataTable>
            <RadzenRow Gap="0.5rem" Style="align-items:flex-end">
                <RadzenColumn Size="12" SizeMD="2"><RadzenFormField Text="Desde" Variant="Variant.Outlined"><RadzenTextBox @bind-Value="nuevaAcc.Desde" Placeholder="Desde" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenFormField Text="Hasta" Variant="Variant.Outlined"><RadzenTextBox @bind-Value="nuevaAcc.Hasta" Placeholder="Hasta" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenFormField Text="Distancia (km)" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="nuevaAcc.DistanciaKm" Placeholder="0" Format="0.00" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenFormField Text="Tiempo (min)" Variant="Variant.Outlined"><RadzenNumeric @bind-Value="nuevaAcc.TiempoMin" Placeholder="0" Format="0" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenFormField Text="Tipo vía" Variant="Variant.Outlined"><RadzenDropDown Data="@tiposViaConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="nuevaAcc.TipoVia" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2"><RadzenFormField Text="Medio" Variant="Variant.Outlined"><RadzenDropDown Data="@mediosTransporteConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="nuevaAcc.MedioTransporte" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="12" Style="display:flex;align-items:flex-end"><RadzenButton Icon="add" Text="Agregar" ButtonStyle="ButtonStyle.Light" Click="@AgregarAccesibilidad" /></RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldSet>

    @* Centros Educativos *@
    <RadzenFieldSet Text="Centros Educativos" Icon="school">
        <RadzenStack Gap="0.75rem">
            <IpressDataTable TItem="CentroEducativoItemDto" Data="@(Model.CentrosEducativos ?? new())" AllowGrouping="false" AllowFiltering="false" PageSize="5" Style="width:100%">
                <Columns>
                    <RadzenDataGridColumn TItem="CentroEducativoItemDto" Property="TipoCentroEducativo" Title="Tipo" Width="140px" />
                    <RadzenDataGridColumn TItem="CentroEducativoItemDto" Property="NombreCentroEducativo" Title="Nombre" />
                    <RadzenDataGridColumn TItem="CentroEducativoItemDto" Title="" Width="80px" Sortable="false" Filterable="false">
                        <Template Context="ce">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => QuitarCentroEducativo(ce))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </IpressDataTable>
            <RadzenRow Gap="0.5rem" Style="align-items:flex-end">
                <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Tipo" Variant="Variant.Outlined"><RadzenDropDown Data="@tiposCentroEducativoConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="nuevoCE.TipoCentroEducativo" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6"><RadzenFormField Text="Nombre del centro educativo" Variant="Variant.Outlined"><RadzenTextBox @bind-Value="nuevoCE.NombreCentroEducativo" Placeholder="Nombre" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2" Style="display:flex;align-items:flex-end"><RadzenButton Icon="add" Text="Agregar" ButtonStyle="ButtonStyle.Light" Click="@AgregarCentroEducativo" Style="width:100%" /></RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldSet>

    @* Autoridades locales o Comunales *@
    <RadzenFieldSet Text="Autoridades locales o Comunales" Icon="badge">
        <RadzenStack Gap="0.75rem">
            <IpressDataTable TItem="AutoridadItemDto" Data="@(Model.Autoridades ?? new())" AllowGrouping="false" AllowFiltering="false" PageSize="5" Style="width:100%">
                <Columns>
                    <RadzenDataGridColumn TItem="AutoridadItemDto" Property="TipoAutoridad" Title="Tipo" Width="180px" />
                    <RadzenDataGridColumn TItem="AutoridadItemDto" Property="NombreAutoridad" Title="Nombre" />
                    <RadzenDataGridColumn TItem="AutoridadItemDto" Title="" Width="80px" Sortable="false" Filterable="false">
                        <Template Context="a">
                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => QuitarAutoridad(a))" />
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </IpressDataTable>
            <RadzenRow Gap="0.5rem" Style="align-items:flex-end">
                <RadzenColumn Size="12" SizeMD="4"><RadzenFormField Text="Tipo de autoridad" Variant="Variant.Outlined"><RadzenTextBox @bind-Value="nuevaAut.TipoAutoridad" Placeholder="Tipo" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="6"><RadzenFormField Text="Nombre" Variant="Variant.Outlined"><RadzenTextBox @bind-Value="nuevaAut.NombreAutoridad" Placeholder="Nombre" Style="width:100%" /></RadzenFormField></RadzenColumn>
                <RadzenColumn Size="12" SizeMD="2" Style="display:flex;align-items:flex-end"><RadzenButton Icon="add" Text="Agregar" ButtonStyle="ButtonStyle.Light" Click="@AgregarAutoridad" Style="width:100%" /></RadzenColumn>
            </RadzenRow>
        </RadzenStack>
    </RadzenFieldSet>

    <RadzenStack Orientation="Orientation.Horizontal" Gap="0.75rem" JustifyContent="JustifyContent.End" Style="margin-top:0.5rem">
        <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@CancelarClick" />
        <RadzenButton Text="Guardar" ButtonStyle="ButtonStyle.Primary" Click="@GuardarClick" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public CentroPobladoRequestDto Model { get; set; } = new();
    [Parameter] public EventCallback OnGuardar { get; set; }
    [Parameter] public EventCallback OnCancelar { get; set; }

    private async Task GuardarClick() => await OnGuardar.InvokeAsync();
    private async Task CancelarClick() => await OnCancelar.InvokeAsync();
    [Parameter] public List<EstablecimientoListDto> Establecimientos { get; set; } = new();
    [Parameter] public List<GeografiaItemDto> Departamentos { get; set; } = new();
    [Parameter] public Func<string?, Task<List<ProvinciaItemDto>>> GetProvincias { get; set; } = null!;
    [Parameter] public Func<string?, Task<List<DistritoItemDto>>> GetDistritos { get; set; } = null!;

    private List<ProvinciaItemDto> provincias = new();
    private List<DistritoItemDto> distritos = new();
    private string? codigoDepartamento;
    private string? codigoProvincia;
    private string? codigoDistrito;
    private decimal? ubigeoCcpNum;
    private AccesibilidadItemDto nuevaAcc = new();
    private CentroEducativoItemDto nuevoCE = new();
    private AutoridadItemDto nuevaAut = new();

    private IEnumerable<GeografiaItemDto> departamentosConOpcion => new[] { new GeografiaItemDto { Codigo = "", Nombre = "--seleccionar--" } }.Concat(Departamentos ?? new List<GeografiaItemDto>());
    private IEnumerable<ProvinciaItemDto> provinciasConOpcion => new[] { new ProvinciaItemDto { Codigo = "", Nombre = "--seleccionar--" } }.Concat(provincias);
    private IEnumerable<DistritoItemDto> distritosConOpcion => new[] { new DistritoItemDto { Ubigeo = "", Nombre = "--seleccionar--" } }.Concat(distritos);
    private IEnumerable<EstablecimientoOption> establecimientosConOpcion => new[] { new EstablecimientoOption { Id = null, Nombre = "--seleccionar--" } }.Concat((Establecimientos ?? new()).Select(e => new EstablecimientoOption { Id = e.IdEstablecimiento, Nombre = e.Nombre ?? "" }));

    private static readonly List<SelectItem> quintiles = new() { new("Q1", "Q1"), new("Q2", "Q2"), new("Q3", "Q3"), new("Q4", "Q4"), new("Q5", "Q5") };
    private static readonly List<SelectItemInt> horasElectricidad = Enumerable.Range(1, 24).Select(i => new SelectItemInt(i, i + " hrs")).ToList();
    private static readonly List<SelectItem> tiposTelefono = new() { new("Teléfono de la comunidad", "Teléfono de la comunidad"), new("EE.SS", "EE.SS") };
    private static readonly List<SelectItem> vertimientos = new() { new("río", "río"), new("lago", "lago"), new("mar", "mar"), new("canal de regadío", "canal de regadío"), new("infiltración en el suelo", "infiltración en el suelo") };
    private static readonly List<SelectItem> tiposVia = new() { new("Trocha", "Trocha"), new("Camino de herradura", "Camino de herradura"), new("Camino carrozable", "Camino carrozable"), new("Carretera afirmada", "Carretera afirmada"), new("Carretera asfaltada", "Carretera asfaltada"), new("Vía fluvial", "Vía fluvial"), new("Vía lacustre", "Vía lacustre"), new("Vía férrea", "Vía férrea") };
    private static readonly List<SelectItem> mediosTransporte = new() { new("Transporte público", "Transporte público"), new("Camión", "Camión"), new("Auto", "Auto"), new("Tren", "Tren"), new("Bote/lancha", "Bote/lancha"), new("Mototaxi", "Mototaxi"), new("bicicleta", "bicicleta"), new("A pie", "A pie") };
    private static readonly List<SelectItem> tiposCentroEducativo = new() { new("Pronoi/CEI", "Pronoi/CEI"), new("Primaria", "Primaria"), new("Secundaria", "Secundaria"), new("Otros", "Otros") };

    private IEnumerable<SelectItem> quintilesConOpcion => new[] { new SelectItem("", "--seleccionar--") }.Concat(quintiles);
    private IEnumerable<SelectItemIntNullable> horasElectricidadConOpcion => new[] { new SelectItemIntNullable { Value = null, Text = "--seleccionar--" } }.Concat(horasElectricidad.Select(x => new SelectItemIntNullable { Value = x.Value, Text = x.Text }));
    private IEnumerable<SelectItem> tiposTelefonoConOpcion => new[] { new SelectItem("", "--seleccionar--") }.Concat(tiposTelefono);
    private IEnumerable<SelectItem> vertimientosConOpcion => new[] { new SelectItem("", "--seleccionar--") }.Concat(vertimientos);
    private IEnumerable<SelectItem> tiposViaConOpcion => new[] { new SelectItem("", "--seleccionar--") }.Concat(tiposVia);
    private IEnumerable<SelectItem> mediosTransporteConOpcion => new[] { new SelectItem("", "--seleccionar--") }.Concat(mediosTransporte);
    private IEnumerable<SelectItem> tiposCentroEducativoConOpcion => new[] { new SelectItem("", "--seleccionar--") }.Concat(tiposCentroEducativo);

    private class SelectItem { public string? Value { get; set; } public string Text { get; set; } = ""; public SelectItem(string? v, string t) { Value = v; Text = t; } }
    private class SelectItemInt { public int Value { get; set; } public string Text { get; set; } = ""; public SelectItemInt(int v, string t) { Value = v; Text = t; } }
    private class SelectItemIntNullable { public int? Value { get; set; } public string Text { get; set; } = ""; }
    private class EstablecimientoOption { public int? Id { get; set; } public string Nombre { get; set; } = ""; }

    protected override void OnParametersSet()
    {
        if (Model?.Ubigeo?.Length == 6)
        {
            codigoDepartamento = Model.Ubigeo.Substring(0, 2);
            codigoProvincia = Model.Ubigeo.Substring(0, 4);
            codigoDistrito = Model.Ubigeo;
        }
        if (!string.IsNullOrEmpty(Model?.UbigeoCcp) && decimal.TryParse(Model.UbigeoCcp, out var u)) ubigeoCcpNum = u;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrEmpty(codigoDepartamento)) provincias = await GetProvincias(codigoDepartamento) ?? new();
        if (!string.IsNullOrEmpty(codigoProvincia)) distritos = await GetDistritos(codigoProvincia) ?? new();
    }


    private async Task OnDepartamentoChange()
    {
        codigoProvincia = null;
        codigoDistrito = null;
        Model.Ubigeo = null;
        Model.Departamento = Departamentos?.FirstOrDefault(d => d.Codigo == codigoDepartamento)?.Nombre;
        Model.Provincia = null;
        Model.Distrito = null;
        provincias = string.IsNullOrEmpty(codigoDepartamento) ? new() : (await GetProvincias(codigoDepartamento) ?? new());
        distritos = new();
    }

    private async Task OnProvinciaChange()
    {
        codigoDistrito = null;
        Model.Ubigeo = null;
        Model.Provincia = provincias.FirstOrDefault(p => p.Codigo == codigoProvincia)?.Nombre;
        Model.Distrito = null;
        distritos = string.IsNullOrEmpty(codigoProvincia) ? new() : (await GetDistritos(codigoProvincia) ?? new());
    }

    private void OnDistritoChange()
    {
        Model.Ubigeo = string.IsNullOrEmpty(codigoDistrito) ? null : codigoDistrito;
        Model.Distrito = string.IsNullOrEmpty(codigoDistrito) ? null : distritos.FirstOrDefault(d => d.Ubigeo == codigoDistrito)?.Nombre;
    }

    private void AgregarAccesibilidad()
    {
        Model.Accesibilidades ??= new();
        Model.Accesibilidades.Add(new AccesibilidadItemDto { Desde = nuevaAcc.Desde, Hasta = nuevaAcc.Hasta, DistanciaKm = nuevaAcc.DistanciaKm, TiempoMin = nuevaAcc.TiempoMin, TipoVia = nuevaAcc.TipoVia, MedioTransporte = nuevaAcc.MedioTransporte });
        nuevaAcc = new();
    }

    private void QuitarAccesibilidad(AccesibilidadItemDto a) => (Model.Accesibilidades ?? new()).Remove(a);

    private void AgregarCentroEducativo()
    {
        if (string.IsNullOrWhiteSpace(nuevoCE.NombreCentroEducativo)) return;
        Model.CentrosEducativos ??= new();
        Model.CentrosEducativos.Add(new CentroEducativoItemDto { TipoCentroEducativo = nuevoCE.TipoCentroEducativo, NombreCentroEducativo = nuevoCE.NombreCentroEducativo });
        nuevoCE = new();
    }

    private void QuitarCentroEducativo(CentroEducativoItemDto ce) => (Model.CentrosEducativos ?? new()).Remove(ce);

    private void AgregarAutoridad()
    {
        if (string.IsNullOrWhiteSpace(nuevaAut.TipoAutoridad) && string.IsNullOrWhiteSpace(nuevaAut.NombreAutoridad)) return;
        Model.Autoridades ??= new();
        Model.Autoridades.Add(new AutoridadItemDto { TipoAutoridad = nuevaAut.TipoAutoridad, NombreAutoridad = nuevaAut.NombreAutoridad });
        nuevaAut = new();
    }

    private void QuitarAutoridad(AutoridadItemDto a) => (Model.Autoridades ?? new()).Remove(a);

    private async Task AbrirModalEstablecimiento()
    {
        if (Model.IdEstablecimiento == null) return;
        var est = Establecimientos.FirstOrDefault(e => e.IdEstablecimiento == Model.IdEstablecimiento);
        if (est == null) return;
        await DialogService.OpenAsync<EstablecimientoInfoModal>("Información del establecimiento", new Dictionary<string, object> { ["Establecimiento"] = est }, new DialogOptions { Width = "420px" });
    }
}
