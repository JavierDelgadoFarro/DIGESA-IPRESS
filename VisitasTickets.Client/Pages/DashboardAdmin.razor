    // PREPARADO PARA API - Método que se puede reemplazar fácilmente
    private async Task RefreshData()
    {
        isRefreshing = true;
        StateHasChanged();

        // Simular llamada a la API
        await Task.Delay(1000);

        // TODO: Reemplazar con llamada real a la API
        // estadisticas = await AuthService.GetEstadisticasAsync();
        // actividadesRecientes = await AuthService.GetActividadesRecientesAsync();

        // Por ahora, recargar datos simulados
        CargarDatosSimulados();

        isRefreshing = false;
        StateHasChanged();
    }

    // Métodos auxiliares para estilos dinámicos
    private string GetColorClass(string tipo) => tipo switch
    {
        "usuario" => "bg-blue-600",
        "ticket" => "bg-amber-600",
        "visita" => "bg-green-600",
        "reporte" => "bg-purple-600",
        _ => "bg-gray-600"
    };

    private string GetBadgeClass(string estado) => estado switch
    {
        "Completado" => "bg-green-100 text-green-800",
        "En Proceso" => "bg-blue-100 text-blue-800",
        "Pendiente" => "bg-amber-100 text-amber-800",
        _ => "bg-gray-100 text-gray-800"
    };

