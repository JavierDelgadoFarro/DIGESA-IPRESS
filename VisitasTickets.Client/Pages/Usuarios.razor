@page "/usuarios"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout
@using VisitasTickets.Client.Services
@using VisitasTickets.Domain.Entities
@inject UsuarioService UsuarioService

<PageTitle>Gestión de Usuarios</PageTitle>

<!-- Container Principal con diseño limpio -->
<div class="max-w-7xl mx-auto space-y-6">
    <!-- Card con Header y Búsqueda -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <!-- 1. HEADER SECTION - Filtro de estado (línea ~28) -->
        <div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
            <!-- Buscador -->
            <div class="flex-1 max-w-md">
                <div class="relative">
                    <input type="text"
                           @bind="searchText"
                           @bind:event="oninput"
                           placeholder="Buscar..."
                           class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm">
                    <svg class="absolute right-3 top-2.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>
            </div>

            <!-- Filtro de estado - CORREGIDO -->
            <div class="mx-4 flex-shrink-0">
                <select @bind="estadoFiltro" @bind:after="StateHasChanged"
                        class="min-w-[140px] px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                    <option value="">Todos</option>
                    <option value="Activo">Activo</option>
                    <option value="Inactivo">Inactivo</option>
                </select>
            </div>

            <!-- Botón Add -->
            <button @onclick="AbrirModalNuevo"
                    class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors shadow-sm flex-shrink-0">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Nuevo
            </button>
        </div>

        <!-- Tabla -->
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left">
                            <button class="flex items-center gap-1 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-gray-900 focus:outline-none">
                                Personal
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
                                </svg>
                            </button>
                        </th>
                        <th scope="col" class="px-6 py-3 text-left">
                            <button class="flex items-center gap-1 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-gray-900 focus:outline-none">
                                Usuario
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
                                </svg>
                            </button>
                        </th>
                        <th scope="col" class="px-6 py-3 text-left">
                            <button class="flex items-center gap-1 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-gray-900 focus:outline-none">
                                Estado
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
                                </svg>
                            </button>
                        </th>
                        <th scope="col" class="px-6 py-3 text-center">
                            <span class="text-xs font-semibold text-gray-600 uppercase tracking-wider">Acciones</span>
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (PagedUsuarios.Any())
                    {
                        @foreach (var usuario in PagedUsuarios)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full @GetColorAvatar(usuario.ApellidosNombrePer) flex items-center justify-center text-white font-semibold text-xs">
                                            @GetInitials(usuario.ApellidosNombrePer)
                                        </div>
                                        <span class="text-sm font-medium text-gray-900">@usuario.ApellidosNombrePer</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm text-gray-700">@usuario.NombreUsuarioUsu</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (usuario.EstadoTexto == "Activo")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <button @onclick="() => AbrirModalEditar(usuario)"
                                                class="p-2 text-gray-500 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
                                                title="Editar">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                            </svg>
                                        </button>
                                        <button @onclick="() => ConfirmarReset(usuario)"
                                                class="p-2 text-gray-500 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg transition-colors"
                                                title="Resetear contraseña">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                                            </svg>
                                        </button>
                                    <button @onclick="() => ConfirmarEliminar(usuario)"
                                            class="p-2 rounded-lg transition-colors
                                            @(usuario.EstadoTexto == "Activo"
                                                        ? "text-gray-500 hover:text-red-600 hover:bg-red-50"
                                                        : "text-gray-500 hover:text-green-600 hover:bg-green-50")"
                                            title="@(usuario.EstadoTexto == "Activo" ? "Desactivar" : "Activar")">

                                            <!-- Ícono Power -->
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      stroke-width="2"
                                                      d="M12 2v10m6.364-4.364a9 9 0 11-12.728 0" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-16 text-center">
                                <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                                </svg>
                                <p class="text-sm text-gray-500">No se encontraron usuarios</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 2. FOOTER - Items por página (línea ~180) -->
        <div class="flex items-center justify-between px-6 py-3 border-t border-gray-200 bg-gray-50">
            <!-- Items por página - CORREGIDO -->
            <div class="flex items-center gap-2 text-sm text-gray-700 flex-shrink-0">
                <span class="whitespace-nowrap">Mostrar</span>
                <select @bind="pageSize" @bind:after="StateHasChanged"
                        class="min-w-[70px] px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
                <span class="whitespace-nowrap">por página</span>
            </div>

            <!-- Paginación -->
            <div class="flex items-center gap-2 flex-shrink-0">
                <span class="text-sm text-gray-700 mr-4 whitespace-nowrap">
                    @((currentPage - 1) * pageSize + 1)-@Math.Min(currentPage * pageSize, FilteredUsuarios.Count()) de @FilteredUsuarios.Count()
                </span>

                <button @onclick="() => { currentPage = 1; StateHasChanged(); }"
                        disabled="@(currentPage == 1)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
                    </svg>
                </button>

                <button @onclick="PrevPage"
                        disabled="@(currentPage == 1)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                </button>

                <button class="px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-lg min-w-[40px]">
                    @currentPage
                </button>

                <button @onclick="NextPage"
                        disabled="@(currentPage == totalPages)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </button>

                <button @onclick="() => { currentPage = totalPages; StateHasChanged(); }"
                        disabled="@(currentPage == totalPages)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Modal Crear/Editar Usuario -->
@if (mostrarModal)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 animate-fadeIn" @onclick="CerrarModal">
        <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto animate-slideIn" @onclick:stopPropagation="true">
            <!-- Header del Modal -->
            <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white px-6 py-4 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-bold">@(esEdicion ? "Editar Usuario" : "Nuevo Usuario")</h2>
                    <button @onclick="CerrarModal" class="p-2 hover:bg-blue-700 rounded-lg transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Formulario -->
            <div class="p-6 space-y-6">
                @if (!string.IsNullOrEmpty(mensajeError))
                {
                    <div class="bg-red-50 border-l-4 border-red-500 p-4 rounded-r-lg">
                        <p class="text-sm text-red-700 font-medium">@mensajeError</p>
                    </div>
                }

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Nombres *</label>
                        <input type="text"
                               @bind="usuarioEditando.IdPersonalNavigation.Nombre"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"/>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Apellido Paterno *</label>
                        <input type="text"
                               @bind="usuarioEditando.IdPersonalNavigation.Paterno"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"/>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Apellido Materno *</label>
                        <input type="text"
                               @bind="usuarioEditando.IdPersonalNavigation.Materno"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"/>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-gray-700 mb-2">Usuario *</label>
                        <input type="text"
                               @bind="usuarioEditando.NombreUsuarioUsu"
                               class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"/>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
                    <button @onclick="CerrarModal"
                            class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Cancelar
                    </button>
                    <button @onclick="GuardarUsuario"
                            class="px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg font-medium hover:from-blue-700 hover:to-blue-800 transition-all shadow-lg hover:shadow-xl">
                        @(esEdicion ? "Actualizar" : "Crear") Usuario
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Confirmar Eliminación -->
@if (mostrarModalEliminar)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 animate-fadeIn">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full animate-slideIn">
            <div class="p-6">
                <div class="w-16 h-16 @(usuarioEliminar?.EstadoTexto == "Activo" ? "bg-red-100" : "bg-green-100") rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 @(usuarioEliminar?.EstadoTexto == "Activo" ? "text-red-600" : "text-green-600")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 text-center mb-2">¿Cambiar estado del usuario?</h3>
                <p class="text-gray-600 text-center mb-6">
                    ¿Estás seguro de que deseas @(usuarioEliminar?.EstadoTexto == "Activo" ? "desactivar" : "activar") a
                    <span class="font-semibold">@usuarioEliminar?.NombreUsuarioUsu</span>?
                </p>
                <div class="flex gap-3">
                    <button @onclick="() => mostrarModalEliminar = false"
                            class="flex-1 px-4 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Cancelar
                    </button>
                    <button @onclick="EliminarUsuario"
                            class="flex-1 px-4 py-3 @(usuarioEliminar?.EstadoTexto == "Activo" ? "bg-gradient-to-r from-red-500 to-red-600" : "bg-gradient-to-r from-green-500 to-green-600") text-white rounded-lg font-medium hover:shadow-lg transition-all">
                        @(usuarioEliminar?.EstadoTexto == "Activo" ? "Desactivar" : "Activar")
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Modal Reset Contraseña -->
@if (mostrarModalReset)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 animate-fadeIn">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full animate-slideIn">
            <div class="p-6">
                <div class="w-16 h-16 bg-yellow-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <svg class="w-8 h-8 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 text-center mb-2">¿Resetear Contraseña?</h3>
                <p class="text-gray-600 text-center mb-6">
                    ¿Estás seguro de que deseas resetear la contraseña de
                    <span class="font-semibold">@usuarioReset?.NombreUsuarioUsu</span>?
                    <br />
                    Se asignará la contraseña por defecto.
                </p>
                <div class="flex gap-3">
                    <button @onclick="() => mostrarModalReset = false"
                            class="flex-1 px-4 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Cancelar
                    </button>
                    <button @onclick="ResetearContrasena"
                            class="flex-1 px-4 py-3 bg-gradient-to-r from-yellow-500 to-yellow-600 text-white rounded-lg font-medium hover:shadow-lg transition-all">
                        Resetear
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<!-- Toast Notifications -->
@if (mostrarToast)
{
    <div class="fixed bottom-4 right-4 @toastColor text-white px-6 py-4 rounded-lg shadow-2xl transition-all duration-500 flex items-center gap-3 animate-slideIn">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            @if (toastColor == "bg-green-600")
            {
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            }
            else
            {
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            }
        </svg>
        <span class="font-medium">@mensajeToast</span>
    </div>
}

<!-- Estilos CSS -->
<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }

    .animate-slideIn {
        animation: slideIn 0.3s ease-out;
    }
</style>

@code {
    private List<UsuarioModel> usuariosTodos = new();
    private bool mostrarModal = false;
    private bool esEdicion = false;
    private AdmUsuario usuarioEditando = new() { IdPersonalNavigation = new AdmPersonal() };
    private bool mostrarModalEliminar = false;
    private UsuarioModel? usuarioEliminar;
    private string mensajeError = "";
    private bool mostrarModalReset = false;
    private UsuarioModel? usuarioReset;

    private bool mostrarToast = false;
    private string mensajeToast = "";
    private string toastColor = "bg-green-600";

    private string searchText = "";
    private string estadoFiltro = "";
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        usuariosTodos = await UsuarioService.GetUsuariosAsync();
    }

    private void AbrirModalNuevo()
    {
        esEdicion = false;
        usuarioEditando = new AdmUsuario
        {
            IdPersonalNavigation = new AdmPersonal()
        };
        mostrarModal = true;
    }

    private async Task AbrirModalEditar(UsuarioModel usuarioDto)
    {
        var dto = await UsuarioService.GetUsuarioCompletoAsync(usuarioDto.IdUsuario);

        if (dto != null)
        {
            usuarioEditando = new AdmUsuario
            {
                IdUsuario = dto.IdUsuario,
                NombreUsuarioUsu = dto.NombreUsuarioUsu,
                IdPersonalNavigation = new AdmPersonal
                {
                    Paterno = dto.Paterno,
                    Materno = dto.Materno,
                    Nombre = dto.Nombre
                }
            };

            esEdicion = true;
            mostrarModal = true;
        }
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        usuarioEditando = new AdmUsuario
        {
            IdPersonalNavigation = new AdmPersonal()
        };
        mensajeError = "";
    }

    private async Task GuardarUsuario()
    {
        mensajeError = "";

        if (string.IsNullOrWhiteSpace(usuarioEditando.NombreUsuarioUsu))
        {
            mensajeError = "El nombre de usuario es obligatorio.";
            return;
        }

        if (string.IsNullOrWhiteSpace(usuarioEditando.IdPersonalNavigation?.Paterno) ||
            string.IsNullOrWhiteSpace(usuarioEditando.IdPersonalNavigation?.Materno) ||
            string.IsNullOrWhiteSpace(usuarioEditando.IdPersonalNavigation?.Nombre))
        {
            mensajeError = "Debe ingresar Apellido paterno, Apellido materno y Nombre del personal.";
            return;
        }

        bool ok = esEdicion
            ? await UsuarioService.UpdateUsuarioAsync(usuarioEditando.IdUsuario, usuarioEditando)
            : await UsuarioService.CreateUsuarioAsync(usuarioEditando);

        if (ok)
        {
            usuariosTodos = await UsuarioService.GetUsuariosAsync();
            CerrarModal();

            mensajeToast = esEdicion ? "Usuario actualizado correctamente." : "Usuario creado correctamente.";
            toastColor = "bg-green-600";
        }
        else
        {
            mensajeError = "Error al guardar el usuario.";
            mensajeToast = "Error al guardar el usuario.";
            toastColor = "bg-red-600";
        }

        mostrarToast = true;
        StateHasChanged();
        await Task.Delay(3000);
        mostrarToast = false;
        StateHasChanged();
    }

    private void ConfirmarEliminar(UsuarioModel usuarioDto)
    {
        usuarioEliminar = usuarioDto;
        mostrarModalEliminar = true;
    }

    private async Task EliminarUsuario()
    {
        if (usuarioEliminar != null)
        {
            var ok = await UsuarioService.DeleteUsuarioAsync(usuarioEliminar.IdUsuario);
            if (ok)
            {
                usuariosTodos = await UsuarioService.GetUsuariosAsync();

                var actualizado = usuariosTodos.FirstOrDefault(u => u.IdUsuario == usuarioEliminar.IdUsuario);

                mostrarModalEliminar = false;
                usuarioEliminar = null;

                if (actualizado != null)
                {
                    mensajeToast = actualizado.EstadoTexto == "Activo"
                        ? $"Usuario {actualizado.NombreUsuarioUsu} activado correctamente."
                        : $"Usuario {actualizado.NombreUsuarioUsu} desactivado correctamente.";

                    toastColor = actualizado.EstadoTexto == "Activo" ? "bg-green-600" : "bg-red-600";
                }
            }
            else
            {
                mostrarModalEliminar = false;
                usuarioEliminar = null;

                mensajeToast = "Error al cambiar estado del usuario.";
                toastColor = "bg-red-600";
            }

            mostrarToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            mostrarToast = false;
            StateHasChanged();
        }
    }

    private void ConfirmarReset(UsuarioModel usuarioDto)
    {
        usuarioReset = usuarioDto;
        mostrarModalReset = true;
    }

    private async Task ResetearContrasena()
    {
        if (usuarioReset != null)
        {
            var ok = await UsuarioService.ResetPasswordAsync(usuarioReset.IdUsuario);
            if (ok)
            {
                usuariosTodos = await UsuarioService.GetUsuariosAsync();

                mensajeToast = $"Contraseña de {usuarioReset.NombreUsuarioUsu} reseteada correctamente.";
                toastColor = "bg-green-600";
            }
            else
            {
                mensajeToast = "Error al resetear la contraseña.";
                toastColor = "bg-red-600";
            }

            mostrarModalReset = false;
            usuarioReset = null;

            mostrarToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            mostrarToast = false;
            StateHasChanged();
        }
    }

    private IEnumerable<UsuarioModel> FilteredUsuarios =>
        usuariosTodos.Where(u =>
            (string.IsNullOrEmpty(searchText) ||
             (u.NombreUsuarioUsu?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (u.ApellidosNombrePer?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            &&
            (string.IsNullOrEmpty(estadoFiltro) || u.EstadoTexto == estadoFiltro));

    private int totalPages => (int)Math.Ceiling((double)FilteredUsuarios.Count() / pageSize);

    private IEnumerable<UsuarioModel> PagedUsuarios =>
        FilteredUsuarios.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private void NextPage() { if (currentPage < totalPages) currentPage++; }
    private void PrevPage() { if (currentPage > 1) currentPage--; }

    private string GetInitials(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "??";

        var parts = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();

        return nombre.Length >= 2 ? nombre.Substring(0, 2).ToUpper() : nombre.ToUpper();
    }

    private string GetColorAvatar(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "bg-blue-500";

        var colors = new[] { "bg-blue-500", "bg-green-500", "bg-purple-500", "bg-pink-500", "bg-indigo-500", "bg-red-500" };
        var index = Math.Abs(nombre.GetHashCode()) % colors.Length;
        return colors[index];
    }
}