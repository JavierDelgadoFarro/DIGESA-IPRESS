@page "/usuarios"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout
@using VisitasTickets.Client.Services
@using VisitasTickets.Client.Components.Common
@using VisitasTickets.Client.Components.Usuarios
@using VisitasTickets.Domain.Entities
@using static VisitasTickets.Client.Components.Common.ConfirmDialog
@inject UsuarioService UsuarioService
@inject NotificationService NotificationService

<PageTitle>Gestión de Usuarios</PageTitle>

<!-- Container Principal con diseño limpio -->
<div class="max-w-7xl mx-auto space-y-6">
    <!-- Card con Header y Búsqueda -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-200 overflow-hidden">
        <!-- Componente de Filtros -->
        <UsuarioFilters SearchText="@searchText"
                        EstadoFiltro="@estadoFiltro"
                        SearchTextChanged="@((value) => { searchText = value; StateHasChanged(); })"
                        EstadoFiltroChanged="@((value) => { estadoFiltro = value; StateHasChanged(); })"
                        OnNuevoClick="@AbrirModalNuevo" />

        <!-- Tabla -->
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-200">
                <thead class="bg-gray-50">
                    <tr>
                        <th scope="col" class="px-6 py-3 text-left">
                            <button class="flex items-center gap-1 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-gray-900 focus:outline-none">
                                Personal
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
                                </svg>
                            </button>
                        </th>
                        <th scope="col" class="px-6 py-3 text-left">
                            <button class="flex items-center gap-1 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-gray-900 focus:outline-none">
                                Usuario
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
                                </svg>
                            </button>
                        </th>
                        <th scope="col" class="px-6 py-3 text-left">
                            <button class="flex items-center gap-1 text-xs font-semibold text-gray-600 uppercase tracking-wider hover:text-gray-900 focus:outline-none">
                                Estado
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 9l4-4 4 4m0 6l-4 4-4-4"></path>
                                </svg>
                            </button>
                        </th>
                        <th scope="col" class="px-6 py-3 text-center">
                            <span class="text-xs font-semibold text-gray-600 uppercase tracking-wider">Acciones</span>
                        </th>
                    </tr>
                </thead>
                <tbody class="bg-white divide-y divide-gray-200">
                    @if (PagedUsuarios.Any())
                    {
                        @foreach (var usuario in PagedUsuarios)
                        {
                            <tr class="hover:bg-gray-50 transition-colors">
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <div class="flex items-center gap-3">
                                        <div class="w-8 h-8 rounded-full @GetColorAvatar(usuario.ApellidosNombrePer) flex items-center justify-center text-white font-semibold text-xs">
                                            @GetInitials(usuario.ApellidosNombrePer)
                                        </div>
                                        <span class="text-sm font-medium text-gray-900">@usuario.ApellidosNombrePer</span>
                                    </div>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    <span class="text-sm text-gray-700">@usuario.NombreUsuarioUsu</span>
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap">
                                    @if (usuario.EstadoTexto == "Activo")
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                                            Activo
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-800">
                                            Inactivo
                                        </span>
                                    }
                                </td>
                                <td class="px-6 py-4 whitespace-nowrap text-center">
                                    <div class="flex items-center justify-center gap-2">
                                        <button @onclick="() => AbrirModalEditar(usuario)"
                                                class="p-2 text-gray-500 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors"
                                                title="Editar">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                            </svg>
                                        </button>
                                        <button @onclick="() => ConfirmarReset(usuario)"
                                                class="p-2 text-gray-500 hover:text-yellow-600 hover:bg-yellow-50 rounded-lg transition-colors"
                                                title="Resetear contraseña">
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                                            </svg>
                                        </button>
                                    <button @onclick="() => ConfirmarEliminar(usuario)"
                                            class="p-2 rounded-lg transition-colors
                                            @(usuario.EstadoTexto == "Activo"
                                                        ? "text-gray-500 hover:text-red-600 hover:bg-red-50"
                                                        : "text-gray-500 hover:text-green-600 hover:bg-green-50")"
                                            title="@(usuario.EstadoTexto == "Activo" ? "Desactivar" : "Activar")">

                                            <!-- Ícono Power -->
                                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round"
                                                      stroke-linejoin="round"
                                                      stroke-width="2"
                                                      d="M12 2v10m6.364-4.364a9 9 0 11-12.728 0" />
                                            </svg>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="px-6 py-16 text-center">
                                <svg class="w-12 h-12 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                                </svg>
                                <p class="text-sm text-gray-500">No se encontraron usuarios</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- 2. FOOTER - Items por página (línea ~180) -->
        <div class="flex items-center justify-between px-6 py-3 border-t border-gray-200 bg-gray-50">
            <!-- Items por página - CORREGIDO -->
            <div class="flex items-center gap-2 text-sm text-gray-700 flex-shrink-0">
                <span class="whitespace-nowrap">Mostrar</span>
                <select @bind="pageSize" @bind:after="StateHasChanged"
                        class="min-w-[70px] px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-blue-500">
                    <option value="5">5</option>
                    <option value="10">10</option>
                    <option value="20">20</option>
                    <option value="50">50</option>
                </select>
                <span class="whitespace-nowrap">por página</span>
            </div>

            <!-- Paginación -->
            <div class="flex items-center gap-2 flex-shrink-0">
                <span class="text-sm text-gray-700 mr-4 whitespace-nowrap">
                    @((currentPage - 1) * pageSize + 1)-@Math.Min(currentPage * pageSize, FilteredUsuarios.Count()) de @FilteredUsuarios.Count()
                </span>

                <button @onclick="() => { currentPage = 1; StateHasChanged(); }"
                        disabled="@(currentPage == 1)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
                    </svg>
                </button>

                <button @onclick="PrevPage"
                        disabled="@(currentPage == 1)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                </button>

                <button class="px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-lg min-w-[40px]">
                    @currentPage
                </button>

                <button @onclick="NextPage"
                        disabled="@(currentPage == totalPages)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </button>

                <button @onclick="() => { currentPage = totalPages; StateHasChanged(); }"
                        disabled="@(currentPage == totalPages)"
                        class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>
</div>

<!-- Componente Modal de Formulario -->
<UsuarioFormModal IsVisible="@mostrarModal"
                  IsEditing="@esEdicion"
                  Usuario="@usuarioEditando"
                  ErrorMessage="@mensajeError"
                  OnSave="@GuardarUsuario"
                  OnClose="@CerrarModal" />

<!-- Componente Modal de Confirmación para Eliminar/Activar -->
<ConfirmDialog IsVisible="@mostrarModalEliminar"
               Title="@(usuarioEliminar?.EstadoTexto == "Activo" ? "¿Desactivar usuario?" : "¿Activar usuario?")"
               Message="@GetMensajeEliminar()"
               Type="@(usuarioEliminar?.EstadoTexto == "Activo" ? ConfirmDialogType.Danger : ConfirmDialogType.Success)"
               Icon="@(usuarioEliminar?.EstadoTexto == "Activo" ? ConfirmDialogIcon.Warning : ConfirmDialogIcon.Success)"
               ConfirmButtonText="@(usuarioEliminar?.EstadoTexto == "Activo" ? "Desactivar" : "Activar")"
               OnConfirm="@EliminarUsuario"
               OnCancel="@(() => { mostrarModalEliminar = false; usuarioEliminar = null; })" />

<!-- Componente Modal de Reset de Contraseña -->
<ConfirmDialog IsVisible="@mostrarModalReset"
               Title="¿Resetear Contraseña?"
               Message="@GetMensajeReset()"
               Type="@ConfirmDialogType.Warning"
               Icon="@ConfirmDialogIcon.Lock"
               ConfirmButtonText="Resetear"
               OnConfirm="@ResetearContrasena"
               OnCancel="@(() => { mostrarModalReset = false; usuarioReset = null; })" />

<!-- Componente Toast -->
<Toast />

@code {
    private List<UsuarioModel> usuariosTodos = new();
    private bool mostrarModal = false;
    private bool esEdicion = false;
    private AdmUsuario usuarioEditando = new() { IdPersonalNavigation = new AdmPersonal() };
    private bool mostrarModalEliminar = false;
    private UsuarioModel? usuarioEliminar;
    private string mensajeError = "";
    private bool mostrarModalReset = false;
    private UsuarioModel? usuarioReset;

    private string searchText = "";
    private string estadoFiltro = "";
    private int currentPage = 1;
    private int pageSize = 10;

    protected override async Task OnInitializedAsync()
    {
        usuariosTodos = await UsuarioService.GetUsuariosAsync();
    }

    private void AbrirModalNuevo()
    {
        esEdicion = false;
        usuarioEditando = new AdmUsuario
        {
            IdPersonalNavigation = new AdmPersonal()
        };
        mostrarModal = true;
    }

    private async Task AbrirModalEditar(UsuarioModel usuarioDto)
    {
        var dto = await UsuarioService.GetUsuarioCompletoAsync(usuarioDto.IdUsuario);

        if (dto != null)
        {
            usuarioEditando = new AdmUsuario
            {
                IdUsuario = dto.IdUsuario,
                NombreUsuarioUsu = dto.NombreUsuarioUsu,
                IdPersonalNavigation = new AdmPersonal
                {
                    Paterno = dto.Paterno,
                    Materno = dto.Materno,
                    Nombre = dto.Nombre
                }
            };

            esEdicion = true;
            mostrarModal = true;
        }
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        usuarioEditando = new AdmUsuario
        {
            IdPersonalNavigation = new AdmPersonal()
        };
        mensajeError = "";
    }

    private async Task GuardarUsuario()
    {
        mensajeError = "";

        if (string.IsNullOrWhiteSpace(usuarioEditando.NombreUsuarioUsu))
        {
            mensajeError = "El nombre de usuario es obligatorio.";
            return;
        }

        if (string.IsNullOrWhiteSpace(usuarioEditando.IdPersonalNavigation?.Paterno) ||
            string.IsNullOrWhiteSpace(usuarioEditando.IdPersonalNavigation?.Materno) ||
            string.IsNullOrWhiteSpace(usuarioEditando.IdPersonalNavigation?.Nombre))
        {
            mensajeError = "Debe ingresar Apellido paterno, Apellido materno y Nombre del personal.";
            return;
        }

        bool ok = esEdicion
            ? await UsuarioService.UpdateUsuarioAsync(usuarioEditando.IdUsuario, usuarioEditando)
            : await UsuarioService.CreateUsuarioAsync(usuarioEditando);

        if (ok)
        {
            usuariosTodos = await UsuarioService.GetUsuariosAsync();
            CerrarModal();
            NotificationService.ShowSuccess(esEdicion ? "Usuario actualizado correctamente." : "Usuario creado correctamente.");
        }
        else
        {
            mensajeError = "Error al guardar el usuario.";
            NotificationService.ShowError("Error al guardar el usuario.");
        }
    }

    private void ConfirmarEliminar(UsuarioModel usuarioDto)
    {
        usuarioEliminar = usuarioDto;
        mostrarModalEliminar = true;
    }

    private async Task EliminarUsuario()
    {
        if (usuarioEliminar != null)
        {
            var ok = await UsuarioService.DeleteUsuarioAsync(usuarioEliminar.IdUsuario);
            if (ok)
            {
                usuariosTodos = await UsuarioService.GetUsuariosAsync();
                var actualizado = usuariosTodos.FirstOrDefault(u => u.IdUsuario == usuarioEliminar.IdUsuario);

                mostrarModalEliminar = false;
                usuarioEliminar = null;

                if (actualizado != null)
                {
                    var mensaje = actualizado.EstadoTexto == "Activo"
                        ? $"Usuario {actualizado.NombreUsuarioUsu} activado correctamente."
                        : $"Usuario {actualizado.NombreUsuarioUsu} desactivado correctamente.";

                    if (actualizado.EstadoTexto == "Activo")
                        NotificationService.ShowSuccess(mensaje);
                    else
                        NotificationService.ShowError(mensaje);
                }
            }
            else
            {
                mostrarModalEliminar = false;
                usuarioEliminar = null;
                NotificationService.ShowError("Error al cambiar estado del usuario.");
            }
        }
    }

    private void ConfirmarReset(UsuarioModel usuarioDto)
    {
        usuarioReset = usuarioDto;
        mostrarModalReset = true;
    }

    private async Task ResetearContrasena()
    {
        if (usuarioReset != null)
        {
            var ok = await UsuarioService.ResetPasswordAsync(usuarioReset.IdUsuario);
            if (ok)
            {
                usuariosTodos = await UsuarioService.GetUsuariosAsync();
                NotificationService.ShowSuccess($"Contraseña de {usuarioReset.NombreUsuarioUsu} reseteada correctamente.");
            }
            else
            {
                NotificationService.ShowError("Error al resetear la contraseña.");
            }

            mostrarModalReset = false;
            usuarioReset = null;
        }
    }

    private IEnumerable<UsuarioModel> FilteredUsuarios =>
        usuariosTodos.Where(u =>
            (string.IsNullOrEmpty(searchText) ||
             (u.NombreUsuarioUsu?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
             (u.ApellidosNombrePer?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false))
            &&
            (string.IsNullOrEmpty(estadoFiltro) || u.EstadoTexto == estadoFiltro));

    private int totalPages => (int)Math.Ceiling((double)FilteredUsuarios.Count() / pageSize);

    private IEnumerable<UsuarioModel> PagedUsuarios =>
        FilteredUsuarios.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private void NextPage() { if (currentPage < totalPages) currentPage++; }
    private void PrevPage() { if (currentPage > 1) currentPage--; }

    private string GetInitials(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "??";

        var parts = nombre.Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
            return $"{parts[0][0]}{parts[1][0]}".ToUpper();

        return nombre.Length >= 2 ? nombre.Substring(0, 2).ToUpper() : nombre.ToUpper();
    }

    private string GetColorAvatar(string? nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre)) return "bg-blue-500";

        var colors = new[] { "bg-blue-500", "bg-green-500", "bg-purple-500", "bg-pink-500", "bg-indigo-500", "bg-red-500" };
        var index = Math.Abs(nombre.GetHashCode()) % colors.Length;
        return colors[index];
    }

    private string GetMensajeEliminar()
    {
        if (usuarioEliminar == null) return "";
        var accion = usuarioEliminar.EstadoTexto == "Activo" ? "desactivar" : "activar";
        return $"¿Estás seguro de que deseas <strong>{accion}</strong> a <strong>{usuarioEliminar.NombreUsuarioUsu}</strong>?";
    }

    private string GetMensajeReset()
    {
        if (usuarioReset == null) return "";
        return $"¿Estás seguro de que deseas resetear la contraseña de <strong>{usuarioReset.NombreUsuarioUsu}</strong>?<br/>Se asignará la contraseña por defecto.";
    }
}