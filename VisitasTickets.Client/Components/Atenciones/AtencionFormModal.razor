@using VisitasTickets.Domain.Dtos

@if (IsVisible)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 animate-fadeIn" @onclick="Cerrar">
        <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto animate-slideIn" @onclick:stopPropagation="true">
            <!-- Header del Modal -->
            <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white px-6 py-4 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-bold">📋 Nueva Atención</h2>
                    <button @onclick="Cerrar" class="p-2 hover:bg-blue-700 rounded-lg transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Formulario -->
            <div class="p-6 space-y-6">
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="bg-rose-50 border-l-4 border-rose-600 p-4 rounded-r-lg">
                        <p class="text-sm text-rose-700 font-medium">@ErrorMessage</p>
                    </div>
                }

                <!-- Sección 1: Datos del Ciudadano -->
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                        Datos del Ciudadano
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Documento *</label>
                            <div class="flex gap-4">
                                <label class="flex items-center cursor-pointer">
                                    <input type="radio"
                                           value="DNI"
                                           checked="@(TipoDocumento == "DNI")"
                                           @onchange="@(e => TipoDocumentoChanged.InvokeAsync("DNI"))"
                                           class="w-4 h-4 text-blue-600 focus:ring-blue-500">
                                    <span class="ml-2 text-sm font-medium text-gray-700">DNI</span>
                                </label>
                                <label class="flex items-center cursor-pointer">
                                    <input type="radio"
                                           value="CE"
                                           checked="@(TipoDocumento == "CE")"
                                           @onchange="@(e => TipoDocumentoChanged.InvokeAsync("CE"))"
                                           class="w-4 h-4 text-blue-600 focus:ring-blue-500">
                                    <span class="ml-2 text-sm font-medium text-gray-700">Carnet de Extranjería</span>
                                </label>
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                Número de @(TipoDocumento == "DNI" ? "DNI" : "Carnet") *
                            </label>
                            <input type="text"
                                   value="@NumeroDocumento"
                                   @oninput="@(e => NumeroDocumentoChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   maxlength="@(TipoDocumento == "DNI" ? "8" : "20")"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="@(TipoDocumento == "DNI" ? "Ingrese 8 dígitos" : "Ingrese número")"/>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Nombres *</label>
                            <input type="text"
                                   value="@Nombres"
                                   @oninput="@(e => NombresChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="Ingrese nombres"/>
                        </div>

                        <div class="md:col-span-2">
                            <label class="block text-sm font-medium text-gray-700 mb-2">Apellidos *</label>
                            <input type="text"
                                   value="@Apellidos"
                                   @oninput="@(e => ApellidosChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="Ingrese apellidos"/>
                        </div>
                    </div>
                </div>

                <hr class="my-6 border-gray-200">

                <!-- Sección 2: Datos de la Atención -->
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Datos de la Atención
                    </h3>
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Trámite *</label>
                            <select value="@IdTipoTramite"
                                    @onchange="@(e => IdTipoTramiteChanged.InvokeAsync(int.Parse(e.Value?.ToString() ?? "0")))"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                <option value="0">-- Seleccione un trámite --</option>
                                @foreach (var tramite in TiposTramite)
                                {
                                    <option value="@tramite.IdTipoTramite">@tramite.NombreTramite</option>
                                }
                            </select>
                            @if (IdTipoTramite > 0)
                            {
                                var tramiteSeleccionado = TiposTramite.FirstOrDefault(t => t.IdTipoTramite == IdTipoTramite);
                                if (tramiteSeleccionado != null && !string.IsNullOrEmpty(tramiteSeleccionado.Descripcion))
                                {
                                    <p class="mt-2 text-xs text-gray-600 bg-gray-50 p-3 rounded border border-gray-200">
                                        📌 @tramiteSeleccionado.Descripcion
                                    </p>
                                }
                            }
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Observación (Opcional)</label>
                            <textarea value="@Observacion"
                                      @oninput="@(e => ObservacionChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                      rows="3"
                                      maxlength="500"
                                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none"
                                      placeholder="Agregue alguna observación adicional..."></textarea>
                            <p class="text-xs text-gray-500 mt-1">@(Observacion?.Length ?? 0)/500 caracteres</p>
                        </div>

                        <!-- Atención Preferencial -->
                        <div class="bg-amber-50 border-2 border-amber-100 rounded-lg p-4">
                            <label class="flex items-center cursor-pointer">
                                <input type="checkbox"
                                       checked="@EsPreferencial"
                                       @onchange="@(e => EsPreferencialChanged.InvokeAsync((bool)e.Value!))"
                                       class="w-5 h-5 text-amber-600 rounded focus:ring-2 focus:ring-amber-500">
                                <span class="ml-3 text-sm font-semibold text-gray-900">⭐ Atención Preferencial</span>
                            </label>

                            @if (EsPreferencial)
                            {
                                <div class="mt-4">
                                    <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Preferencia *</label>
                                    <select value="@(IdTipoPreferencial ?? 0)"
                                            @onchange="@(e => IdTipoPreferencialChanged.InvokeAsync(int.Parse(e.Value?.ToString() ?? "0")))"
                                            class="w-full px-4 py-3 border border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white">
                                        <option value="0">-- Seleccione el motivo --</option>
                                        @foreach (var tipo in TiposPreferencial)
                                        {
                                            <option value="@tipo.IdTipoPreferencial">@tipo.NombreTipoPreferencial</option>
                                        }
                                    </select>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-slate-200">
                    <button @onclick="Cerrar"
                            class="px-6 py-3 border border-slate-300 rounded-lg text-slate-700 font-medium hover:bg-slate-50 active:scale-95 transition-all">
                        Cancelar
                    </button>
                    <button @onclick="Guardar"
                            class="px-6 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 active:scale-95 transition-all shadow-sm">
                        Registrar Atención
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }

    .animate-slideIn {
        animation: slideIn 0.3s ease-out;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string TipoDocumento { get; set; } = "DNI";
    [Parameter] public EventCallback<string> TipoDocumentoChanged { get; set; }
    [Parameter] public string NumeroDocumento { get; set; } = "";
    [Parameter] public EventCallback<string> NumeroDocumentoChanged { get; set; }
    [Parameter] public string Nombres { get; set; } = "";
    [Parameter] public EventCallback<string> NombresChanged { get; set; }
    [Parameter] public string Apellidos { get; set; } = "";
    [Parameter] public EventCallback<string> ApellidosChanged { get; set; }
    [Parameter] public int IdTipoTramite { get; set; }
    [Parameter] public EventCallback<int> IdTipoTramiteChanged { get; set; }
    [Parameter] public string Observacion { get; set; } = "";
    [Parameter] public EventCallback<string> ObservacionChanged { get; set; }
    [Parameter] public bool EsPreferencial { get; set; }
    [Parameter] public EventCallback<bool> EsPreferencialChanged { get; set; }
    [Parameter] public int? IdTipoPreferencial { get; set; }
    [Parameter] public EventCallback<int?> IdTipoPreferencialChanged { get; set; }
    [Parameter] public List<TipoTramiteDto> TiposTramite { get; set; } = new();
    [Parameter] public List<TipoPreferencialDto> TiposPreferencial { get; set; } = new();
    [Parameter] public string ErrorMessage { get; set; } = "";
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task Guardar()
    {
        await OnSave.InvokeAsync();
    }

    private async Task Cerrar()
    {
        await OnClose.InvokeAsync();
    }
}
