@using VisitasTickets.Domain.Dtos
@using VisitasTickets.Client.Services
@inject VisitanteService VisitanteService

@if (IsVisible)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 animate-fadeIn" @onclick="Cerrar">
        <div class="bg-white rounded-2xl shadow-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto animate-slideIn" @onclick:stopPropagation="true">
            <!-- Header del Modal -->
            <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white px-6 py-4 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-bold">📋 Nueva Atención</h2>
                    <button @onclick="Cerrar" class="p-2 hover:bg-blue-700 rounded-lg transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Formulario -->
            <div class="p-6 space-y-6">
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="bg-rose-50 border-l-4 border-rose-600 p-4 rounded-r-lg">
                        <p class="text-sm text-rose-700 font-medium">@ErrorMessage</p>
                    </div>
                }

                <!-- Sección 1: Datos del Ciudadano -->
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                        Datos del Ciudadano
                    </h3>
                    <div class="space-y-6">
                        <!-- Atención Preferencial - PRIMERO -->
                        <div class="p-4 border-2 border-amber-300 bg-amber-50 rounded-xl">
                            <label class="flex items-center cursor-pointer">
                                <input type="checkbox"
                                       checked="@EsPreferencial"
                                       @onchange="@(e => EsPreferencialChanged.InvokeAsync((bool)e.Value!))"
                                       class="w-6 h-6 text-amber-600 border-2 border-amber-400 rounded focus:ring-2 focus:ring-amber-500">
                                <span class="ml-3 text-base font-bold text-amber-900">⭐ Atención Preferencial</span>
                            </label>
                            <p class="text-xs text-amber-700 mt-2 ml-9">Marque si tiene prioridad de atención (adulto mayor, gestante, discapacidad, etc.)</p>
                        </div>

                        <!-- Tipo Preferencial (si aplica) -->
                        @if (EsPreferencial)
                        {
                            <div class="pl-8 border-l-4 border-amber-400 bg-amber-50 p-4 rounded-r-lg">
                                <label class="block text-sm font-semibold text-amber-900 mb-2">Motivo Preferencial *</label>
                                <select value="@(IdTipoPreferencial ?? 0)"
                                        @onchange="@(e => IdTipoPreferencialChanged.InvokeAsync(int.Parse(e.Value?.ToString() ?? "0")))"
                                        class="w-full px-4 py-3 border-2 border-amber-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-amber-500 bg-white">
                                    <option value="0">-- Seleccione el motivo --</option>
                                    @foreach (var tipo in TiposPreferencial)
                                    {
                                        <option value="@tipo.IdTipoPreferencial">@tipo.NombreTipoPreferencial</option>
                                    }
                                </select>
                            </div>
                        }

                        <!-- Tipo de Documento -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-3">Tipo de Documento *</label>
                            <div class="flex gap-4">
                                <label class="flex items-center cursor-pointer px-6 py-3 border-2 rounded-lg transition-all @(TipoDocumento == "DNI" ? "border-blue-500 bg-blue-50" : "border-gray-300")">
                                    <input type="radio"
                                           value="DNI"
                                           checked="@(TipoDocumento == "DNI")"
                                           @onchange="@(e => CambiarTipoDocumento("DNI"))"
                                           class="w-4 h-4 text-blue-600 focus:ring-blue-500">
                                    <span class="ml-3 text-sm font-medium">📄 DNI</span>
                                </label>
                                <label class="flex items-center cursor-pointer px-6 py-3 border-2 rounded-lg transition-all @(TipoDocumento == "CE" ? "border-blue-500 bg-blue-50" : "border-gray-300")">
                                    <input type="radio"
                                           value="CE"
                                           checked="@(TipoDocumento == "CE")"
                                           @onchange="@(e => CambiarTipoDocumento("CE"))"
                                           class="w-4 h-4 text-blue-600 focus:ring-blue-500">
                                    <span class="ml-3 text-sm font-medium">🛂 Carnet de Extranjería</span>
                                </label>
                            </div>
                        </div>

                        <!-- Número de Documento CON BOTÓN BUSCAR -->
                        <div>
                            <!-- Aviso informativo -->
                            <div class="bg-blue-50 border-l-4 border-blue-400 p-3 mb-3 rounded-r-lg">
                                <p class="text-sm text-blue-800 font-medium">🔍 Primero busque su documento para verificar si ya está registrado en el sistema</p>
                            </div>
                            
                            <label class="block text-sm font-semibold text-gray-700 mb-2">
                                Número de @(TipoDocumento == "DNI" ? "DNI" : "Carnet") *
                            </label>
                            <div class="flex gap-2">
                                <input type="text"
                                       value="@NumeroDocumento"
                                       @oninput="@ValidarDocumento"
                                       maxlength="@(TipoDocumento == "DNI" ? "8" : "12")"
                                       class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all text-lg"
                                       placeholder="@(TipoDocumento == "DNI" ? "8 dígitos" : "Hasta 12 caracteres")"/>
                                <button type="button" 
                                        @onclick="BuscarPorDocumento" 
                                        disabled="@buscandoDatos"
                                        class="px-4 py-3 flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-all shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed flex-shrink-0 font-semibold active:scale-95"
                                        title="Buscar datos del documento">
                                    @if (buscandoDatos)
                                    {
                                        <span class="text-lg">⏳</span>
                                        <span class="hidden sm:inline">Buscando...</span>
                                    }
                                    else
                                    {
                                        <span class="text-lg">🔍</span>
                                        <span class="hidden sm:inline">Buscar</span>
                                    }
                                </button>
                            </div>
                            @if (!string.IsNullOrEmpty(errorDocumento))
                            {
                                <p class="text-rose-600 text-sm mt-1">⚠️ @errorDocumento</p>
                            }
                            else if (!string.IsNullOrEmpty(NumeroDocumento))
                            {
                                <p class="text-gray-500 text-xs mt-1">
                                    @if (TipoDocumento == "DNI")
                                    {
                                        <span>@NumeroDocumento.Length de 8 dígitos</span>
                                    }
                                    else
                                    {
                                        <span>@NumeroDocumento.Length de máximo 12 caracteres</span>
                                    }
                                </p>
                            }
                            
                            @if (!string.IsNullOrEmpty(mensajeBusqueda))
                            {
                                <p class="text-sm mt-2 font-medium @(mensajeBusqueda.Contains("✅") ? "text-emerald-600" : mensajeBusqueda.Contains("❌") ? "text-rose-600" : "text-blue-600")">
                                    @mensajeBusqueda
                                </p>
                            }
                        </div>

                        <!-- Nombres - DESHABILITADO hasta buscar -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Nombres *</label>
                            <input type="text"
                                   value="@Nombres"
                                   @oninput="@(e => NombresChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   disabled="@(!camposHabilitados)"
                                   class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all disabled:bg-gray-100 disabled:cursor-not-allowed"
                                   placeholder="@(camposHabilitados ? "Ingrese nombres" : "")"/>
                        </div>

                        <!-- Apellidos - DESHABILITADO hasta buscar -->
                        <div>
                            <label class="block text-sm font-semibold text-gray-700 mb-2">Apellidos *</label>
                            <input type="text"
                                   value="@Apellidos"
                                   @oninput="@(e => ApellidosChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   disabled="@(!camposHabilitados)"
                                   class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all disabled:bg-gray-100 disabled:cursor-not-allowed"
                                   placeholder="@(camposHabilitados ? "Ingrese apellidos" : "")"/>
                        </div>
                    </div>
                </div>

                <hr class="my-6 border-gray-200">

                <!-- Sección 2: Datos de la Atención -->
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Datos de la Atención
                    </h3>
                    <div class="space-y-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Tipo de Trámite *</label>
                            <select value="@IdTipoTramite"
                                    @onchange="@(e => IdTipoTramiteChanged.InvokeAsync(int.Parse(e.Value?.ToString() ?? "0")))"
                                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all">
                                <option value="0">-- Seleccione un trámite --</option>
                                @foreach (var tramite in TiposTramite)
                                {
                                    <option value="@tramite.IdTipoTramite">@tramite.NombreTramite</option>
                                }
                            </select>
                            @if (IdTipoTramite > 0)
                            {
                                var tramiteSeleccionado = TiposTramite.FirstOrDefault(t => t.IdTipoTramite == IdTipoTramite);
                                if (tramiteSeleccionado != null && !string.IsNullOrEmpty(tramiteSeleccionado.Descripcion))
                                {
                                    <p class="mt-2 text-xs text-gray-600 bg-gray-50 p-3 rounded border border-gray-200">
                                        📌 @tramiteSeleccionado.Descripcion
                                    </p>
                                }
                            }
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Observación (Opcional)</label>
                            <textarea value="@Observacion"
                                      @oninput="@(e => ObservacionChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                      rows="3"
                                      maxlength="500"
                                      class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all resize-none"
                                      placeholder="Agregue alguna observación adicional..."></textarea>
                            <p class="text-xs text-gray-500 mt-1">@(Observacion?.Length ?? 0)/500 caracteres</p>
                        </div>
                    </div>
                </div>

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-slate-200">
                    <button @onclick="Cerrar"
                            class="px-6 py-3 border border-slate-300 rounded-lg text-slate-700 font-medium hover:bg-slate-50 active:scale-95 transition-all">
                        Cancelar
                    </button>
                    <button @onclick="Guardar"
                            class="px-6 py-3 bg-blue-600 text-white rounded-lg font-semibold hover:bg-blue-700 active:scale-95 transition-all shadow-sm">
                        Registrar Atención
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }
        to {
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }

    .animate-slideIn {
        animation: slideIn 0.3s ease-out;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public string TipoDocumento { get; set; } = "DNI";
    [Parameter] public EventCallback<string> TipoDocumentoChanged { get; set; }
    [Parameter] public string NumeroDocumento { get; set; } = "";
    [Parameter] public EventCallback<string> NumeroDocumentoChanged { get; set; }
    [Parameter] public string Nombres { get; set; } = "";
    [Parameter] public EventCallback<string> NombresChanged { get; set; }
    [Parameter] public string Apellidos { get; set; } = "";
    [Parameter] public EventCallback<string> ApellidosChanged { get; set; }
    [Parameter] public int IdTipoTramite { get; set; }
    [Parameter] public EventCallback<int> IdTipoTramiteChanged { get; set; }
    [Parameter] public string Observacion { get; set; } = "";
    [Parameter] public EventCallback<string> ObservacionChanged { get; set; }
    [Parameter] public bool EsPreferencial { get; set; }
    [Parameter] public EventCallback<bool> EsPreferencialChanged { get; set; }
    [Parameter] public int? IdTipoPreferencial { get; set; }
    [Parameter] public EventCallback<int?> IdTipoPreferencialChanged { get; set; }
    [Parameter] public List<TipoTramiteDto> TiposTramite { get; set; } = new();
    [Parameter] public List<TipoPreferencialDto> TiposPreferencial { get; set; } = new();
    [Parameter] public string ErrorMessage { get; set; } = "";
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    // Variables para búsqueda y validación
    private string errorDocumento = "";
    private bool buscandoDatos = false;
    private string mensajeBusqueda = "";
    private bool camposHabilitados = false; // Controla si nombres y apellidos están habilitados

    private async Task Guardar()
    {
        await OnSave.InvokeAsync();
    }

    private async Task Cerrar()
    {
        await OnClose.InvokeAsync();
    }

    private async Task CambiarTipoDocumento(string tipo)
    {
        await TipoDocumentoChanged.InvokeAsync(tipo);
        await NumeroDocumentoChanged.InvokeAsync(""); // Limpiar el número cuando cambia el tipo
        await NombresChanged.InvokeAsync(""); // Limpiar nombres
        await ApellidosChanged.InvokeAsync(""); // Limpiar apellidos
        errorDocumento = ""; // Limpiar el error
        mensajeBusqueda = ""; // Limpiar mensaje de búsqueda
        camposHabilitados = false; // Bloquear campos de nuevo
    }

    private async Task BuscarPorDocumento()
    {
        if (string.IsNullOrWhiteSpace(NumeroDocumento))
        {
            mensajeBusqueda = "Por favor ingrese un número de documento";
            return;
        }

        // Validar longitud según tipo de documento
        if (TipoDocumento == "DNI" && NumeroDocumento.Length != 8)
        {
            mensajeBusqueda = "El DNI debe tener 8 dígitos";
            return;
        }

        buscandoDatos = true;
        mensajeBusqueda = "";
        
        try
        {
            var datos = await VisitanteService.BuscarPorDocumentoAsync(NumeroDocumento);
            
            if (datos != null)
            {
                // Si encuentra datos, completar y MANTENER BLOQUEADOS
                await NombresChanged.InvokeAsync(datos.Nombres);
                await ApellidosChanged.InvokeAsync(datos.Apellidos);
                camposHabilitados = false; // Mantener bloqueados
                mensajeBusqueda = "✅ Datos encontrados y cargados (bloqueados)";
            }
            else
            {
                // Si NO encuentra datos, HABILITAR para que los complete manualmente
                await NombresChanged.InvokeAsync("");
                await ApellidosChanged.InvokeAsync("");
                camposHabilitados = true; // Habilitar para edición manual
                mensajeBusqueda = "ℹ️ No se encontraron datos previos. Puede ingresar los datos manualmente";
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al buscar datos: {ex.Message}");
            mensajeBusqueda = "❌ Error al buscar datos";
            camposHabilitados = false; // Mantener bloqueados en caso de error
        }
        finally
        {
            buscandoDatos = false;
        }
    }

    private async Task ValidarDocumento(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString() ?? "";
        errorDocumento = "";

        if (TipoDocumento == "DNI")
        {
            // Solo números
            if (!string.IsNullOrEmpty(valor) && !System.Text.RegularExpressions.Regex.IsMatch(valor, @"^\d+$"))
            {
                errorDocumento = "El DNI solo debe contener números";
            }
            else if (valor.Length > 8)
            {
                errorDocumento = "El DNI debe tener exactamente 8 dígitos";
            }
            else if (!string.IsNullOrEmpty(valor) && valor.Length < 8)
            {
                errorDocumento = $"Faltan {8 - valor.Length} dígitos";
            }
        }
        else if (TipoDocumento == "CE")
        {
            // Alfanumérico
            if (valor.Length > 12)
            {
                errorDocumento = "El Carnet de Extranjería no puede tener más de 12 caracteres";
            }
        }
        
        await NumeroDocumentoChanged.InvokeAsync(valor);
    }
}
