@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthProvider
@inject ILocalStorageService _localStorage
@using Microsoft.AspNetCore.Components.Authorization
@using Blazored.LocalStorage
@using VisitasTickets.Client.Services
@using VisitasTickets.Domain.Dtos
@implements IDisposable

<div class="flex h-screen bg-gray-100 overflow-hidden">
    <!-- Overlay para cerrar el menú -->
    @if (isMenuOpen)
    {
        <div class="fixed inset-0 bg-black bg-opacity-50 z-30 animate-fadeIn"
             @onclick="ToggleMenu"></div>
    }

    <!-- Sidebar -->
    <aside class="@GetSidebarClasses() bg-white shadow-xl z-40 transition-all duration-300 ease-in-out">
        <!-- Header del Sidebar -->
        <div class="flex items-center justify-between p-4 border-b border-gray-200">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 bg-gradient-to-br from-blue-600 to-blue-800 rounded-lg flex items-center justify-center shadow-lg">
                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <div>
                    <p class="font-bold text-gray-900 text-lg">DIGESA-IPRESS</p>
                    <p class="text-xs text-gray-500">Sistema de Gestión</p>
                </div>
            </div>

            <!-- Botón para cerrar -->
            <button @onclick="ToggleMenu"
                    class="p-2 rounded-lg hover:bg-gray-100 transition-colors">
                <svg class="w-6 h-6 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
            </button>
        </div>

        <!-- Navegación -->
        <nav class="p-4 overflow-y-auto h-[calc(100vh-180px)]">
            @if (Accesos != null && Accesos.Modulos.Any())
            {
                var sistema = Accesos.Modulos.First();
                foreach (var menu in sistema.Menus)
                {
                    <div class="mb-6">
                        <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3 px-3">
                            @menu.NombreMenu
                        </p>
                        <div class="space-y-1">
                            @foreach (var sub in menu.SubMenus)
                            {
                                <a href="@sub.Ruta"
                                   @onclick="OnMenuItemClick"
                                   class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 rounded-lg hover:bg-blue-50 hover:text-blue-700 transition-all group @GetActiveClass(sub.Ruta)">
                                    @((MarkupString)GetMenuIcon(sub.Ruta, sub.NombreSubMenu))
                                    <span class="flex-1">@sub.NombreSubMenu</span>
                                </a>
                            }
                        </div>
                    </div>
                }
            }
            else if (Accesos != null && !Accesos.Modulos.Any())
            {
                <div class="mb-6">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wider mb-3 px-3">Principal</p>
                    <a href="/principal" @onclick="OnMenuItemClick"
                       class="flex items-center gap-3 px-4 py-3 text-sm font-medium text-gray-700 rounded-lg hover:bg-blue-50 hover:text-blue-700 transition-all group @GetActiveClass("/principal")">
                        <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path></svg>
                        <span class="flex-1">Inicio</span>
                    </a>
                </div>
            }
            else
            {
                <div class="text-center py-8">
                    <div class="animate-spin w-8 h-8 border-4 border-blue-600 border-t-transparent rounded-full mx-auto"></div>
                    <p class="text-sm text-gray-500 mt-4">Cargando menú...</p>
                </div>
            }
        </nav>

        <!-- Footer del Sidebar -->
        <div class="absolute bottom-0 left-0 right-0 p-4 border-t border-gray-200 bg-white">
            <button @onclick="Logout"
                    class="w-full flex items-center justify-center gap-2 px-4 py-2 text-sm font-medium text-white bg-rose-600 hover:bg-rose-700 rounded-lg active:scale-95 transition-all shadow-lg hover:shadow-xl">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                Cerrar sesión
            </button>
        </div>
    </aside>

    <!-- Main content -->
    <div class="flex-1 flex flex-col overflow-hidden">
        <!-- Header con botón hamburguesa -->
        <header class="bg-gradient-to-r from-blue-600 to-blue-800 text-white p-4 flex items-center justify-between shadow-lg z-20">
            <!-- Botón hamburguesa (visible en todas las pantallas) -->
            <button @onclick="ToggleMenu"
                    class="p-2 rounded-lg hover:bg-blue-700 transition-colors mr-3 flex items-center gap-2">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    @if (isMenuOpen)
                    {
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    }
                    else
                    {
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    }
                </svg>
                <span class="text-sm font-medium hidden md:block">
                    @(isMenuOpen ? "Cerrar" : "Menú")
                </span>
            </button>

            <!-- Notificaciones y perfil -->
            <div class="flex items-center gap-2 md:gap-4">
                <div class="flex items-center gap-2 px-2 md:px-3 py-1 bg-blue-700 rounded-lg">
                    <div class="w-8 h-8 bg-white rounded-full flex items-center justify-center text-blue-600 font-bold text-sm">
                        @inicialesUsuario
                    </div>
                    <span class="text-sm font-medium hidden lg:block">@nombreUsuario</span>
                </div>
            </div>
        </header>

        <!-- Body -->
        <main class="flex-1 overflow-auto bg-gray-50 p-4 lg:p-6">
            @Body
        </main>
    </div>
</div>

<!-- Estilos personalizados -->
<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }
</style>

@code {
    private AccesosResponse? Accesos;
    private bool isMenuOpen = false;
    private string currentPath = string.Empty;
    private string nombreUsuario = "Usuario";
    private string inicialesUsuario = "U";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            // Cargar nombre de usuario
            var authState = await AuthProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            nombreUsuario = user.Identity?.Name ?? "Usuario";
            
            // Generar iniciales
            inicialesUsuario = GenerarIniciales(nombreUsuario);
            
            Accesos = await AuthService.GetAccesosAsync();
            currentPath = NavManager.ToBaseRelativePath(NavManager.Uri);
            NavManager.LocationChanged += OnLocationChanged;
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando accesos: {ex.Message}");
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        currentPath = NavManager.ToBaseRelativePath(e.Location);
        StateHasChanged();
    }

    private void ToggleMenu()
    {
        isMenuOpen = !isMenuOpen;
    }

    private void OnMenuItemClick()
    {
        // Cerrar el menú al hacer clic en un item
        isMenuOpen = false;
    }

    private async Task Logout()
    {
        await _localStorage.RemoveItemAsync("authToken");
        ((CustomAuthStateProvider)AuthProvider).NotifyUserLogout();
        NavManager.NavigateTo("/login", forceLoad: true);
    }

    // Método para obtener las clases del sidebar según el estado
    private string GetSidebarClasses()
    {
        // Sidebar siempre es fixed (flotante) y se oculta/muestra con translate
        var baseClasses = "fixed inset-y-0 left-0 w-64 flex flex-col";
        var visibilityClasses = isMenuOpen ? "translate-x-0" : "-translate-x-full";
        return $"{baseClasses} {visibilityClasses}";
    }

    // Método para resaltar el item activo
    private string GetActiveClass(string ruta)
    {
        var cleanPath = currentPath.TrimStart('/').ToLower();
        var cleanRuta = ruta.TrimStart('/').ToLower();

        return cleanPath == cleanRuta || cleanPath.StartsWith(cleanRuta + "/")
            ? "bg-blue-100 text-blue-700 font-bold border-l-4 border-blue-600"
            : "";
    }

    private string GenerarIniciales(string nombre)
    {
        if (string.IsNullOrWhiteSpace(nombre))
            return "U";
        
        var partes = nombre.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        if (partes.Length == 0)
            return "U";
        
        if (partes.Length == 1)
            return partes[0].Substring(0, Math.Min(2, partes[0].Length)).ToUpper();
        
        // Tomar primera letra del primer nombre y primera del primer apellido
        return (partes[0][0].ToString() + partes[1][0].ToString()).ToUpper();
    }

    private string GetMenuIcon(string ruta, string nombre)
    {
        var rutaLower = ruta.ToLower();
        var nombreLower = nombre.ToLower();
        
        // Iconos específicos por ruta o nombre
        if (rutaLower.Contains("dashboard/admin") || nombreLower.Contains("administrador"))
            return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z'></path></svg>";
        
        // Gestión de Usuarios (plural) - Icono de grupo de personas
        if (rutaLower.Contains("usuarios") || nombreLower == "usuarios")
            return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z'></path></svg>";
        
        // Dashboard Usuario (singular) - Icono de panel/gráfico
        if (rutaLower.Contains("dashboard/user") || (rutaLower.Contains("dashboard") && nombreLower == "usuario"))
            return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M16 8v8m-4-5v5m-4-2v2m-2 4h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z'></path></svg>";
        
        if (rutaLower.Contains("pendientes") || nombreLower.Contains("pendientes"))
            return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z'></path></svg>";
        
        if (rutaLower.Contains("atenciones") && !rutaLower.Contains("pendientes") && !rutaLower.Contains("atendidos"))
            return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4'></path></svg>";
        
        if (rutaLower.Contains("atendidos") || nombreLower.Contains("atendidos") || nombreLower.Contains("historial"))
            return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z'></path></svg>";
        
        // Icono por defecto
        return "<svg class='w-5 h-5 text-gray-400 group-hover:text-blue-600 transition-colors' fill='none' stroke='currentColor' viewBox='0 0 24 24'><path stroke-linecap='round' stroke-linejoin='round' stroke-width='2' d='M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z'></path></svg>";
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }
}