@page "/establecimientos"
@page "/establecimientos/nuevo"
@page "/establecimientos/{Id:int}"
@attribute [Authorize]
@layout MainLayout
@using Radzen
@using Radzen.Blazor
@inject MaestrosService Maestros
@inject NotificationService Notify
@inject PermisosService Permisos
@inject NavigationManager Nav
@inject DialogService DialogService
@inject IJSRuntime JS

<RadzenStack Gap="0.5rem" Style="height:100%">
    @* Listado primero: se muestra cuando se está en la ruta base de establecimientos (no en /nuevo ni en /{id}) *@
    @if (mostrarListado)
    {
        <RadzenCard Style="padding:0.5rem;flex:1;display:flex;flex-direction:column;min-height:0">
            <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center" Gap="1rem" Wrap="FlexWrap.Wrap">
                <RadzenBreadcrumb>
                    <RadzenBreadcrumbItem Text="Inicio" Path="/principal" />
                    <RadzenBreadcrumbItem Text="Establecimientos" />
                </RadzenBreadcrumb>
                @if (Permisos.TienePermiso("/establecimientos", "CREAR")) { <RadzenButton Icon="add" Text="Crear" ButtonStyle="ButtonStyle.Primary" Click="@Nuevo" /> }
            </RadzenStack>
            @if (cargandoLista)
            {
                <RadzenProgressBarCircular ShowValue="false" Mode="ProgressBarMode.Indeterminate" Style="margin:1rem auto;display:block" />
            }
            else
            {
            <IpressDataTable TItem="EstablecimientoListDto" Data="@items" Style="margin-top:0.5rem" EmptyText="No hay establecimientos. Use «Crear» para registrar uno.">
                <Columns>
                    <RadzenDataGridColumn TItem="EstablecimientoListDto" Property="Diresa" Title="Diresa" Width="120px" Filterable="true" Sortable="true" Groupable="true" />
                    <RadzenDataGridColumn TItem="EstablecimientoListDto" Property="Red" Title="Red" Width="120px" Filterable="true" Sortable="true" Groupable="true" />
                    <RadzenDataGridColumn TItem="EstablecimientoListDto" Property="MicroRed" Title="MicroRed" Width="120px" Filterable="true" Sortable="true" Groupable="true" />
                    <RadzenDataGridColumn TItem="EstablecimientoListDto" Property="Codigo" Title="Código" Width="100px" Filterable="true" Sortable="true" Groupable="true" />
                    <RadzenDataGridColumn TItem="EstablecimientoListDto" Property="Nombre" Title="Nombre" Filterable="true" Sortable="true" Groupable="true">
                        <Template Context="e">
                            <a href="/establecimientos/@e.IdEstablecimiento" class="rz-link">@e.Nombre</a>
                        </Template>
                    </RadzenDataGridColumn>
                    <RadzenDataGridColumn TItem="EstablecimientoListDto" Title="Acciones" Sortable="false" Filterable="false" Width="160px" Frozen="true" TextAlign="TextAlign.Center">
                        <Template Context="e">
                            @if (Permisos.TienePermiso("/establecimientos", "EDITAR"))
                            { <RadzenButton Icon="edit" Text="Editar" ButtonStyle="ButtonStyle.Secondary" Size="ButtonSize.Small" Click="@(() => Editar(e))" Style="margin-right:4px" /> }
                            @if (Permisos.TienePermiso("/establecimientos", "ELIMINAR"))
                            { <RadzenButton Icon="delete" Text="Eliminar" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => Eliminar(e))" /> }
                        </Template>
                    </RadzenDataGridColumn>
                </Columns>
            </IpressDataTable>
            }
        </RadzenCard>
    }
    else if (esNuevo || Id > 0)
    {
        <RadzenCard>
            @if (form != null)
            {
                <RadzenStack Gap="1.5rem" Style="margin-top:0.5rem">
                    <RadzenFieldSet Text="Información general" Icon="business" Class="ipress-fieldset-section">
                        <div class="ipress-section-content">
                            <div class="ipress-section-title">Información general</div>
                            <RadzenRow Gap="1rem">
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenStack Gap="0.75rem">
                                        <RadzenFormField Text="Código" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenTextBox @bind-Value="form.Codigo" Placeholder="" Style="width:100%" Class="ipress-input-equal" /></RadzenFormField>
                                        <RadzenFormField Text="Nombre" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenTextBox @bind-Value="form.Nombre" Placeholder="" Style="width:100%" Class="ipress-input-equal" /></RadzenFormField>
                                        <div class="ipress-casillero">
                                            <RadzenCheckBox @bind-Value="form.TieneTelefono" Name="tieneTel" />
                                            <span class="ipress-casillero-text">¿Tiene teléfono?</span>
                                        </div>
                                        <div class="ipress-casillero">
                                            <RadzenCheckBox @bind-Value="form.TieneRadio" Name="tieneRadio" />
                                            <span class="ipress-casillero-text">¿Tiene radio?</span>
                                        </div>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenStack Gap="0.75rem">
                                        <RadzenFormField Text="Departamento" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@departamentosConOpcion" TextProperty="Nombre" ValueProperty="Codigo" @bind-Value="codigoDepartamento" Style="width:100%" Change="@OnDepartamentoChange" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Provincia" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@provinciasConOpcion" TextProperty="Nombre" ValueProperty="Codigo" @bind-Value="codigoProvincia" Style="width:100%" Change="@OnProvinciaChange" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Distrito" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@distritosConOpcion" TextProperty="Nombre" ValueProperty="Ubigeo" @bind-Value="codigoDistrito" Style="width:100%" Change="@OnDistritoChange" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Ubigeo (autocompletado)" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenTextBox Value="@form.Ubigeo" ReadOnly="true" Style="width:100%;background:#f1f5f9;color:#000" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenStack Gap="0.75rem">
                                        <RadzenFormField Text="Diresa" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@diresasConOpcion" TextProperty="Nombre" ValueProperty="Id" @bind-Value="form.IdDiresa" Style="width:100%" Change="@OnDiresaChange" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Red" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@redesConOpcion" TextProperty="Nombre" ValueProperty="Id" @bind-Value="form.IdRed" Style="width:100%" Change="@OnRedChange" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Microred" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@microRedesConOpcion" TextProperty="Nombre" ValueProperty="Id" @bind-Value="form.IdMicroRed" Style="width:100%" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Quintil Regional" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@quintilesConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="form.QuintilRegional" Style="width:100%" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                    </RadzenStack>
                                </RadzenColumn>
                            </RadzenRow>
                        </div>
                    </RadzenFieldSet>
                    <RadzenFieldSet Text="Coordenadas UTM-WGS84" Icon="place" Class="ipress-fieldset-section">
                        <div class="ipress-section-content ipress-section-coords">
                            <div class="ipress-section-title">Coordenadas UTM-WGS84</div>
                            <RadzenRow Gap="1rem">
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenStack Gap="0.75rem">
                                        <RadzenFormField Text="Este (UTM 100000-999999)" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenNumeric @bind-Value="form.Este" Min="100000" Max="999999" Format="N2" Style="width:100%" Placeholder="" Class="ipress-input-equal" /></RadzenFormField>
                                        <RadzenFormField Text="Norte (UTM 100000-999999)" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenNumeric @bind-Value="form.Norte" Min="100000" Max="999999" Format="N2" Style="width:100%" Placeholder="" Class="ipress-input-equal" /></RadzenFormField>
                                        <RadzenFormField Text="Altitud (m.s.n.m.)" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenNumeric @bind-Value="form.AltitudMsnm" Style="width:100%" Placeholder="" Class="ipress-input-equal" /></RadzenFormField>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenStack Gap="0.75rem">
                                        <RadzenFormField Text="Latitud" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenNumeric @bind-Value="form.Latitud" Format="N5" Style="width:100%" Placeholder="" Class="ipress-input-equal" /></RadzenFormField>
                                        <RadzenFormField Text="Longitud" Variant="Variant.Outlined" AllowFloatingLabel="false"><RadzenNumeric @bind-Value="form.Longitud" Format="N5" Style="width:100%" Placeholder="" Class="ipress-input-equal" /></RadzenFormField>
                                    </RadzenStack>
                                </RadzenColumn>
                                <RadzenColumn Size="12" SizeMD="4">
                                    <RadzenStack Gap="0.75rem">
                                        <RadzenFormField Text="Huso" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@husosConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="form.Huso" Style="width:100%" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                        <RadzenFormField Text="Banda" Variant="Variant.Outlined" AllowFloatingLabel="false">
                                            <RadzenDropDown Data="@bandasConOpcion" ValueProperty="Value" TextProperty="Text" @bind-Value="form.Banda" Style="width:100%" Class="ipress-input-equal" />
                                        </RadzenFormField>
                                    </RadzenStack>
                                </RadzenColumn>
                            </RadzenRow>
                        </div>
                    </RadzenFieldSet>
                    <RadzenFieldSet Text="Centros Poblados" Icon="location_city">
                        <RadzenText TextStyle="TextStyle.Body2" Style="margin-bottom:0.5rem;color:#000">Agregue centros poblados asociados al establecimiento. Opcional.</RadzenText>
                        <RadzenStack Orientation="Orientation.Horizontal" Gap="0.5rem">
                            <RadzenDropDown Data="@centrosPobladosConOpcion" TextProperty="Nombre" ValueProperty="Id" @bind-Value="centroPobladoSeleccionado" Style="width:100%;max-width:400px" Filter="true" />
                            <RadzenButton Icon="add" Text="Agregar" ButtonStyle="ButtonStyle.Light" Click="@AgregarCentroPoblado" Disabled="@(centroPobladoSeleccionado == null)" />
                        </RadzenStack>
                        @if (form.CentrosPoblados?.Any() == true)
                        {
                            <IpressDataTable TItem="CentroPobladoItemDto" Data="@form.CentrosPoblados" AllowGrouping="false" AllowFiltering="false" PageSize="10" Style="width:100%;margin-top:1rem">
                                <Columns>
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="IdCentroPoblado" Title="ID" Width="70px" TextAlign="TextAlign.Center" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="Ubigeo" Title="Ubigeo" Width="90px">
                                        <Template Context="cp">@(cp.Ubigeo ?? cp.UbigeoCcp ?? "")</Template>
                                    </RadzenDataGridColumn>
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="Departamento" Title="Departamento" Width="120px" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="Provincia" Title="Provincia" Width="120px" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="Distrito" Title="Distrito" Width="120px" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="CentroPoblado" Title="Centro Poblado" Width="180px" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="Ambito" Title="Ámbito" Width="90px" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Property="Quintil" Title="Quintil" Width="70px" />
                                    <RadzenDataGridColumn TItem="CentroPobladoItemDto" Title="Quitar" Width="80px" Sortable="false" Filterable="false">
                                        <Template Context="cp">
                                            <RadzenButton Icon="delete" ButtonStyle="ButtonStyle.Danger" Size="ButtonSize.Small" Click="@(() => QuitarCentroPoblado(cp))" />
                                        </Template>
                                    </RadzenDataGridColumn>
                                </Columns>
                            </IpressDataTable>
                        }
                        else
                        {
                            <RadzenText TextStyle="TextStyle.Body2" Style="margin-top:0.5rem;color:#000">No hay centros poblados agregados. Use el desplegable y «Agregar» para asociar.</RadzenText>
                        }
                    </RadzenFieldSet>
                    @if (Permisos.TienePermiso("/establecimientos", "EDITAR") || Permisos.TienePermiso("/establecimientos", "CREAR"))
                    {
                        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Style="margin-top:0.5rem;padding-top:1rem;border-top:1px solid #e5e7eb">
                            <RadzenButton Icon="save" Text="@(esNuevo ? "Guardar" : "Guardar cambios")" ButtonStyle="ButtonStyle.Primary" Click="@Guardar" />
                        </RadzenStack>
                    }
                </RadzenStack>
            }
        </RadzenCard>
    }
</RadzenStack>

@code {
    [Parameter] public int Id { get; set; }
    private bool esNuevo => Nav.Uri.EndsWith("/nuevo", StringComparison.OrdinalIgnoreCase);
    private bool mostrarListado => !esNuevo && Id <= 0;
    private List<EstablecimientoListDto> items = new();
    private EstablecimientoDto? form;
    private List<DiresaDto> diresas = new();
    private List<RedDto> redes = new();
    private List<MicroRedDto> microRedes = new();
    private List<GeografiaItemDto> departamentos = new();
    private List<ProvinciaItemDto> provincias = new();
    private List<DistritoItemDto> distritos = new();
    private string? codigoDepartamento;
    private string? codigoProvincia;
    private string? codigoDistrito;
    private static readonly List<QuintilItem> quintiles = new() { new("Q1"), new("Q2"), new("Q3"), new("Q4"), new("Q5") };
    private IEnumerable<RedDto> redesFiltradas => form?.IdDiresa != null ? redes.Where(r => r.IdDiresa == form.IdDiresa).ToList() : new List<RedDto>();
    private IEnumerable<MicroRedDto> microRedesFiltradas => form?.IdRed != null ? microRedes.Where(m => m.IdRed == form.IdRed).ToList() : new List<MicroRedDto>();
    private List<CentroPobladoDto> todosCentrosPoblados = new();
    private IEnumerable<CentroPobladoDto> centrosPobladosDisponibles => todosCentrosPoblados
        .Where(c => (form?.CentrosPoblados ?? new List<CentroPobladoItemDto>()).All(a => a.IdCentroPoblado != c.IdCentroPoblado))
        .ToList();

    private IEnumerable<GeografiaItemDto> departamentosConOpcion => new[] { new GeografiaItemDto { Codigo = "", Nombre = "--seleccionar--" } }.Concat(departamentos);
    private IEnumerable<ProvinciaItemDto> provinciasConOpcion => new[] { new ProvinciaItemDto { Codigo = "", Nombre = "--seleccionar--" } }.Concat(provincias);
    private IEnumerable<DistritoItemDto> distritosConOpcion => new[] { new DistritoItemDto { Ubigeo = "", Nombre = "--seleccionar--" } }.Concat(distritos);
    private IEnumerable<QuintilItem> quintilesConOpcion => new[] { new QuintilItem("", "--seleccionar--") }.Concat(quintiles);
    private IEnumerable<SelectOptionIntNullable> diresasConOpcion => new[] { new SelectOptionIntNullable { Id = null, Nombre = "--seleccionar--" } }.Concat(diresas.Select(d => new SelectOptionIntNullable { Id = d.IdDiresa, Nombre = d.Nombre }));
    private IEnumerable<SelectOptionIntNullable> redesConOpcion => new[] { new SelectOptionIntNullable { Id = null, Nombre = "--seleccionar--" } }.Concat(redesFiltradas.Select(r => new SelectOptionIntNullable { Id = r.IdRed, Nombre = r.Nombre }));
    private IEnumerable<SelectOptionIntNullable> microRedesConOpcion => new[] { new SelectOptionIntNullable { Id = null, Nombre = "--seleccionar--" } }.Concat(microRedesFiltradas.Select(m => new SelectOptionIntNullable { Id = m.IdMicroRed, Nombre = m.Nombre }));
    private IEnumerable<SelectOptionIntNullable> centrosPobladosConOpcion => new[] { new SelectOptionIntNullable { Id = null, Nombre = "--seleccionar--" } }.Concat(centrosPobladosDisponibles.Select(c => new SelectOptionIntNullable { Id = c.IdCentroPoblado, Nombre = c.CentroPoblado ?? "" }));

    private static readonly List<HusoItem> husos = new() { new(17, "17"), new(18, "18"), new(19, "19") };
    private static readonly List<BandaItem> bandas = new() { new("K", "K"), new("L", "L"), new("M", "M"), new("N", "N") };
    private IEnumerable<HusoItem> husosConOpcion => new[] { new HusoItem(null, "--seleccionar--") }.Concat(husos);
    private IEnumerable<BandaItem> bandasConOpcion => new[] { new BandaItem("", "--seleccionar--") }.Concat(bandas);

    private int? centroPobladoSeleccionado;
    private bool cargandoLista;

    protected override async Task OnInitializedAsync()
    {
        diresas = await Maestros.GetDiresasAsync() ?? new List<DiresaDto>();
        redes = await Maestros.GetRedesAsync() ?? new List<RedDto>();
        microRedes = await Maestros.GetMicroRedesAsync() ?? new List<MicroRedDto>();
        departamentos = await Maestros.GetDepartamentosAsync() ?? new List<GeografiaItemDto>();
        todosCentrosPoblados = await Maestros.GetCentrosPobladosAsync() ?? new List<CentroPobladoDto>();
        if (mostrarListado)
        {
            cargandoLista = true;
            items = await Maestros.GetEstablecimientosAsync();
            cargandoLista = false;
        }
    }

    protected override void OnParametersSet()
    {
        if (esNuevo && form == null)
            form = new EstablecimientoDto { CentrosPoblados = new List<CentroPobladoItemDto>() };
    }

    protected override async Task OnParametersSetAsync()
    {
        if (mostrarListado)
        {
            cargandoLista = true;
            items = await Maestros.GetEstablecimientosAsync();
            cargandoLista = false;
        }
        else
        {
            if (esNuevo)
            {
                form = new EstablecimientoDto { CentrosPoblados = new List<CentroPobladoItemDto>() };
                codigoDepartamento = codigoProvincia = codigoDistrito = null;
                provincias = new List<ProvinciaItemDto>();
                distritos = new List<DistritoItemDto>();
            }
            else if (Id > 0)
            {
                form = await Maestros.GetEstablecimientoAsync(Id);
                if (form != null && !string.IsNullOrEmpty(form.Ubigeo) && form.Ubigeo.Length == 6)
                {
                    codigoDepartamento = form.Ubigeo.Substring(0, 2);
                    codigoProvincia = form.Ubigeo.Substring(0, 4);
                    codigoDistrito = form.Ubigeo;
                    provincias = await Maestros.GetProvinciasAsync(codigoDepartamento) ?? new List<ProvinciaItemDto>();
                    distritos = await Maestros.GetDistritosAsync(codigoProvincia) ?? new List<DistritoItemDto>();
                }
            }
            if (form != null && form.CentrosPoblados == null)
                form.CentrosPoblados = new List<CentroPobladoItemDto>();
        }
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnDepartamentoChange()
    {
        form ??= new EstablecimientoDto();
        codigoProvincia = null;
        codigoDistrito = null;
        form.Ubigeo = null;
        form.Departamento = form.Provincia = form.Distrito = null;
        provincias = string.IsNullOrEmpty(codigoDepartamento) ? new List<ProvinciaItemDto>() : (await Maestros.GetProvinciasAsync(codigoDepartamento) ?? new List<ProvinciaItemDto>());
        distritos = new List<DistritoItemDto>();
        if (!string.IsNullOrEmpty(codigoDepartamento))
            form.Departamento = departamentos.FirstOrDefault(d => d.Codigo == codigoDepartamento)?.Nombre;
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnProvinciaChange()
    {
        form ??= new EstablecimientoDto();
        codigoDistrito = null;
        form.Ubigeo = null;
        form.Provincia = form.Distrito = null;
        distritos = string.IsNullOrEmpty(codigoProvincia) ? new List<DistritoItemDto>() : (await Maestros.GetDistritosAsync(codigoProvincia) ?? new List<DistritoItemDto>());
        if (!string.IsNullOrEmpty(codigoProvincia))
            form.Provincia = provincias.FirstOrDefault(p => p.Codigo == codigoProvincia)?.Nombre;
        await InvokeAsync(StateHasChanged);
    }

    private void OnDistritoChange()
    {
        if (form == null) return;
        form.Ubigeo = string.IsNullOrEmpty(codigoDistrito) ? null : codigoDistrito;
        form.Distrito = string.IsNullOrEmpty(codigoDistrito) ? null : distritos.FirstOrDefault(d => d.Ubigeo == codigoDistrito)?.Nombre;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender && esNuevo && form == null)
        {
            form = new EstablecimientoDto { CentrosPoblados = new List<CentroPobladoItemDto>() };
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OnDiresaChange() { form ??= new EstablecimientoDto(); form.IdRed = null; form.IdMicroRed = null; }
    private void OnRedChange() { form ??= new EstablecimientoDto(); form.IdMicroRed = null; }
    private void AgregarCentroPoblado()
    {
        if (form == null || centroPobladoSeleccionado == null) return;
        var cp = todosCentrosPoblados.FirstOrDefault(c => c.IdCentroPoblado == centroPobladoSeleccionado);
        if (cp == null) return;
        form.CentrosPoblados ??= new List<CentroPobladoItemDto>();
        if (form.CentrosPoblados.Any(c => c.IdCentroPoblado == cp.IdCentroPoblado)) return;
        form.CentrosPoblados.Add(new CentroPobladoItemDto { IdCentroPoblado = cp.IdCentroPoblado, Ubigeo = cp.Ubigeo ?? cp.UbigeoCcp, UbigeoCcp = cp.UbigeoCcp, Departamento = cp.Departamento, Provincia = cp.Provincia, Distrito = cp.Distrito, CentroPoblado = cp.CentroPoblado, Ambito = cp.Ambito, Quintil = cp.Quintil });
        centroPobladoSeleccionado = null;
        StateHasChanged();
    }

    private void QuitarCentroPoblado(CentroPobladoItemDto cp)
    {
        if (form?.CentrosPoblados == null) return;
        form.CentrosPoblados.RemoveAll(c => c.IdCentroPoblado == cp.IdCentroPoblado);
        StateHasChanged();
    }

    private void Nuevo() => Nav.NavigateTo("/establecimientos/nuevo");
    private void Editar(EstablecimientoListDto e) => Nav.NavigateTo($"/establecimientos/{e.IdEstablecimiento}");
    private async Task Guardar()
    {
        if (form == null) return;
        const decimal utmMin = 100000m;
        const decimal utmMax = 999999m;
        if (form.Este.HasValue && (form.Este < utmMin || form.Este > utmMax))
        {
            Notify.ShowError("La coordenada UTM debe estar entre 100000.000000 y 999999.000000 (campo Este).");
            return;
        }
        if (form.Norte.HasValue && (form.Norte < utmMin || form.Norte > utmMax))
        {
            Notify.ShowError("La coordenada UTM debe estar entre 100000.000000 y 999999.000000 (campo Norte).");
            return;
        }
        var dto = new EstablecimientoDto
        {
            IdEstablecimiento = form.IdEstablecimiento,
            Codigo = form.Codigo, Nombre = form.Nombre,
            Departamento = form.Departamento, Provincia = form.Provincia, Distrito = form.Distrito,
            QuintilRegional = form.QuintilRegional, Ubigeo = form.Ubigeo, AltitudMsnm = form.AltitudMsnm,
            IdDiresa = form.IdDiresa == 0 ? null : form.IdDiresa,
            IdRed = form.IdRed == 0 ? null : form.IdRed,
            IdMicroRed = form.IdMicroRed == 0 ? null : form.IdMicroRed,
            TieneTelefono = form.TieneTelefono, TieneRadio = form.TieneRadio,
            Este = form.Este, Norte = form.Norte, Huso = form.Huso == 0 ? null : form.Huso, Banda = form.Banda,
            Latitud = form.Latitud, Longitud = form.Longitud,
            CentrosPobladoIds = form.CentrosPoblados?.Select(c => c.IdCentroPoblado).ToList()
        };
        var ok = form.IdEstablecimiento > 0 ? await Maestros.PutEstablecimientoAsync(form.IdEstablecimiento, dto) : await Maestros.PostEstablecimientoAsync(dto);
        if (ok) { Notify.ShowSuccess("Guardado."); Nav.NavigateTo("/establecimientos"); }
        else Notify.ShowError("Error al guardar.");
    }

    private async Task Eliminar(EstablecimientoListDto e)
    {
        if (await DialogService.Confirm("¿Eliminar " + e.Nombre + "?", "Confirmar", new ConfirmOptions { OkButtonText = "Sí", CancelButtonText = "No" }) == true)
        {
            var ok = await Maestros.DeleteEstablecimientoAsync(e.IdEstablecimiento);
            if (ok) { Notify.ShowSuccess("Eliminado."); items = await Maestros.GetEstablecimientosAsync(); StateHasChanged(); }
            else Notify.ShowError("Error al eliminar.");
        }
    }

