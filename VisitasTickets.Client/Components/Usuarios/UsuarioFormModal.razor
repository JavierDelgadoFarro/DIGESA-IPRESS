@using VisitasTickets.Domain.Entities
@using VisitasTickets.Domain.Dtos

@if (IsVisible)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4 animate-fadeIn" @onclick="Cerrar">
        <div class="bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] overflow-y-auto animate-slideIn" @onclick:stopPropagation="true">
            <!-- Header del Modal -->
            <div class="bg-gradient-to-r from-blue-600 to-blue-800 text-white px-6 py-4 rounded-t-2xl">
                <div class="flex items-center justify-between">
                    <h2 class="text-2xl font-bold">@(IsEditing ? "Editar Usuario" : "Nuevo Usuario")</h2>
                    <button @onclick="Cerrar" class="p-2 hover:bg-blue-700 rounded-lg transition-colors">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>
                </div>
            </div>

            <!-- Formulario -->
            <div class="p-6 space-y-6">
                @if (!string.IsNullOrEmpty(ErrorMessage))
                {
                    <div class="bg-rose-50 border-l-4 border-rose-600 p-4 rounded-r-lg">
                        <p class="text-sm text-rose-700 font-medium">@ErrorMessage</p>
                    </div>
                }

                <!-- Sección 1: Datos del Usuario -->
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                        </svg>
                        Datos del Usuario
                    </h3>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Nombres *</label>
                            <input type="text"
                                   value="@Nombre"
                                   @oninput="@(e => NombreChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="Ingrese nombres"/>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Apellido Paterno *</label>
                            <input type="text"
                                   value="@Paterno"
                                   @oninput="@(e => PaternoChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="Ingrese apellido paterno"/>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Apellido Materno *</label>
                            <input type="text"
                                   value="@Materno"
                                   @oninput="@(e => MaternoChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="Ingrese apellido materno"/>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">Usuario *</label>
                            <input type="text"
                                   value="@NombreUsuario"
                                   @oninput="@(e => NombreUsuarioChanged.InvokeAsync(e.Value?.ToString() ?? ""))"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all"
                                   placeholder="Ingrese nombre de usuario"/>
                        </div>
                    </div>
                </div>

                <hr class="my-6 border-gray-200">

                <!-- Sección 2: Permisos de Acceso -->
                <div>
                    <h3 class="text-lg font-semibold text-gray-900 mb-4 flex items-center gap-2">
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                        </svg>
                        Permisos de Acceso
                    </h3>
                    
                    <div class="border border-gray-200 rounded-lg p-4 max-h-80 overflow-y-auto bg-gray-50">
                        @if (MenusDisponibles != null && MenusDisponibles.Any())
                        {
                            @foreach (var menu in MenusDisponibles)
                            {
                                <div class="mb-4 last:mb-0 border border-gray-200 rounded-lg bg-white">
                                    <div class="w-full font-semibold text-gray-700 p-3 flex items-center justify-between">
                                        <div class="flex items-center gap-3">
                                            <input type="checkbox" 
                                                   checked="@TodosSubMenusSeleccionados(menu)"
                                                   @onchange="@(e => ToggleAllSubMenus(menu, (bool)e.Value!))"
                                                   @onclick:stopPropagation="true"
                                                   class="w-5 h-5 text-blue-600 rounded focus:ring-2 focus:ring-blue-500 cursor-pointer border"
                                                   title="Seleccionar/Deseleccionar todos">
                                            <button @onclick="@(() => ToggleMenuExpansion(menu.IdMenu))" 
                                                    type="button"
                                                    class="flex items-center gap-2 hover:text-blue-600 transition-colors">
                                                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                                                </svg>
                                                @menu.NombreMenu
                                                <span class="text-xs text-gray-500 font-normal">(@ContarSubMenusSeleccionados(menu) / @menu.SubMenus.Count)</span>
                                            </button>
                                        </div>
                                        <button @onclick="@(() => ToggleMenuExpansion(menu.IdMenu))" 
                                                type="button"
                                                class="p-1 hover:bg-gray-100 rounded transition-colors">
                                            <svg class="w-5 h-5 text-gray-500 transform transition-transform @(menusExpandidos.GetValueOrDefault(menu.IdMenu, false) ? "rotate-180" : "")" 
                                                 fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                            </svg>
                                        </button>
                                    </div>
                                    
                                    @if (menusExpandidos.GetValueOrDefault(menu.IdMenu, false))
                                    {
                                        <div class="px-3 pb-3 space-y-2 border-t border-gray-100">
                                            @foreach (var subMenu in menu.SubMenus)
                                            {
                                                var isSelected = SubMenusSeleccionados.Contains(subMenu.IdSubMenu);
                                                <label class="flex items-center gap-2 cursor-pointer hover:bg-blue-50 p-2 rounded transition-all @(isSelected ? "bg-blue-50 border-2 border-blue-400" : "border-2 border-transparent")">
                                                    <input type="checkbox" 
                                                           checked="@isSelected"
                                                           @onchange="@(e => ToggleSubMenu(subMenu.IdSubMenu, (bool)e.Value!))"
                                                           class="w-4 h-4 text-blue-600 rounded focus:ring-2 focus:ring-blue-500 border">
                                                    <span class="text-sm @(isSelected ? "text-blue-700 font-medium" : "text-gray-700")">@subMenu.NombreSubMenu</span>
                                                </label>
                                            }
                                        </div>
                                    }
                                </div>
                            }
                        }
                        else
                        {
                            <p class="text-sm text-gray-500 text-center py-4">Cargando menús disponibles...</p>
                        }
                    </div>
                    
                    <p class="text-xs text-gray-500 mt-2">
                        Selecciona los menús a los que el usuario tendrá acceso
                    </p>
                </div>

                <div class="flex items-center justify-end gap-3 pt-6 border-t border-gray-200">
                    <button @onclick="Cerrar"
                            class="px-6 py-3 border border-gray-300 rounded-lg text-gray-700 font-medium hover:bg-gray-50 transition-colors">
                        Cancelar
                    </button>
                    <button @onclick="Guardar"
                            class="px-6 py-3 bg-gradient-to-r from-blue-600 to-blue-700 text-white rounded-lg font-medium hover:from-blue-700 hover:to-blue-800 transition-all shadow-lg hover:shadow-xl">
                        @(IsEditing ? "Actualizar" : "Crear") Usuario
                    </button>
                </div>
            </div>
        </div>
    </div>
}

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(-20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }

    .animate-slideIn {
        animation: slideIn 0.3s ease-out;
    }
</style>

@code {
    [Parameter] public bool IsVisible { get; set; }
    [Parameter] public bool IsEditing { get; set; }
    [Parameter] public int IdUsuario { get; set; }
    [Parameter] public string NombreUsuario { get; set; } = "";
    [Parameter] public EventCallback<string> NombreUsuarioChanged { get; set; }
    [Parameter] public string Nombre { get; set; } = "";
    [Parameter] public EventCallback<string> NombreChanged { get; set; }
    [Parameter] public string Paterno { get; set; } = "";
    [Parameter] public EventCallback<string> PaternoChanged { get; set; }
    [Parameter] public string Materno { get; set; } = "";
    [Parameter] public EventCallback<string> MaternoChanged { get; set; }
    [Parameter] public List<MenuDto> MenusDisponibles { get; set; } = new();
    [Parameter] public List<int> SubMenusSeleccionados { get; set; } = new();
    [Parameter] public string ErrorMessage { get; set; } = "";
    [Parameter] public EventCallback OnSave { get; set; }
    [Parameter] public EventCallback OnClose { get; set; }

    private Dictionary<int, bool> menusExpandidos = new();

    private void ToggleMenuExpansion(int menuId)
    {
        if (menusExpandidos.ContainsKey(menuId))
        {
            menusExpandidos[menuId] = !menusExpandidos[menuId];
        }
        else
        {
            menusExpandidos[menuId] = true;
        }
    }

    private void ToggleAllSubMenus(MenuDto menu, bool isChecked)
    {
        foreach (var subMenu in menu.SubMenus)
        {
            if (isChecked)
            {
                if (!SubMenusSeleccionados.Contains(subMenu.IdSubMenu))
                {
                    SubMenusSeleccionados.Add(subMenu.IdSubMenu);
                }
            }
            else
            {
                SubMenusSeleccionados.Remove(subMenu.IdSubMenu);
            }
        }
    }

    private bool TodosSubMenusSeleccionados(MenuDto menu)
    {
        if (menu.SubMenus.Count == 0) return false;
        return menu.SubMenus.All(sm => SubMenusSeleccionados.Contains(sm.IdSubMenu));
    }

    private int ContarSubMenusSeleccionados(MenuDto menu)
    {
        return menu.SubMenus.Count(sm => SubMenusSeleccionados.Contains(sm.IdSubMenu));
    }

    private void ToggleSubMenu(int subMenuId, bool isChecked)
    {
        if (isChecked)
        {
            if (!SubMenusSeleccionados.Contains(subMenuId))
            {
                SubMenusSeleccionados.Add(subMenuId);
            }
        }
        else
        {
            SubMenusSeleccionados.Remove(subMenuId);
        }
    }

    private async Task Guardar()
    {
        await OnSave.InvokeAsync();
    }

    private async Task Cerrar()
    {
        await OnClose.InvokeAsync();
    }
}
