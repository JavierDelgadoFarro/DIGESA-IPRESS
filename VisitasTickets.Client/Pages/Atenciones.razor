            Observacion = atencionSeleccionada.Observacion,
            ObservacionAtencion = "Persona no presente - Atención cancelada"
        };

        try
        {
            var ok = await AtencionService.UpdateEstadoAtencionAsync(atencionSeleccionada.IdAtencion, dto);
