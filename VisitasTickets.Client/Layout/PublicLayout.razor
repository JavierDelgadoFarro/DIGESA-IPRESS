@inherits LayoutComponentBase

<div class="min-h-screen">
    <!-- Header Simple -->
    <header class="bg-white shadow-sm border-b border-gray-200">
        <div class="max-w-7xl mx-auto px-4 py-4">
            <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <img src="/img/logo-digesa.png" alt="DIGESA" class="h-12" onerror="this.style.display='none'" />
                    <div>
                        <h1 class="text-xl font-bold text-blue-900">DIGESA</h1>
                        <p class="text-xs text-gray-600">Sistema de Atención al Público</p>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Contenido Principal -->
    <main>
        @Body
    </main>

    <!-- Footer Simple -->
    <footer class="bg-gray-50 border-t border-gray-200 py-6 mt-12">
        <div class="max-w-7xl mx-auto px-4 text-center">
            <p class="text-sm text-gray-600">
                © @DateTime.Now.Year DIGESA - Dirección General de Salud Ambiental e Inocuidad Alimentaria
            </p>
        </div>
    </footer>
</div>
