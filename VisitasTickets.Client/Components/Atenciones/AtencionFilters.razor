@using VisitasTickets.Domain.Dtos

<div class="flex items-center justify-between px-6 py-4 border-b border-gray-200">
    <!-- Buscador -->
    <div class="flex-1 max-w-md">
        <div class="relative">
            <input type="text"
                   value="@SearchText"
                   @oninput="@(e => OnSearchTextChanged(e.Value?.ToString() ?? ""))"
                   placeholder="Buscar por nombre, apellido o documento..."
                   class="w-full pl-4 pr-10 py-2.5 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm">
            <svg class="absolute right-3 top-2.5 w-5 h-5 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
            </svg>
        </div>
    </div>

    <!-- Contenedor de Filtros y Botón -->
    <div class="flex items-center gap-3 flex-shrink-0">
        <!-- Filtro por Estado -->
        <select value="@EstadoFiltro"
                @onchange="@(e => OnEstadoFiltroChanged(e.Value?.ToString() ?? ""))"
                class="min-w-[160px] px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white transition-all">
            <option value="">Todos los estados</option>
            <option value="Pendiente">🟡 Pendiente</option>
            <option value="En Ventanilla">🔵 En Ventanilla</option>
        </select>

        <!-- Filtro Preferencial -->
        <select value="@PreferencialFiltro"
                @onchange="@(e => OnPreferencialFiltroChanged(e.Value?.ToString() ?? ""))"
                class="min-w-[140px] px-4 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white transition-all">
            <option value="">Todos</option>
            <option value="preferencial">⭐ Preferenciales</option>
            <option value="normal">Normales</option>
        </select>

        <!-- Botón Nueva Atención -->
        <button @onclick="OnNuevoClick"
                class="flex items-center gap-2 px-4 py-2.5 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors shadow-sm whitespace-nowrap">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Nueva Atención
        </button>
    </div>
</div>

@code {
    [Parameter] public string SearchText { get; set; } = "";
    [Parameter] public string EstadoFiltro { get; set; } = "";
    [Parameter] public string PreferencialFiltro { get; set; } = "";
    [Parameter] public EventCallback<string> SearchTextChanged { get; set; }
    [Parameter] public EventCallback<string> EstadoFiltroChanged { get; set; }
    [Parameter] public EventCallback<string> PreferencialFiltroChanged { get; set; }
    [Parameter] public EventCallback OnNuevoClick { get; set; }

    private async Task OnSearchTextChanged(string value)
    {
        await SearchTextChanged.InvokeAsync(value);
    }

    private async Task OnEstadoFiltroChanged(string value)
    {
        await EstadoFiltroChanged.InvokeAsync(value);
    }

    private async Task OnPreferencialFiltroChanged(string value)
    {
        await PreferencialFiltroChanged.InvokeAsync(value);
    }
}
