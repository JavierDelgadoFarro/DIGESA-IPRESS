        {
            IdAtencion = atencionSeleccionada.IdAtencion,
            IdEstadoAtencion = estadoEnPausa.IdEstadoAtencion,
            Observacion = atencionSeleccionada.Observacion,
            ObservacionAtencion = null
        };

        try
        {
            var ok = await AtencionService.UpdateEstadoAtencionAsync(atencionSeleccionada.IdAtencion, dto);
            if (ok)
            {
                atencionSeleccionada.IdEstadoAtencion = estadoEnPausa.IdEstadoAtencion;
