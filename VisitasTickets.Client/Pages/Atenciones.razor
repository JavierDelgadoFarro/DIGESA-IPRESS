    private void OnDetalleActividadChanged(int idDetalleActividad)
    {
        idDetalleActividadModal = idDetalleActividad;
        
        // Verificar si se debe mostrar el campo de Número de Expediente (IDs 1, 3, 8)
        mostrarNumeroExpediente = (idDetalleActividad == 1 || idDetalleActividad == 3 || idDetalleActividad == 8);
        
        // Limpiar el campo si se oculta
        if (!mostrarNumeroExpediente)
        {
            numeroExpedienteModal = "";
        }
        
        // Limpiar error
        errorModalAtender = "";
    }

