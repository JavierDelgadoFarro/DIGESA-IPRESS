        // Este método ya no se usa desde los botones, solo desde el modal
    }

    private void CerrarModalAtender()
    {
        mostrarModalAtender = false;
        mostrarCronometro = false;
        atencionSeleccionada = null;
        observacionModal = "";
        errorModalAtender = "";
        accionModal = "";
    }

    private async Task ConfirmarCambioEstado()
    {
        try
        {
            if (string.IsNullOrWhiteSpace(observacionModal))
            {
                errorModalAtender = "La observación de atención es obligatoria.";
                return;
            }

            if (atencionSeleccionada == null)
            {
                errorModalAtender = "No se ha seleccionado ninguna atención.";
                NotificationService.ShowError("Error: No se ha seleccionado ninguna atención.");
                return;
            }

            if (estados == null || estados.Count == 0)
            {
                errorModalAtender = "No se encontraron los estados de atención.";
                NotificationService.ShowError("Error: No se cargaron los estados correctamente.");
                return;
            }

            // Solo se llega aquí cuando se está finalizando (cambiando a Atendido)
            var estadoAtendido = estados.FirstOrDefault(e => e.NombreEstado == "Atendido");
            
            if (estadoAtendido == null)
            {
                errorModalAtender = "No se encontró el estado 'Atendido'.";
                NotificationService.ShowError("Error: Estado 'Atendido' no encontrado.");
                return;
            }

            var nombreCompleto = atencionSeleccionada.NombreCompleto; // Guardar antes de cualquier operación

            var dto = new AtencionUpdateDto
            {
                IdAtencion = atencionSeleccionada.IdAtencion,
                IdEstadoAtencion = estadoAtendido.IdEstadoAtencion,
                Observacion = atencionSeleccionada.Observacion, // Mantener observación inicial
                ObservacionAtencion = observacionModal // Nueva observación de atención
            };

            var ok = await AtencionService.UpdateEstadoAtencionAsync(atencionSeleccionada.IdAtencion, dto);
            if (ok)
            {
                CerrarModalAtender();
                await CargarDatos();
                NotificationService.ShowSuccess($"Atención finalizada para {nombreCompleto}");
            }
            else
            {
                errorModalAtender = "Error al finalizar la atención.";
                NotificationService.ShowError("Error al finalizar la atención.");
            }
        }
        catch (Exception ex)
        {
            errorModalAtender = $"Error inesperado: {ex.Message}";
            NotificationService.ShowError($"Error al finalizar: {ex.Message}");
        }
    }

    private IEnumerable<AtencionDto> AtencionesFiltradas
    {
        get
        {
            var query = atenciones.AsEnumerable();

            // Filtro por búsqueda
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                query = query.Where(a =>
                    (a.Nombres?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (a.Apellidos?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false) ||
                    (a.NumeroDocumento?.Contains(searchText, StringComparison.OrdinalIgnoreCase) ?? false));
            }

            // Filtro por estado
            if (!string.IsNullOrWhiteSpace(estadoFiltro))
            {
                query = query.Where(a => a.NombreEstado == estadoFiltro);
            }

            // Filtro preferencial
            if (preferencialFiltro == "preferencial")
            {
                query = query.Where(a => a.EsPreferencial);
            }
            else if (preferencialFiltro == "normal")
            {
                query = query.Where(a => !a.EsPreferencial);
            }

            return query.OrderByDescending(a => a.EsPreferencial)
                        .ThenBy(a => a.FechaRegistro);
        }
    }

    private int AtencionesFiltradasCount => AtencionesFiltradas.Count();
    private int totalPages => (int)Math.Ceiling((double)AtencionesFiltradasCount / pageSize);

    private IEnumerable<AtencionDto> AtencionesFiltradasPaginadas =>
        AtencionesFiltradas.Skip((currentPage - 1) * pageSize).Take(pageSize);

    private void NextPage() { if (currentPage < totalPages) currentPage++; }
    private void PrevPage() { if (currentPage > 1) currentPage--; }

    private string GetBorderColor(AtencionDto atencion)
    {
        if (atencion.EsPreferencial) return "border-amber-400";
        return atencion.NombreEstado switch
        {
            "Pendiente" => "border-yellow-400",
            "En Ventanilla" => "border-blue-400",
            "En Pausa" => "border-orange-400",
            "Atendido" => "border-green-400",
            _ => "border-gray-300"
        };
    }

    private string GetEstadoBadgeClass(string estado)
    {
        return estado switch
        {
            "Pendiente" => "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-yellow-100 text-yellow-800",
            "En Ventanilla" => "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-800",
            "En Pausa" => "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-orange-100 text-orange-800",
            "Atendido" => "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-green-100 text-green-800",
            _ => "inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-semibold bg-gray-100 text-gray-800"
        };
    }

    private string GetEstadoIcon(string estado)
    {
        return estado switch
        {
            "Pendiente" => "🟡",
            "En Ventanilla" => "🔵",
            "En Pausa" => "🟠",
            "Atendido" => "🟢",
            _ => "⚪"
        };
    }

    private async Task CargarAtenciones()
    {
        try
        {
            atenciones = await AtencionService.GetAtencionesActivasAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar atenciones: {ex.Message}");
        }
    }

    public void Dispose()
    {
        // Desuscribirse de eventos SignalR
        SignalRService.OnNuevaAtencion -= async () => await CargarAtenciones();
        SignalRService.OnCambioEstadoAtencion -= async (idAtencion) => await CargarAtenciones();
    }
