    private TimeSpan CalcularTiempoTotal(AtencionDto atencion)
    {
        // Si ya cargamos el historial para esta atención, calcular excluyendo pausas
        if (historialesPorAtencion.ContainsKey(atencion.IdAtencion))
        {
            var historial = historialesPorAtencion[atencion.IdAtencion];
            if (historial.Any())
            {
                var tiempoSegundos = historial
                    .Where(h => h.MinutosEnEsteEstado.HasValue && h.OrdenEstadoNuevo != 3)
                    .Sum(h => h.MinutosEnEsteEstado.Value);
                
                return TimeSpan.FromSeconds(tiempoSegundos);
            }
            return TimeSpan.Zero;
        }
        
        // Fallback: usar diferencia de fechas (incluye pausas, pero es mejor que nada)
        // Este solo se usa si el historial aún no se cargó
        return atencion.FechaActualizacion.HasValue
            ? (atencion.FechaActualizacion.Value - atencion.FechaRegistro)
            : TimeSpan.Zero;
    }

    private string FormatearTiempo(TimeSpan tiempo)
    {
        if (tiempo.TotalDays >= 1)
        {
            return $"{(int)tiempo.TotalDays} día{((int)tiempo.TotalDays > 1 ? "s" : "")} {tiempo.Hours}h {tiempo.Minutes}min";
        }
        else if (tiempo.TotalHours >= 1)
        {
            return $"{(int)tiempo.TotalHours}h {tiempo.Minutes}min {tiempo.Seconds}s";
        }
        else if (tiempo.TotalMinutes >= 1)
        {
            return $"{tiempo.Minutes}min {tiempo.Seconds}s";
        }
        else
        {
            return $"{tiempo.Seconds} segundo{(tiempo.Seconds != 1 ? "s" : "")}";
        }
    }

