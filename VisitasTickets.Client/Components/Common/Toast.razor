@using VisitasTickets.Client.Services
@inject NotificationService NotificationService
@implements IDisposable

@if (mostrarToast)
{
    <div class="fixed bottom-4 right-4 @GetColorClass() text-white px-6 py-4 rounded-lg shadow-2xl transition-all duration-500 flex items-center gap-3 animate-slideIn z-50">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            @switch (tipoActual)
            {
                case NotificationType.Success:
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    break;
                case NotificationType.Error:
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    break;
                case NotificationType.Warning:
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
                    break;
                case NotificationType.Info:
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    break;
            }
        </svg>
        <span class="font-medium">@mensaje</span>
        <button @onclick="OcultarToast" class="ml-2 hover:bg-white hover:bg-opacity-20 rounded-full p-1">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>
    </div>
}

<style>
    @@keyframes slideIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-slideIn {
        animation: slideIn 0.3s ease-out;
    }
</style>

@code {
    private bool mostrarToast = false;
    private string mensaje = "";
    private NotificationType tipoActual = NotificationType.Info;
    private System.Threading.Timer? temporizador;

    protected override void OnInitialized()
    {
        NotificationService.OnNotification += MostrarNotificacion;
    }

    private void MostrarNotificacion(string msg, NotificationType tipo)
    {
        mensaje = msg;
        tipoActual = tipo;
        mostrarToast = true;
        StateHasChanged();

        // Auto-ocultar después de 4 segundos
        temporizador?.Dispose();
        temporizador = new System.Threading.Timer(_ =>
        {
            OcultarToast();
        }, null, 4000, Timeout.Infinite);
    }

    private void OcultarToast()
    {
        mostrarToast = false;
        StateHasChanged();
    }

    private string GetColorClass()
    {
        return tipoActual switch
        {
            NotificationType.Success => "bg-emerald-600",
            NotificationType.Error => "bg-rose-600",
            NotificationType.Warning => "bg-amber-500",
            NotificationType.Info => "bg-blue-600",
            _ => "bg-slate-600"
        };
    }

    public void Dispose()
    {
        NotificationService.OnNotification -= MostrarNotificacion;
        temporizador?.Dispose();
    }
}
