    private void AbrirModalParaReanudar(AtencionDto atencion)
    {
        // Abrir el modal con el cronómetro para una atención que ya está en ventanilla o pausada
        atencionSeleccionada = atencion;
        observacionModal = atencion.ObservacionAtencion ?? "";
        errorModalAtender = "";
        accionModal = "finalizar";
        tituloModalAtender = atencion.NombreEstado == "En Pausa" ? "Atención en Pausa" : "En ventanilla";
        tituloObservacionModal = "Observación de Atención";
        placeholderObservacion = "Ingrese los detalles de la atención brindada...";
        textoBotonConfirmar = "Finalizar";
        
        // Establecer valores desde la atención o por defecto
        if (atencion.IdTipoTrabajo.HasValue)
        {
            idTipoTrabajoModal = atencion.IdTipoTrabajo.Value;
        }
        else
        {
            var tipoPresencial = tiposTrabajo.FirstOrDefault(t => t.NombreTipoTrabajo == "PRESENCIAL");
            idTipoTrabajoModal = tipoPresencial?.IdTipoTrabajo ?? (tiposTrabajo.FirstOrDefault()?.IdTipoTrabajo ?? 0);
        }
        
        idDetalleActividadModal = atencion.IdDetalleActividad ?? 0;
        
        mostrarCronometro = true;
        mostrarModalAtender = true;
        StateHasChanged();
    }

