@page "/registro-publico"
@layout PublicLayout
@using VisitasTickets.Domain.Dtos
@using VisitasTickets.Client.Services
@using Microsoft.JSInterop
@inject HttpClient Http
@inject VisitanteService VisitanteService
@inject NavigationManager NavManager
@inject IJSRuntime JS

<PageTitle>Registro de Atención - DIGESA</PageTitle>

<div class="min-h-screen bg-gradient-to-br from-blue-50 to-blue-100 py-8 px-4">
    <div class="max-w-2xl mx-auto">
        <!-- Header -->
        <div class="text-center mb-8">
            <div class="bg-white rounded-2xl shadow-lg p-6 mb-6">
                <h1 class="text-3xl font-bold text-blue-900 mb-2">🎫 Registro de Atención</h1>
                <p class="text-gray-600">Complete el formulario para generar su atención</p>
            </div>
        </div>

        <!-- Formulario -->
        <div class="bg-white rounded-2xl shadow-xl p-8">
            @if (!string.IsNullOrEmpty(mensajeError))
            {
                <div class="bg-rose-50 border-l-4 border-rose-600 p-4 mb-6 rounded-r-lg">
                    <p class="text-sm text-rose-700 font-medium">@mensajeError</p>
                </div>
            }

            <EditForm Model="@atencion" OnValidSubmit="@RegistrarAtencion">
                <DataAnnotationsValidator />

                <!-- ¿Es Preferencial? -->
                <div class="mb-6 p-4 border-2 border-amber-300 bg-amber-50 rounded-xl">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" @bind="atencion.EsPreferencial" class="w-6 h-6 text-amber-600 border-2 border-amber-400 rounded focus:ring-2 focus:ring-amber-500" />
                        <span class="ml-3 text-base font-bold text-amber-900">⭐ Atención Preferencial</span>
                    </label>
                    <p class="text-xs text-amber-700 mt-2 ml-9">Marque esta opción si tiene prioridad de atención (adulto mayor, gestante, discapacidad, etc.)</p>
                </div>

                <!-- Tipo Preferencial (si aplica) -->
                @if (atencion.EsPreferencial && tiposPreferencial.Any())
                {
                    <div class="mb-6 pl-8 border-l-4 border-amber-400 bg-amber-50 p-4 rounded-r-lg">
                        <label class="block text-sm font-semibold text-amber-900 mb-2">Motivo Preferencial *</label>
                        <select @bind="atencion.IdTipoPreferencial" class="w-full px-4 py-3 border-2 border-amber-300 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent bg-white">
                            <option value="">Seleccione el motivo</option>
                            @foreach (var tipo in tiposPreferencial)
                            {
                                <option value="@tipo.IdTipoPreferencial">@tipo.NombreTipoPreferencial</option>
                            }
                        </select>
                    </div>
                }

                <!-- Tipo de Documento -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-3">Tipo de Documento *</label>
                    <div class="flex gap-4">
                        <label class="flex items-center cursor-pointer px-6 py-3 border-2  rounded-lg @(atencion.TipoDocumento == "DNI" ? "border-blue-500 bg-blue-50" : "border-gray-300")">
                            <input type="radio" value="DNI" @onchange="@(() => CambiarTipoDocumento("DNI"))" checked="@(atencion.TipoDocumento == "DNI")" class="w-4 h-4 text-blue-600" />
                            <span class="ml-3 text-sm font-medium">📄 DNI</span>
                        </label>
                        <label class="flex items-center cursor-pointer px-6 py-3 border-2 rounded-lg @(atencion.TipoDocumento == "CE" ? "border-blue-500 bg-blue-50" : "border-gray-300")">
                            <input type="radio" value="CE" @onchange="@(() => CambiarTipoDocumento("CE"))" checked="@(atencion.TipoDocumento == "CE")" class="w-4 h-4 text-blue-600" />
                            <span class="ml-3 text-sm font-medium">🛂 Carnet de Extranjería</span>
                        </label>
                    </div>
                </div>

                <!-- Número de Documento -->
                <div class="mb-6">
                    <!-- Aviso informativo -->
                    <div class="bg-blue-50 border-l-4 border-blue-400 p-3 mb-3 rounded-r-lg">
                        <p class="text-sm text-blue-800 font-medium">🔍 Primero busque su documento para verificar si ya está registrado en el sistema</p>
                    </div>
                    
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Número de Documento *</label>
                    <div class="flex gap-2">
                        <InputText @bind-Value="atencion.NumeroDocumento" 
                                   @oninput="ValidarDocumento"
                                   maxlength="@(atencion.TipoDocumento == "DNI" ? "8" : "12")"
                                   class="flex-1 px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent text-lg" 
                                   placeholder="@(atencion.TipoDocumento == "DNI" ? "8 dígitos" : "Hasta 12 caracteres")" />
                        <button type="button" @onclick="BuscarPorDocumento" disabled="@buscandoDatos" 
                                class="px-4 py-3 flex items-center justify-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-all shadow-md hover:shadow-lg disabled:opacity-50 disabled:cursor-not-allowed flex-shrink-0 font-semibold active:scale-95"
                                title="Buscar datos del documento">
                            @if (buscandoDatos)
                            {
                                <span class="text-lg">⏳</span>
                                <span class="hidden sm:inline">Buscando...</span>
                            }
                            else
                            {
                                <span class="text-lg">🔍</span>
                                <span class="hidden sm:inline">Buscar</span>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="@(() => atencion.NumeroDocumento)" class="text-rose-600 text-sm mt-1" />
                    @if (!string.IsNullOrEmpty(errorDocumento))
                    {
                        <p class="text-rose-600 text-sm mt-1">⚠️ @errorDocumento</p>
                    }
                    else if (!string.IsNullOrEmpty(atencion.NumeroDocumento))
                    {
                        <p class="text-gray-500 text-xs mt-1">
                            @if (atencion.TipoDocumento == "DNI")
                            {
                                <span>@atencion.NumeroDocumento.Length de 8 dígitos</span>
                            }
                            else
                            {
                                <span>@atencion.NumeroDocumento.Length de máximo 12 caracteres</span>
                            }
                        </p>
                    }
                    
                    @if (!string.IsNullOrEmpty(mensajeBusqueda))
                    {
                        <p class="text-sm mt-2 font-medium @(mensajeBusqueda.Contains("✅") ? "text-emerald-600" : mensajeBusqueda.Contains("❌") ? "text-rose-600" : "text-blue-600")">
                            @mensajeBusqueda
                        </p>
                    }
                </div>

                <!-- Nombres -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Nombres *</label>
                    <InputText @bind-Value="atencion.Nombres" 
                               disabled="@(!camposHabilitados)" 
                               class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent disabled:bg-gray-100 disabled:cursor-not-allowed" 
                               placeholder="@(camposHabilitados ? "Ingrese sus nombres" : "")" />
                    <ValidationMessage For="@(() => atencion.Nombres)" class="text-rose-600 text-sm mt-1" />
                </div>

                <!-- Apellidos -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Apellidos *</label>
                    <InputText @bind-Value="atencion.Apellidos" 
                               disabled="@(!camposHabilitados)" 
                               class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent disabled:bg-gray-100 disabled:cursor-not-allowed" 
                               placeholder="@(camposHabilitados ? "Ingrese sus apellidos" : "")" />
                    <ValidationMessage For="@(() => atencion.Apellidos)" class="text-rose-600 text-sm mt-1" />
                </div>

                <!-- Tipo de Trámite -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Tipo de Trámite *</label>
                    <select value="@atencion.IdTipoTramite" @onchange="OnTramiteChanged" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent">
                        <option value="0">Seleccione un trámite</option>
                        @foreach (var tramite in tramites)
                        {
                            <option value="@tramite.IdTipoTramite">@tramite.NombreTramite</option>
                        }
                    </select>
                    
                    <!-- Descripción informativa del trámite (si existe) -->
                    @if (!string.IsNullOrEmpty(tramiteSeleccionado?.Descripcion))
                    {
                        <div class="mt-3 bg-blue-50 border-l-4 border-blue-400 p-4 rounded-r-lg">
                            <p class="text-sm text-blue-800">📌 @tramiteSeleccionado.Descripcion</p>
                        </div>
                    }
                </div>

                <!-- Observación (opcional) -->
                <div class="mb-6">
                    <label class="block text-sm font-semibold text-gray-700 mb-2">Observación (opcional)</label>
                    <textarea @bind="atencion.Observacion" rows="3" class="w-full px-4 py-3 border-2 border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent" placeholder="Agregue cualquier información adicional"></textarea>
                </div>

                <!-- Botón de envío -->
                <button type="submit" disabled="@procesando" class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white font-bold py-4 px-6 rounded-lg hover:from-blue-700 hover:to-blue-800 transition duration-200 disabled:opacity-50 disabled:cursor-not-allowed text-lg shadow-lg">
                    @if (procesando)
                    {
                        <span>⏳ Registrando...</span>
                    }
                    else
                    {
                        <span>✓ Generar Atención</span>
                    }
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private AtencionCreateDto atencion = new AtencionCreateDto { TipoDocumento = "DNI" };
    private List<TipoTramiteDto> tramites = new();
    private List<TipoPreferencialDto> tiposPreferencial = new();
    private TipoTramiteDto? tramiteSeleccionado = null;
    private bool procesando = false;
    private string mensajeError = "";
    private string errorDocumento = "";
    private bool buscandoDatos = false;
    private string mensajeBusqueda = "";
    private bool camposHabilitados = false; // Controla si nombres y apellidos están habilitados

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
    }

    private async Task CargarDatos()
    {
        tramites = await VisitanteService.GetTramitesAsync();
        tiposPreferencial = await VisitanteService.GetTiposPreferencialAsync();
    }

    private void CambiarTipoDocumento(string tipo)
    {
        atencion.TipoDocumento = tipo;
        atencion.NumeroDocumento = ""; // Limpiar el número cuando cambia el tipo
        atencion.Nombres = ""; // Limpiar nombres
        atencion.Apellidos = ""; // Limpiar apellidos
        errorDocumento = ""; // Limpiar el error
        mensajeBusqueda = ""; // Limpiar mensaje de búsqueda
        camposHabilitados = false; // Bloquear campos de nuevo
    }

    private async Task BuscarPorDocumento()
    {
        if (string.IsNullOrWhiteSpace(atencion.NumeroDocumento))
        {
            mensajeBusqueda = "Por favor ingrese un número de documento";
            return;
        }

        // Validar longitud según tipo de documento
        if (atencion.TipoDocumento == "DNI" && atencion.NumeroDocumento.Length != 8)
        {
            mensajeBusqueda = "El DNI debe tener 8 dígitos";
            return;
        }

        buscandoDatos = true;
        mensajeBusqueda = "";
        
        try
        {
            var datos = await VisitanteService.BuscarPorDocumentoAsync(atencion.NumeroDocumento);
            
            if (datos != null)
            {
                // Si encuentra datos, completar y MANTENER BLOQUEADOS
                atencion.Nombres = datos.Nombres;
                atencion.Apellidos = datos.Apellidos;
                camposHabilitados = false; // Mantener bloqueados
                mensajeBusqueda = "✅ Datos encontrados y cargados (bloqueados)";
            }
            else
            {
                // Si NO encuentra datos, HABILITAR para que los complete manualmente
                atencion.Nombres = "";
                atencion.Apellidos = "";
                camposHabilitados = true; // Habilitar para edición manual
                mensajeBusqueda = "ℹ️ No se encontraron datos previos. Puede ingresar los datos manualmente";
            }
        }
        catch (Exception ex)
        {
            mensajeBusqueda = "❌ Error al buscar datos";
            camposHabilitados = false; // Mantener bloqueados en caso de error
        }
        finally
        {
            buscandoDatos = false;
        }
    }

    private void ValidarDocumento(ChangeEventArgs e)
    {
        var valor = e.Value?.ToString() ?? "";
        errorDocumento = "";

        if (atencion.TipoDocumento == "DNI")
        {
            // Solo números
            if (!string.IsNullOrEmpty(valor) && !System.Text.RegularExpressions.Regex.IsMatch(valor, @"^\d+$"))
            {
                errorDocumento = "El DNI solo debe contener números";
            }
            else if (valor.Length > 8)
            {
                errorDocumento = "El DNI debe tener exactamente 8 dígitos";
            }
            else if (!string.IsNullOrEmpty(valor) && valor.Length < 8)
            {
                errorDocumento = $"Faltan {8 - valor.Length} dígitos";
            }
        }
        else if (atencion.TipoDocumento == "CE")
        {
            // Alfanumérico
            if (valor.Length > 12)
            {
                errorDocumento = "El Carnet de Extranjería no puede tener más de 12 caracteres";
            }
        }
        
        atencion.NumeroDocumento = valor;
    }

    private void OnTramiteChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int tramiteId))
        {
            atencion.IdTipoTramite = tramiteId;
            tramiteSeleccionado = tramites.FirstOrDefault(t => t.IdTipoTramite == tramiteId);
        }
    }

    private async Task RegistrarAtencion()
    {
        mensajeError = "";
        errorDocumento = "";

        // Validar tipo de trámite
        if (atencion.IdTipoTramite == 0)
        {
            mensajeError = "Por favor seleccione un tipo de trámite";
            return;
        }

        // Validar documento
        if (string.IsNullOrWhiteSpace(atencion.NumeroDocumento))
        {
            errorDocumento = "El número de documento es obligatorio";
            return;
        }

        if (atencion.TipoDocumento == "DNI")
        {
            if (!System.Text.RegularExpressions.Regex.IsMatch(atencion.NumeroDocumento, @"^\d{8}$"))
            {
                errorDocumento = "El DNI debe tener exactamente 8 dígitos";
                return;
            }
        }
        else if (atencion.TipoDocumento == "CE")
        {
            if (atencion.NumeroDocumento.Length > 12 || atencion.NumeroDocumento.Length < 6)
            {
                errorDocumento = "El Carnet de Extranjería debe tener entre 6 y 12 caracteres";
                return;
            }
        }

        if (atencion.EsPreferencial && !atencion.IdTipoPreferencial.HasValue)
        {
            mensajeError = "Por favor seleccione el motivo de atención preferencial";
            return;
        }

        procesando = true;

        try
        {
            var resultado = await VisitanteService.RegistrarAtencionAsync(atencion);

            if (resultado != null)
            {
                // Reproducir mensaje de voz confirmando el registro (inmediato, sin espera)
                await ReproducirMensajeVoz("Ha sido registrado. En breve lo estaremos llamando.");
                
                // Navegar a la página de turno usando el ID único de atención
                NavManager.NavigateTo($"/mi-turno/id/{resultado.IdAtencion}");
            }
            else
            {
                mensajeError = "No se pudo registrar la atención. Por favor intente nuevamente.";
            }
        }
        catch (Exception ex)
        {
            mensajeError = $"Error: {ex.Message}";
        }
        finally
        {
            procesando = false;
        }
    }

    private async Task ReproducirMensajeVoz(string mensaje)
    {
        try
        {
            var mensajeLimpio = mensaje.Replace("'", "\\'");
            
            // Inicializar y reproducir en una sola operación (hay interacción del usuario)
            await JS.InvokeVoidAsync("eval", $@"
                if ('speechSynthesis' in window) {{
                    window.speechSynthesis.cancel();
                    
                    var utterance = new SpeechSynthesisUtterance('{mensajeLimpio}');
                    utterance.lang = 'es-ES';
                    utterance.rate = 0.9;
                    utterance.pitch = 1.0;
                    utterance.volume = 1.0;
                    
                    window.speechSynthesis.speak(utterance);
                    console.log('[VOZ REGISTRO] Reproduciendo:', '{mensajeLimpio}');
                }}
            ");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al reproducir voz: {ex.Message}");
        }
    }
}
