@page "/atenciones/pendientes"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout
@using VisitasTickets.Client.Services
@using VisitasTickets.Client.Components.Common
@using VisitasTickets.Client.Components.Atenciones
@using VisitasTickets.Domain.Dtos
@using Microsoft.JSInterop
@using static VisitasTickets.Client.Components.Common.ConfirmDialog
@inject AtencionService AtencionService
@inject NotificationService NotificationService
@inject SignalRService SignalRService
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Atenciones - Sistema de Atenciones</PageTitle>

<!-- Container Principal -->
<div class="max-w-7xl mx-auto space-y-6">
    <!-- Título de la Página -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">Pendientes</h1>
            <p class="text-sm text-slate-500 mt-1">Gestiona las atenciones pendientes y en proceso</p>
        </div>
    </div>

    <!-- Card con Filtros y Lista -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <!-- Componente de Filtros -->
        <AtencionFilters SearchText="@searchText"
                         EstadoFiltro="@estadoFiltro"
                         PreferencialFiltro="@preferencialFiltro"
                         SearchTextChanged="@((value) => { searchText = value; StateHasChanged(); })"
                         EstadoFiltroChanged="@((value) => { estadoFiltro = value; StateHasChanged(); })"
                         PreferencialFiltroChanged="@((value) => { preferencialFiltro = value; StateHasChanged(); })"
                         OnNuevoClick="@AbrirModalNueva" />

        <!-- Grid de Atenciones -->
        <div class="p-6">
            @if (isLoading)
            {
                <div class="flex justify-center items-center py-16">
                    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
                </div>
            }
            else if (AtencionesFiltradasPaginadas.Any())
            {
                <!-- Tabla con diseño moderno y minimalista -->
                <div class="overflow-x-auto rounded-xl border border-slate-200 shadow-sm">
                    <table class="w-full">
                        <thead class="bg-slate-50/50">
                            <tr>
                                <th class="px-6 py-4 text-center text-[11px] font-bold text-slate-500 uppercase tracking-wider w-20">#</th>
                                <th class="px-6 py-4 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Estado</th>
                                <th class="px-6 py-4 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Persona</th>
                                <th class="px-6 py-4 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Documento</th>
                                <th class="px-6 py-4 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Trámite</th>
                                <th class="px-6 py-4 text-left text-[11px] font-bold text-slate-500 uppercase tracking-wider">Hora Registro</th>
                                <th class="px-6 py-4 text-center text-[11px] font-bold text-slate-500 uppercase tracking-wider">Acciones</th>
                            </tr>
                        </thead>
                        <tbody class="bg-white divide-y divide-slate-100">
                            @foreach (var atencion in AtencionesFiltradasPaginadas)
                            {
                                <tr class="hover:bg-slate-50/50 transition-all duration-200">
                                    
                                    <!-- Número de Orden -->
                                    <td class="px-6 py-4 text-center">
                                        <span class="inline-flex items-center justify-center w-9 h-9 rounded-full @(atencion.EsPreferencial ? "bg-amber-50 text-amber-700 border border-amber-100" : "bg-slate-100 text-slate-700 border border-slate-200") font-bold text-sm">
                                            @atencion.NumeroOrden
                                        </span>
                                    </td>
                                    
                                    <!-- Estado -->
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        @{
                                            var (bgClass, textClass, dotClass) = GetEstadoPillClasses(atencion.NombreEstado);
                                        }
                                        <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full @bgClass @textClass text-xs font-medium w-fit">
                                            <span class="w-1.5 h-1.5 rounded-full @dotClass"></span>
                                            @atencion.NombreEstado
                                        </span>
                                    </td>

                                    <!-- Persona -->
                                    <td class="px-6 py-4">
                                        <div class="flex flex-col gap-0.5">
                                            <span class="text-sm font-semibold text-slate-900">@atencion.NombreCompleto</span>
                                            @if (atencion.EsPreferencial && !string.IsNullOrEmpty(atencion.NombreTipoPreferencial))
                                            {
                                                <span class="text-xs text-amber-700 font-medium">⭐ Preferencial: @atencion.NombreTipoPreferencial</span>
                                            }
                                        </div>
                                    </td>

                                    <!-- Documento -->
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex flex-col gap-0.5">
                                            <span class="text-xs text-slate-500">@atencion.TipoDocumento</span>
                                            <span class="text-sm font-mono text-slate-900">@atencion.NumeroDocumento</span>
                                        </div>
                                    </td>

                                    <!-- Trámite -->
                                    <td class="px-6 py-4">
                                        <div class="max-w-xs">
                                            <p class="text-sm text-slate-900 truncate" title="@atencion.NombreTramite">
                                                @atencion.NombreTramite
                                            </p>
                                            @if (!string.IsNullOrEmpty(atencion.Observacion))
                                            {
                                                <details class="mt-1">
                                                    <summary class="text-xs text-blue-600 cursor-pointer hover:text-blue-700 transition-colors">Ver observación inicial</summary>
                                                    <p class="text-xs text-slate-600 mt-1.5 p-2.5 bg-slate-50 rounded-lg border border-slate-200">@atencion.Observacion</p>
                                                </details>
                                            }
                                            @if (!string.IsNullOrEmpty(atencion.ObservacionAtencion))
                                            {
                                                <details class="mt-1">
                                                    <summary class="text-xs text-emerald-600 cursor-pointer hover:text-emerald-700 transition-colors">Ver observación de atención</summary>
                                                    <p class="text-xs text-slate-600 mt-1.5 p-2.5 bg-emerald-50 rounded-lg border border-emerald-100">@atencion.ObservacionAtencion</p>
                                                </details>
                                            }
                                        </div>
                                    </td>

                                    <!-- Hora -->
                                    <td class="px-6 py-4 whitespace-nowrap">
                                        <div class="flex flex-col gap-0.5">
                                            <span class="text-sm text-slate-900">@atencion.FechaRegistro.ToString("HH:mm")</span>
                                            <span class="text-xs text-slate-500">@atencion.FechaRegistro.ToString("dd/MM/yy")</span>
                                        </div>
                                    </td>

                                    <!-- Acciones -->
                                    <td class="px-6 py-4 whitespace-nowrap text-center">
                                        <div class="flex gap-2 justify-center">
                                            @if (atencion.NombreEstado == "Pendiente")
                                            {
                                                <button @onclick="@(() => IniciarAtencion(atencion))"
                                                        class="px-4 py-2 text-sm font-medium border border-emerald-600 text-emerald-600 rounded-lg hover:bg-emerald-50 active:scale-95 transition-all inline-flex items-center gap-2"
                                                        title="Iniciar atención">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                                                    </svg>
                                                    Atender
                                                </button>
                                            }
                                            @if (atencion.NombreEstado == "En Ventanilla")
                                            {
                                                <button @onclick="@(() => AbrirModalParaReanudar(atencion))"
                                                        class="px-4 py-2 text-sm font-medium border border-blue-600 text-blue-600 rounded-lg hover:bg-blue-50 active:scale-95 transition-all inline-flex items-center gap-2"
                                                        title="Ver atención en curso">
                                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                                        <path d="M10 12a2 2 0 100-4 2 2 0 000 4z"></path>
                                                        <path fill-rule="evenodd" d="M.458 10C1.732 5.943 5.522 3 10 3s8.268 2.943 9.542 7c-1.274 4.057-5.064 7-9.542 7S1.732 14.057.458 10zM14 10a4 4 0 11-8 0 4 4 0 018 0z" clip-rule="evenodd"></path>
                                                    </svg>
                                                    Ver
                                                </button>
                                            }
                                            @if (atencion.NombreEstado == "En Pausa")
                                            {
                                                <button @onclick="@(() => AbrirModalParaReanudar(atencion))"
                                                        class="px-4 py-2 text-sm font-medium border border-amber-600 text-amber-600 rounded-lg hover:bg-amber-50 active:scale-95 transition-all inline-flex items-center gap-2"
                                                        title="Reanudar atención pausada">
                                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                                        <path d="M6.3 2.841A1.5 1.5 0 004 4.11V15.89a1.5 1.5 0 002.3 1.269l9.344-5.89a1.5 1.5 0 000-2.538L6.3 2.84z"></path>
                                                    </svg>
                                                    Reanudar
                                                </button>
                                            }
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

                <!-- Paginación -->
                <div class="flex items-center justify-between mt-6 px-6 py-4 border-t border-slate-200 bg-slate-50/30">
                    <!-- Items por página -->
                    <div class="flex items-center gap-2 text-sm text-slate-600 flex-shrink-0">
                        <span class="whitespace-nowrap">Mostrar</span>
                        <select @bind="pageSize" @bind:after="StateHasChanged"
                                class="min-w-[70px] px-3 py-2 border border-slate-200 rounded-lg text-sm text-slate-700 bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all">
                            <option value="6">6</option>
                            <option value="12">12</option>
                            <option value="24">24</option>
                            <option value="48">48</option>
                        </select>
                        <span class="whitespace-nowrap">por página</span>
                    </div>

                    <!-- Paginación -->
                    <div class="flex items-center gap-2 flex-shrink-0">
                        <span class="text-sm text-slate-600 mr-4 whitespace-nowrap font-medium">
                            @((currentPage - 1) * pageSize + 1)-@Math.Min(currentPage * pageSize, AtencionesFiltradasCount) de @AtencionesFiltradasCount
                        </span>

                        <button @onclick="@(() => { currentPage = 1; StateHasChanged(); })"
                                disabled="@(currentPage == 1)"
                                class="p-2 text-slate-600 hover:bg-slate-100 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-all active:scale-95">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
                            </svg>
                        </button>

                        <button @onclick="PrevPage"
                                disabled="@(currentPage == 1)"
                                class="p-2 text-slate-600 hover:bg-slate-100 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-all active:scale-95">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </button>

                        <button class="px-4 py-1.5 bg-blue-600 text-white text-sm font-semibold rounded-lg min-w-[45px] shadow-sm">
                            @currentPage
                        </button>

                        <button @onclick="NextPage"
                                disabled="@(currentPage == totalPages)"
                                class="p-2 text-slate-600 hover:bg-slate-100 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-all active:scale-95">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </button>

                        <button @onclick="@(() => { currentPage = totalPages; StateHasChanged(); })"
                                disabled="@(currentPage == totalPages)"
                                class="p-2 text-slate-600 hover:bg-slate-100 rounded-lg disabled:opacity-30 disabled:cursor-not-allowed transition-all active:scale-95">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-16">
                    <svg class="w-16 h-16 text-slate-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <p class="text-lg text-slate-700 font-semibold">No hay atenciones activas</p>
                    <p class="text-sm text-slate-500 mt-1">Crea una nueva atención para comenzar</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Modal Formulario -->
<AtencionFormModal IsVisible="@mostrarModal"
                   @bind-TipoDocumento="@tipoDocumento"
                   @bind-NumeroDocumento="@numeroDocumento"
                   @bind-Nombres="@nombres"
                   @bind-Apellidos="@apellidos"
                   @bind-IdTipoTramite="@idTipoTramite"
                   @bind-Observacion="@observacion"
                   @bind-EsPreferencial="@esPreferencial"
                   @bind-IdTipoPreferencial="@idTipoPreferencial"
                   TiposTramite="@tiposTramite"
                   TiposPreferencial="@tiposPreferencial"
                   ErrorMessage="@mensajeError"
                   OnSave="@GuardarAtencion"
                   OnClose="@CerrarModal" />

<!-- Modal Atender -->
<AtencionAtenderModal IsVisible="@mostrarModalAtender"
                      IdAtencion="@(atencionSeleccionada?.IdAtencion)"
                      MostrarCronometro="@mostrarCronometro"
                      NumeroOrden="@(atencionSeleccionada?.NumeroOrden)"
                      Titulo="@tituloModalAtender"
                      TituloObservacion="@tituloObservacionModal"
                      Placeholder="@placeholderObservacion"
                      TextoBotonConfirmar="@textoBotonConfirmar"
                      NombrePersona="@(atencionSeleccionada?.NombreCompleto)"
                      DescripcionTramite="@(atencionSeleccionada?.NombreTramite)"
                      ObservacionInicial="@(atencionSeleccionada?.Observacion)"
                      @bind-Observacion="@observacionModal"
                      TiposTrabajo="@tiposTrabajo"
                      DetallesActividad="@detallesActividad"
                      @bind-IdTipoTrabajo="@idTipoTrabajoModal"
                      IdDetalleActividad="@idDetalleActividadModal"
                      IdDetalleActividadChanged="@OnDetalleActividadChanged"
                      @bind-NumeroExpediente="@numeroExpedienteModal"
                      MostrarNumeroExpediente="@mostrarNumeroExpediente"
                      ErrorMessage="@errorModalAtender"
                      OnConfirm="@ConfirmarCambioEstado"
                      OnClose="@CerrarModalAtender"
                      OnPausar="@PausarAtencion"
                      OnContinuar="@ContinuarAtencion"
                      OnCancelar="@ConfirmarCancelarAtencion" />

<!-- Modal de Confirmación para Cancelar -->
<ConfirmDialog IsVisible="@mostrarModalCancelar"
               Title="¿Cancelar atención?"
               Message="¿Está seguro de cancelar esta atención?"
               Type="@ConfirmDialogType.Danger"
               Icon="@ConfirmDialogIcon.Danger"
               ConfirmButtonText="Cancelar atención"
               OnConfirm="@CancelarAtencion"
               OnCancel="@(() => mostrarModalCancelar = false)" />

<!-- Toast -->
<Toast />

@code {
    private List<AtencionDto> atenciones = new();
    private List<TipoTramiteDto> tiposTramite = new();
    private List<TipoPreferencialDto> tiposPreferencial = new();
    private List<EstadoAtencionDto> estados = new();
    private List<TipoTrabajoDto> tiposTrabajo = new();
    private List<DetalleActividadDto> detallesActividad = new();
    private bool isLoading = true;

    // Modal
    private bool mostrarModal = false;
    private bool mostrarModalCancelar = false;
    private string tipoDocumento = "DNI";
    private string numeroDocumento = "";
    private string nombres = "";
    private string apellidos = "";
    private int idTipoTramite = 0;
    private string observacion = "";
    private bool esPreferencial = false;
    private int? idTipoPreferencial = null;
    private string mensajeError = "";

    // Modal Atender/Finalizar
    private bool mostrarModalAtender = false;
    private bool mostrarCronometro = false;
    private AtencionDto? atencionSeleccionada = null;
    private string observacionModal = "";
    private string errorModalAtender = "";
    private string accionModal = ""; // "atender" o "finalizar"
    private string tituloModalAtender = "";
    private string tituloObservacionModal = "";
    private string placeholderObservacion = "";
    private string textoBotonConfirmar = "";
    private int idTipoTrabajoModal = 0;
    private int idDetalleActividadModal = 0;
    private string numeroExpedienteModal = "";
    private bool mostrarNumeroExpediente = false;

    // Filtros y Paginación
    private string searchText = "";
    private string estadoFiltro = "";
    private string preferencialFiltro = "";
    private int currentPage = 1;
    private int pageSize = 12;

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();

        // Asegurar que SignalR esté conectado antes de suscribirse
        if (!SignalRService.IsConnected)
        {
            Console.WriteLine("Atenciones: SignalR no conectado, iniciando conexión...");
            await SignalRService.IniciarConexionAsync();
        }

        Console.WriteLine($"Atenciones: Estado de conexión SignalR: {SignalRService.IsConnected}");

        // Suscribirse a eventos de SignalR para actualizaciones en tiempo real
        SignalRService.OnNuevaAtencion += async () =>
        {
            Console.WriteLine("Atenciones: Evento OnNuevaAtencion recibido");
            await InvokeAsync(async () =>
            {
                await CargarAtenciones();
                NotificationService.ShowSuccess("¡Nueva atención registrada!");
                StateHasChanged();
            });
        };

        SignalRService.OnCambioEstadoAtencion += async (idAtencion) =>
        {
            Console.WriteLine($"Atenciones: Evento OnCambioEstadoAtencion recibido para ID: {idAtencion}");
            await InvokeAsync(async () =>
            {
                await CargarAtenciones();
                StateHasChanged();
            });
        };
    }

    private async Task CargarDatos()
    {
        isLoading = true;
        try
        {
            var atencionesTask = AtencionService.GetAtencionesActivasAsync();
            var tiposTramiteTask = AtencionService.GetTiposTramiteAsync();
            var tiposPreferencialTask = AtencionService.GetTiposPreferencialAsync();
            var estadosTask = AtencionService.GetEstadosAsync();
            var tiposTrabajoTask = AtencionService.GetTiposTrabajoAsync();
            var detallesActividadTask = AtencionService.GetDetallesActividadAsync();

            await Task.WhenAll(atencionesTask, tiposTramiteTask, tiposPreferencialTask, estadosTask, tiposTrabajoTask, detallesActividadTask);

            atenciones = atencionesTask.Result;
            tiposTramite = tiposTramiteTask.Result;
            tiposPreferencial = tiposPreferencialTask.Result;
            estados = estadosTask.Result;
            tiposTrabajo = tiposTrabajoTask.Result;
            detallesActividad = detallesActividadTask.Result;
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Error al cargar datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void AbrirModalNueva()
    {
        tipoDocumento = "DNI";
        numeroDocumento = "";
        nombres = "";
        apellidos = "";
        idTipoTramite = 0;
        observacion = "";
        esPreferencial = false;
        idTipoPreferencial = null;
        mensajeError = "";
        mostrarModal = true;
    }

    private void CerrarModal()
    {
        mostrarModal = false;
        mensajeError = "";
    }

    private async Task GuardarAtencion()
    {
        mensajeError = "";

        // Validaciones
        if (string.IsNullOrWhiteSpace(numeroDocumento))
        {
            mensajeError = "El número de documento es obligatorio.";
            return;
        }

        if (tipoDocumento == "DNI" && numeroDocumento.Length != 8)
        {
            mensajeError = "El DNI debe tener 8 dígitos.";
            return;
        }

        if (string.IsNullOrWhiteSpace(nombres) || string.IsNullOrWhiteSpace(apellidos))
        {
            mensajeError = "Nombres y apellidos son obligatorios.";
            return;
        }

        if (idTipoTramite == 0)
        {
            mensajeError = "Debe seleccionar un tipo de trámite.";
            return;
        }

        if (esPreferencial && (!idTipoPreferencial.HasValue || idTipoPreferencial == 0))
        {
            mensajeError = "Debe seleccionar el tipo de preferencia.";
            return;
        }

        var dto = new AtencionCreateDto
        {
            TipoDocumento = tipoDocumento,
            NumeroDocumento = numeroDocumento,
            Nombres = nombres,
            Apellidos = apellidos,
            IdTipoTramite = idTipoTramite,
            Observacion = observacion,
            EsPreferencial = esPreferencial,
            IdTipoPreferencial = esPreferencial ? idTipoPreferencial : null
        };

        var result = await AtencionService.CreateAtencionAsync(dto);

        if (result != null)
        {
            await CargarDatos();
            CerrarModal();
            NotificationService.ShowSuccess($"Atención registrada correctamente para {result.NombreCompleto}");
        }
        else
        {
            mensajeError = "Error al registrar la atención.";
            NotificationService.ShowError("Error al registrar la atención.");
        }
    }

    private async Task IniciarAtencion(AtencionDto atencion)
    {
        // Primero cambiar el estado a "En Ventanilla" SIN validar observación
        var estadoEnVentanilla = estados.FirstOrDefault(e => e.NombreEstado == "En Ventanilla");
        if (estadoEnVentanilla == null)
        {
            NotificationService.ShowError("No se encontró el estado 'En Ventanilla'.");
            return;
        }

        var dto = new AtencionUpdateDto
        {
            IdAtencion = atencion.IdAtencion,
            IdEstadoAtencion = estadoEnVentanilla.IdEstadoAtencion,
            Observacion = atencion.Observacion, // Mantener la observación inicial
            ObservacionAtencion = null // Aún no hay observación de atención
        };

        try
        {
            var ok = await AtencionService.UpdateEstadoAtencionAsync(atencion.IdAtencion, dto);
            if (ok)
            {
                // Actualizar el objeto local para reflejar el cambio de estado
                atencion.IdEstadoAtencion = estadoEnVentanilla.IdEstadoAtencion;
                atencion.NombreEstado = "En Ventanilla";
                atencion.OrdenEstado = 2;
                
                // Configurar y abrir modal ANTES de recargar datos
                atencionSeleccionada = atencion;
                observacionModal = "";
                errorModalAtender = "";
                accionModal = "finalizar";
                tituloModalAtender = "En ventanilla";
                tituloObservacionModal = "Observación de Atención";
                placeholderObservacion = "Ingrese los detalles de la atención brindada...";
                textoBotonConfirmar = "Finalizar";
                
                // Establecer valores por defecto para Tipo de Trabajo y Detalle de Actividad
                var tipoPresencial = tiposTrabajo.FirstOrDefault(t => t.NombreTipoTrabajo == "PRESENCIAL");
                idTipoTrabajoModal = tipoPresencial?.IdTipoTrabajo ?? (tiposTrabajo.FirstOrDefault()?.IdTipoTrabajo ?? 0);
                idDetalleActividadModal = 0; // Sin selección por defecto
                numeroExpedienteModal = "";
                mostrarNumeroExpediente = false;
                observacionModal = "";
                errorModalAtender = "";
                
                mostrarCronometro = true; // Activar cronómetro
                mostrarModalAtender = true;
                
                // Forzar actualización de la UI
                StateHasChanged();
            }
            else
            {
