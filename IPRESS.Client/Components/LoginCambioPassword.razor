@namespace IPRESS.Client.Components
@using Radzen
@using Radzen.Blazor
@inject UsuarioService UsuarioService
@inject NotificationService Notify
@inject DialogService DialogService

<RadzenStack Gap="1rem">
    <RadzenText TextStyle="TextStyle.Body2">Por seguridad, debe cambiar su contraseña antes de continuar.</RadzenText>
    <RadzenFormField Text="Nueva contraseña" Variant="Variant.Outlined">
        <div style="display:flex;align-items:center;gap:0;border:1px solid var(--rz-base-300);border-radius:4px;overflow:hidden;">
            @if (showNueva)
            {
                <RadzenTextBox @bind-Value="nuevaPassword" Placeholder="Nueva contraseña" Style="flex:1;border:none;box-shadow:none" />
            }
            else
            {
                <RadzenPassword @bind-Value="nuevaPassword" Placeholder="Nueva contraseña" Style="flex:1;border:none;box-shadow:none" />
            }
            <RadzenButton type="button" Icon="@(showNueva ? "visibility_off" : "visibility")" ButtonStyle="ButtonStyle.Light" Click="@(() => showNueva = !showNueva)" Style="min-width:2.5rem;flex-shrink:0" Title="@(showNueva ? "Ocultar" : "Ver")" />
        </div>
    </RadzenFormField>
    <RadzenFormField Text="Confirmar contraseña" Variant="Variant.Outlined">
        <div style="display:flex;align-items:center;gap:0;border:1px solid var(--rz-base-300);border-radius:4px;overflow:hidden;">
            @if (showConfirmar)
            {
                <RadzenTextBox @bind-Value="confirmarPassword" Placeholder="Confirmar contraseña" Style="flex:1;border:none;box-shadow:none" />
            }
            else
            {
                <RadzenPassword @bind-Value="confirmarPassword" Placeholder="Confirmar contraseña" Style="flex:1;border:none;box-shadow:none" />
            }
            <RadzenButton type="button" Icon="@(showConfirmar ? "visibility_off" : "visibility")" ButtonStyle="ButtonStyle.Light" Click="@(() => showConfirmar = !showConfirmar)" Style="min-width:2.5rem;flex-shrink:0" Title="@(showConfirmar ? "Ocultar" : "Ver")" />
        </div>
    </RadzenFormField>
    <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
        <RadzenButton Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@Cancel" />
        <RadzenButton Text="Guardar" Icon="save" Click="@Guardar" />
    </RadzenStack>
</RadzenStack>

@code {
    [Parameter] public int UsuarioId { get; set; }
    private string nuevaPassword = "";
    private string confirmarPassword = "";
    private bool showNueva = false;
    private bool showConfirmar = false;

    private async Task Guardar()
    {
        if (string.IsNullOrWhiteSpace(nuevaPassword) || nuevaPassword != confirmarPassword)
        {
            Notify.ShowError("Las contraseñas no coinciden.");
            return;
        }
        var ok = await UsuarioService.CambiarPasswordAsync(nuevaPassword);
        if (ok)
        {
            Notify.ShowSuccess("Contraseña actualizada. Vuelva a iniciar sesión.");
            DialogService.Close(true);
        }
        else Notify.ShowError("Error al cambiar la contraseña.");
    }

    private void Cancel() => DialogService.Close(false);
}
