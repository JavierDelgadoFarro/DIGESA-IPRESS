    private async Task DescargarExcel()
    {
        try
        {
            // Determinar el usuarioId a filtrar
            int? filtroUsuarioId = null;
            
            // Si hay un filtro de usuario aplicado, usar ese
            if (!string.IsNullOrEmpty(usuarioFiltro) && int.TryParse(usuarioFiltro, out int userId))
            {
                filtroUsuarioId = userId;
            }
            // Si no es administrador, filtrar por el usuario actual
            else if (!esAdministrador && usuarioActualId.HasValue)
            {
                filtroUsuarioId = usuarioActualId.Value;
            }
            // Si es administrador y no hay filtro, obtener todo (null)

            var excelBytes = await AtencionService.DescargarHistorialExcelAsync(filtroUsuarioId);
            
            if (excelBytes != null)
            {
                var fileName = $"Historial_Atenciones_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
                var base64 = Convert.ToBase64String(excelBytes);
                await JS.InvokeVoidAsync("downloadFileFromBase64", fileName, base64);
                
                // Mostrar notificación de éxito
                NotificationService.ShowSuccess("Excel descargado exitosamente");
            }
            else
            {
                NotificationService.ShowError("Error al generar el archivo Excel");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al descargar Excel: {ex.Message}");
            NotificationService.ShowError("Error al descargar el archivo");
        }
    }

    public void Dispose()
    {
        // Desuscribirse de eventos SignalR
        SignalRService.OnCambioEstadoAtencion -= async (idAtencion) => await CargarDatos();
    }
