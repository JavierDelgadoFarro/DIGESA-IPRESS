@page "/"
@page "/login"
@layout LoginLayout
@attribute [AllowAnonymous]
@inject AuthService AuthService
@inject NavigationManager NavManager
@inject AuthenticationStateProvider AuthProvider
@inject ILocalStorageService _localStorage
@inject SignalRService SignalRService
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Authorization
@using Blazored.LocalStorage
@using VisitasTickets.Client.Services
@using VisitasTickets.Client.Models
@inject UsuarioService UsuarioService

<div class="flex items-center justify-center min-h-screen bg-white">
    <div class="w-full max-w-md px-4">
        <!-- Card Principal -->
        <div class="bg-white shadow-2xl rounded-2xl overflow-hidden">
            <!-- Header con branding -->
            <div class="bg-gradient-to-r from-blue-600 to-blue-800 px-8 py-10 text-center">
                <div class="w-20 h-20 bg-white rounded-full mx-auto mb-4 flex items-center justify-center shadow-lg">
                    <svg class="w-12 h-12 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white mb-2">Sistema de Gestión de Visitas</h1>
            </div>

            <!-- Formulario -->
            <div class="px-8 py-10">
                <EditForm Model="@this" OnValidSubmit="DoLogin">
                    <div class="space-y-5">
                        <!-- Campo Usuario -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <span class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                    </svg>
                                    Usuario
                                </span>
                            </label>
                            <input type="text"
                                   @bind="username"
                                   @bind:event="oninput"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-gray-50 hover:bg-white"
                                   placeholder="Ingrese su usuario"
                                   disabled="@isLoading"
                                   autocomplete="username" />
                        </div>

                        <!-- Campo Contraseña -->
                        <div>
                            <label class="block text-sm font-medium text-gray-700 mb-2">
                                <span class="flex items-center gap-2">
                                    <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
                                    </svg>
                                    Contraseña
                                </span>
                            </label>
                            <input type="password"
                                   @bind="password"
                                   @bind:event="oninput"
                                   @onkeydown="HandleKeyDown"
                                   class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-all duration-200 bg-gray-50 hover:bg-white"
                                   placeholder="Ingrese su contraseña"
                                   disabled="@isLoading"
                                   autocomplete="current-password" />
                        </div>

                        <!-- Mensaje de Error -->
                        @if (!string.IsNullOrEmpty(errorMessage))
                        {
                            <div class="bg-rose-50 border-l-4 border-rose-600 p-4 rounded-r-lg animate-pulse">
                                <div class="flex items-center gap-2">
                                    <svg class="w-5 h-5 text-rose-600 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
                                    </svg>
                                    <p class="text-sm text-rose-700 font-medium">@errorMessage</p>
                                </div>
                            </div>
                        }

                        <!-- Botón de Login -->
                        <button type="submit"
                                disabled="@isLoading"
                                class="w-full bg-gradient-to-r from-blue-600 to-blue-700 text-white font-semibold py-3 px-4 rounded-lg hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transform transition-all duration-200 hover:scale-105 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:scale-100 shadow-lg">
                            @if (isLoading)
                            {
                                <span class="flex items-center justify-center gap-2">
                                    <svg class="animate-spin h-5 w-5 text-white" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
                                    </svg>
                                    <span>Iniciando sesión...</span>
                                </span>
                            }
                            else
                            {
                                <span class="flex items-center justify-center gap-2">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"></path>
                                    </svg>
                                    <span>Ingresar</span>
                                </span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
</div>

@if (mostrarModalCambioPassword)
{
    <div class="fixed inset-0 bg-black bg-opacity-50 z-50 flex items-center justify-center p-4">
        <div class="bg-white rounded-2xl shadow-2xl max-w-md w-full p-6">
            <h3 class="text-xl font-bold mb-4">Cambiar Contraseña</h3>
            <p class="mb-4">Por seguridad, debe cambiar su contraseña antes de continuar.</p>

            <div class="space-y-4">
                <input type="password" @bind="nuevaPassword" placeholder="Nueva contraseña" class="w-full border px-3 py-2 rounded" />
                <input type="password" @bind="confirmarPassword" placeholder="Confirmar contraseña" class="w-full border px-3 py-2 rounded" />
            </div>

            <div class="flex justify-end gap-2 mt-6">
                <button @onclick="CerrarModalCambioPassword" class="px-4 py-2 border rounded">Cancelar</button>
                <button @onclick="GuardarNuevaPassword" class="px-4 py-2 bg-blue-600 text-white rounded">Guardar</button>
            </div>
        </div>
    </div>
}

@if (mostrarToast)
{
    <div class="fixed bottom-4 right-4 @toastColor text-white px-4 py-2 rounded-lg shadow-lg transition-opacity duration-500">
        @mensajeToast
    </div>
}

@code {
    private string username = string.Empty;
    private string password = string.Empty;
    private string errorMessage = string.Empty;
    private bool isLoading = false;
    private bool mostrarModalCambioPassword = false;
    private string nuevaPassword = "";
    private string confirmarPassword = "";
    private int usuarioId;
    private bool mostrarToast = false;
    private string mensajeToast = "";
    private string toastColor = "bg-emerald-600";


    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isLoading)
        {
            await DoLogin();
        }
    }

    private async Task DoLogin()
    {
        if (string.IsNullOrWhiteSpace(username) || string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Por favor, complete todos los campos.";
            return;
        }

        errorMessage = string.Empty;
        isLoading = true;

        try
        {
            var result = await AuthService.LoginAsync(username, password);

            if (result.RequiereCambio)
            {
                mostrarModalCambioPassword = true;
                usuarioId = result.UsuarioId;
                return;
            }

            if (!string.IsNullOrEmpty(result.Token))
            {
                ((CustomAuthStateProvider)AuthProvider).NotifyUserAuthentication(result.Token);
                
                // Dar tiempo al AuthenticationStateProvider para actualizar el estado
                await Task.Delay(100);
                
                // Iniciar conexión SignalR
                await SignalRService.IniciarConexionAsync();
                
                // Obtener accesos del usuario y redirigir al dashboard correspondiente
                var accesos = await AuthService.GetAccesosAsync();
                string rutaDestino = "/principal"; // Ruta por defecto

                if (accesos != null && accesos.Modulos != null)
                {
                    // Obtener todas las rutas a las que el usuario tiene acceso
                    var rutasDisponibles = accesos.Modulos
                        .SelectMany(m => m.Menus)
                        .SelectMany(m => m.SubMenus)
                        .Select(s => s.Ruta?.ToLower())
                        .Where(r => !string.IsNullOrEmpty(r))
                        .ToList();

                    // Prioridad: dashboard/admin > dashboard/user > principal
                    if (rutasDisponibles.Contains("/dashboard/admin"))
                    {
                        rutaDestino = "/dashboard/admin";
                    }
                    else if (rutasDisponibles.Contains("/dashboard/user"))
                    {
                        rutaDestino = "/dashboard/user";
                    }
                }

                NavManager.NavigateTo(rutaDestino);
            }
            else
            {
                errorMessage = result.Message ?? "Credenciales inválidas. Por favor, verifique su usuario y contraseña.";
            }
        }
        catch (HttpRequestException)
        {
            errorMessage = "Error al conectar con el servidor. Verifique su conexión.";
        }
        catch (Exception ex)
        {
            errorMessage = "Error inesperado. Intente nuevamente.";
            Console.WriteLine($"Error en login: {ex.Message}");
        }
        finally
        {
            isLoading = false;
        }
    }


    private async Task GuardarNuevaPassword()
    {
        if (string.IsNullOrWhiteSpace(nuevaPassword) || nuevaPassword != confirmarPassword)
        {
            mensajeToast = "Las contraseñas no coinciden.";
            toastColor = "bg-rose-600";
            mostrarToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            mostrarToast = false;
            return;
        }

        var ok = await UsuarioService.CambiarPasswordAsync(usuarioId, nuevaPassword);
        if (ok)
        {
            mostrarModalCambioPassword = false;
            mensajeToast = "Contraseña actualizada correctamente. Vuelva a iniciar sesión.";
            toastColor = "bg-emerald-600";
            mostrarToast = true;
            StateHasChanged();

            await Task.Delay(1000);
            mostrarToast = false;

            NavManager.NavigateTo("/login", true);
        }
        else
        {
            mensajeToast = "Error al cambiar la contraseña.";
            toastColor = "bg-rose-600";
            mostrarToast = true;
            StateHasChanged();
            await Task.Delay(3000);
            mostrarToast = false;
        }
    }

    private void CerrarModalCambioPassword()
    {
        mostrarModalCambioPassword = false;
        nuevaPassword = "";
        confirmarPassword = "";
    }
}