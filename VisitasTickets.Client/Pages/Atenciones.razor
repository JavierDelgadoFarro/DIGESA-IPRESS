    private async Task CancelarAtencion()
    {
        if (atencionSeleccionada == null) return;

        mostrarModalCancelar = false;

        var estadoCancelado = estados.FirstOrDefault(e => e.NombreEstado == "Cancelado");
        if (estadoCancelado == null)
