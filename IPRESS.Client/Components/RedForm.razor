@namespace IPRESS.Client.Components
@using Radzen
@using Radzen.Blazor
@inject MaestrosService Maestros
@inject NotificationService Notify
@inject DialogService DialogService

<EditForm Model="@Form" OnValidSubmit="@Guardar">
    <RadzenStack Gap="1rem">
        <IpressFormField Text="Diresa">
            <IpressDropDown @bind-Value="Form.IdDiresa" Data="@diresasConOpcion" TextProperty="Nombre" ValueProperty="Id" />
        </IpressFormField>
        <IpressFormField Text="Código">
            <IpressTextBox @bind-Value="@CodigoTexto" Placeholder="" MaxLength="10" />
        </IpressFormField>
        <IpressFormField Text="Nombre">
            <IpressTextBox @bind-Value="@Form.Nombre" />
        </IpressFormField>
        <IpressFormField Text="Departamento (opcional)">
            <IpressDropDown Data="@departamentosConOpcion" TextProperty="Nombre" ValueProperty="Codigo" @bind-Value="@codigoDepartamento" Change="@OnDepartamentoChange" />
        </IpressFormField>
        <IpressFormField Text="Provincia (opcional)">
            <IpressDropDown Data="@provinciasConOpcion" TextProperty="Nombre" ValueProperty="Codigo" @bind-Value="@codigoProvincia" Change="@OnProvinciaChange" />
        </IpressFormField>
        <IpressFormField Text="Distrito (opcional)">
            <IpressDropDown Data="@distritosConOpcion" TextProperty="Nombre" ValueProperty="Ubigeo" @bind-Value="@Form.Ubigeo" />
        </IpressFormField>
        <IpressFormField Text="Ubigeo (solo lectura)">
            <IpressTextBox Value="@Form.Ubigeo" ReadOnly="true" />
        </IpressFormField>
        <RadzenStack Orientation="Orientation.Horizontal" JustifyContent="JustifyContent.End" Gap="0.5rem">
            <RadzenButton ButtonType="ButtonType.Button" Text="Cancelar" ButtonStyle="ButtonStyle.Light" Click="@(() => DialogService.Close(false))" />
            <RadzenButton ButtonType="ButtonType.Submit" Text="Guardar" Icon="save" />
        </RadzenStack>
    </RadzenStack>
</EditForm>

@code {
    [Parameter] public RedDto Form { get; set; } = new();
    [Parameter] public List<DiresaDto> Diresas { get; set; } = new();

    private string _codigoTexto = "";
    private List<GeografiaItemDto> departamentos = new();
    private List<ProvinciaItemDto> provincias = new();
    private List<DistritoItemDto> distritos = new();
    private IEnumerable<SelectOptionIntRed> diresasConOpcion => new[] { new SelectOptionIntRed { Id = 0, Nombre = "--seleccionar--" } }.Concat(Diresas.Select(d => new SelectOptionIntRed { Id = d.IdDiresa, Nombre = d.Nombre }));
    private IEnumerable<GeografiaItemDto> departamentosConOpcion => new[] { new GeografiaItemDto { Codigo = "", Nombre = "--seleccionar--" } }.Concat(departamentos);
    private IEnumerable<ProvinciaItemDto> provinciasConOpcion => new[] { new ProvinciaItemDto { Codigo = "", Nombre = "--seleccionar--" } }.Concat(provincias);
    private IEnumerable<DistritoItemDto> distritosConOpcion => new[] { new DistritoItemDto { Ubigeo = "", Nombre = "--seleccionar--" } }.Concat(distritos);
    private string? codigoDepartamento;
    private string? codigoProvincia;

    protected override async Task OnInitializedAsync()
    {
        departamentos = await Maestros.GetDepartamentosAsync() ?? new();
    }

    protected override async Task OnParametersSetAsync()
    {
        _codigoTexto = Form.IdRed > 0 ? Form.Codigo.ToString() : "";
        if (Form.Ubigeo?.Length == 6 && distritos.Count == 0)
        {
            codigoProvincia = Form.Ubigeo.Substring(0, 4);
            codigoDepartamento = Form.Ubigeo.Substring(0, 2);
            provincias = await Maestros.GetProvinciasAsync(codigoDepartamento) ?? new();
            distritos = await Maestros.GetDistritosAsync(codigoProvincia) ?? new();
        }
    }

    private string CodigoTexto { get => _codigoTexto; set => _codigoTexto = value ?? ""; }

    private async Task OnDepartamentoChange()
    {
        codigoProvincia = null;
        Form.Ubigeo = null;
        provincias = string.IsNullOrEmpty(codigoDepartamento) ? new() : (await Maestros.GetProvinciasAsync(codigoDepartamento) ?? new());
        distritos = new();
        await InvokeAsync(StateHasChanged);
    }

    private async Task OnProvinciaChange()
    {
        Form.Ubigeo = null;
        distritos = string.IsNullOrEmpty(codigoProvincia) ? new() : (await Maestros.GetDistritosAsync(codigoProvincia) ?? new());
        await InvokeAsync(StateHasChanged);
    }

    private async Task Guardar()
    {
        if (!int.TryParse(_codigoTexto?.Trim(), out var codigo))
        {
            Notify.ShowError("El código debe ser numérico.");
            return;
        }
        Form.Codigo = codigo;
        var ok = Form.IdRed > 0 ? await Maestros.PutRedAsync(Form.IdRed, Form) : await Maestros.PostRedAsync(Form);
        if (ok) { Notify.ShowSuccess("Guardado correctamente."); DialogService.Close(true); }
        else Notify.ShowError("Error al guardar.");
    }

    private sealed class SelectOptionIntRed { public int Id { get; set; } public string Nombre { get; set; } = ""; }
}
