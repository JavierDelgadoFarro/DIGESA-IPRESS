@page "/atenciones/atendidos"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout
@using VisitasTickets.Client.Services
@using VisitasTickets.Client.Components.Common
@using VisitasTickets.Domain.Dtos
@using Microsoft.JSInterop
@inject AtencionService AtencionService
@inject NotificationService NotificationService
@inject AuthService AuthService
@inject SignalRService SignalRService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthenticationStateProvider
@inject IJSRuntime JS
@implements IDisposable

<PageTitle>Historial de Atenciones - Sistema de Atenciones</PageTitle>

<!-- Container Principal -->
<div class="max-w-7xl mx-auto space-y-6">
    <!-- Título de la Página -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-bold text-slate-900">Historial de Atenciones</h1>
            <p class="text-sm text-slate-500 mt-1">Consulta todas las atenciones finalizadas y canceladas</p>
        </div>
    </div>

    <!-- Card con Filtros y Lista -->
    <div class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
        <!-- Filtros -->
        <div class="px-6 py-4 border-b border-slate-200 bg-slate-50/30">
            <div class="flex flex-col lg:flex-row gap-4">
                <!-- Buscador -->
                <div class="flex-1 max-w-md">
                    <div class="relative">
                        <input type="text"
                               @bind="searchText"
                               @bind:event="oninput"
                               @bind:after="OnSearchChanged"
                               placeholder="Buscar por nombre, apellido o documento..."
                               class="w-full pl-4 pr-10 py-2.5 border border-slate-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition-all text-sm bg-white text-slate-900 placeholder:text-slate-400">
                        <svg class="absolute right-3 top-2.5 w-5 h-5 text-slate-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                    </div>
                </div>

                <!-- Filtros -->
                <div class="flex flex-wrap items-center gap-3">
                    <!-- Filtro por Estado -->
                    <select @bind="estadoFiltro" @bind:after="OnFiltroChanged"
                            class="min-w-[180px] px-4 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white transition-all text-slate-700">
                        <option value="">Todos los estados</option>
                        <option value="Atendido">✅ Atendido</option>
                        <option value="Cancelado">❌ Cancelado</option>
                    </select>

                    <!-- Filtro Preferencial -->
                    <select @bind="preferencialFiltro" @bind:after="OnFiltroChanged"
                            class="min-w-[140px] px-4 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white transition-all text-slate-700">
                        <option value="">Todos</option>
                        <option value="preferencial">⭐ Preferenciales</option>
                        <option value="normal">Normales</option>
                    </select>

                    <!-- Filtro por Usuario Atendedor -->
                    <select @bind="usuarioFiltro" @bind:after="OnFiltroChanged"
                            disabled="@(!esAdministrador)"
                            class="min-w-[180px] px-4 py-2.5 border border-slate-200 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 bg-white transition-all text-slate-700 @(esAdministrador ? "" : "opacity-60 cursor-not-allowed")">
                        <option value="">Todos los usuarios</option>
                        @foreach (var usuario in UsuariosQueAtendieron)
                        {
                            <option value="@usuario.Id">@usuario.Nombre</option>
                        }
                    </select>

                    <!-- Botón Descargar Excel -->
                    <button @onclick="DescargarExcel"
                            class="px-4 py-2.5 bg-green-600 hover:bg-green-700 text-white font-medium rounded-lg shadow-sm transition-all duration-200 flex items-center gap-2 text-sm whitespace-nowrap">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                        </svg>
                        Descargar Excel
                    </button>
                </div>
            </div>
        </div>

        <!-- Lista de Atenciones -->
        <div class="p-6">
            @if (isLoading)
            {
                <div class="flex justify-center items-center py-16">
                    <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-blue-600"></div>
                </div>
            }
            else if (AtencionesFiltradasPaginadas.Any())
            {
                <div class="space-y-3">
                    @foreach (var atencion in AtencionesFiltradasPaginadas)
                    {
                        var isExpanded = atencionExpandida == atencion.IdAtencion;
                        var tiempoTotal = CalcularTiempoTotal(atencion);
                        var borderColor = atencion.NombreEstado == "Cancelado" ? "border-rose-300" : "border-emerald-300";

                        <div class="border-2 @borderColor rounded-lg overflow-hidden bg-white hover:shadow-md transition-all">
                            <!-- Header Clickeable -->
                            <div class="p-4 cursor-pointer hover:bg-gray-50 transition-colors"
                                 @onclick="@(() => ToggleExpand(atencion.IdAtencion))">
                                <div class="flex items-center justify-between">
                                    <!-- Información Principal -->
                                    <div class="flex-1 flex items-center gap-4">
                                        <!-- Expand Icon -->
                                        <div class="text-gray-400">
                                            @if (isExpanded)
                                            {
                                                <svg class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                                                </svg>
                                            }
                                            else
                                            {
                                                <svg class="w-5 h-5 transform transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                                                </svg>
                                            }
                                        </div>

                                        <!-- Datos del Ciudadano -->
                                        <div class="flex-1">
                                            <div class="flex items-center gap-3 mb-1">
                                                <span class="text-sm font-bold text-gray-900">@atencion.NombreCompleto</span>
                                                <span class="text-xs text-gray-500">@atencion.TipoDocumento: @atencion.NumeroDocumento</span>
                                                @if (atencion.EsPreferencial)
                                                {
                                                    <span class="text-xs font-semibold px-2 py-0.5 bg-amber-50 text-amber-700 border border-amber-100 rounded-full">
                                                        ⭐ Preferencial
                                                    </span>
                                                }
                                            </div>
                                            <div class="flex items-center gap-4 text-xs text-gray-600">
                                                <span class="flex items-center gap-1">
                                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                                    </svg>
                                                    @atencion.NombreTramite
                                                </span>
                                            </div>
                                            <div class="flex items-center gap-4 text-xs text-gray-600 mt-1.5">
                                                <span class="flex items-center gap-1">
                                                    <svg class="w-4 h-4 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
                                                    </svg>
                                                    <span class="font-medium">Registro:</span>
                                                    @atencion.FechaRegistro.ToString("dd/MM/yyyy HH:mm")
                                                </span>
                                                <span class="flex items-center gap-1">
                                                    <svg class="w-4 h-4 text-emerald-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                    </svg>
                                                    <span class="font-medium">Finalización:</span>
                                                    @atencion.FechaActualizacion?.ToString("dd/MM/yyyy HH:mm")
                                                </span>
                                            </div>
                                        </div>

                                        <!-- Badge de Estado y Tiempo -->
                                        <div class="flex items-center gap-3">
                                            @if (atencion.NombreEstado == "Atendido")
                                            {
                                                <span class="text-xs font-semibold px-3 py-1.5 bg-emerald-50 text-emerald-700 border border-emerald-100 rounded-full">
                                                    ✅ Atendido
                                                </span>
                                            }
                                            else if (atencion.NombreEstado == "Cancelado")
                                            {
                                                <span class="text-xs font-semibold px-3 py-1.5 bg-rose-50 text-rose-700 border border-rose-100 rounded-full">
                                                    ❌ Cancelado
                                                </span>
                                            }
                                            @if (tiempoTotal.TotalMinutes > 0)
                                            {
                                                <span class="text-xs text-gray-500 font-medium">
                                                    ⏱️ @FormatearTiempo(tiempoTotal)
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Detalles Expandidos -->
                            @if (isExpanded)
                            {
                                <div class="border-t border-gray-200 bg-gray-50 p-6 animate-fadeIn">
                                    @if (cargandoHistorial)
                                    {
                                        <div class="flex justify-center items-center py-8">
                                            <div class="animate-spin rounded-full h-8 w-8 border-b-2 border-blue-600"></div>
                                            <span class="ml-3 text-sm text-gray-600">Cargando historial...</span>
                                        </div>
                                    }
                                    else if (historialesPorAtencion.ContainsKey(atencion.IdAtencion))
                                    {
                                        var historial = historialesPorAtencion[atencion.IdAtencion];
                                        // Calcular tiempo total solo de estados con tiempo (excluyendo estado final y pausa)
                                        var tiempoTotalCalculado = historial.Any()
                                            ? TimeSpan.FromSeconds(historial.Where(h => h.MinutosEnEsteEstado.HasValue && h.OrdenEstadoNuevo != 3).Sum(h => h.MinutosEnEsteEstado.Value))
                                            : TimeSpan.Zero;

                                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                                            <!-- Columna Izquierda: Timeline Dinámico -->
                                            <div class="space-y-4">
                                                <h3 class="text-sm font-bold text-gray-900 flex items-center gap-2">
                                                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                                    </svg>
                                                    Historial de Atención
                                                </h3>

                                                @if (historial.Any())
                                                {
                                                    @for (int i = 0; i < historial.Count; i++)
                                                    {
                                                        var item = historial[i];
                                                        var esUltimo = i == historial.Count - 1;

                                                        <div class="flex gap-3">
                                                            <div class="flex flex-col items-center">
                                                                <div class="w-8 h-8 rounded-full @GetEstadoColorClass(item.OrdenEstadoNuevo) flex items-center justify-center">
                                                                    <span class="text-sm">@GetEstadoIcon(item.OrdenEstadoNuevo)</span>
                                                                </div>
                                                                @if (!esUltimo)
                                                                {
                                                                    <div class="w-0.5 h-full bg-gray-300 mt-1"></div>
                                                                }
                                                            </div>
                                                            <div class="flex-1 @(!esUltimo ? "pb-4" : "")">
                                                                <p class="text-sm font-semibold text-gray-900">@item.NombreEstadoNuevo</p>
                                                                <p class="text-xs text-gray-600">@item.FechaCambio.ToString("dd/MM/yyyy HH:mm:ss")</p>
                                                                
                                                                @if (!string.IsNullOrEmpty(item.NombreUsuario))
                                                                {
                                                                    <p class="text-xs text-gray-500 mt-1">
                                                                        @if (item.IdEstadoAnterior == null)
                                                                        {
                                                                            <span>Registrado por: <span class="font-medium">@item.NombreUsuario</span></span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span>Cambiado por: <span class="font-medium">@item.NombreUsuario</span></span>
                                                                        }
                                                                    </p>
                                                                }
                                                                
                                                                @if (item.MinutosEnEsteEstado.HasValue)
                                                                {
                                                                    var tiempoEnEstado = TimeSpan.FromSeconds(item.MinutosEnEsteEstado.Value);
                                                                    <p class="text-xs text-blue-600 font-medium mt-1">
                                                                        ⏱️ Tiempo en este estado: @FormatearTiempo(tiempoEnEstado)
                                                                    </p>
                                                                }
                                                                else if (esUltimo && item.OrdenEstadoNuevo >= 4)
                                                                {
                                                                    <p class="text-xs text-emerald-600 font-medium mt-1">
                                                                        ✅ Atención finalizada
                                                                    </p>
                                                                }

                                                                @if (!string.IsNullOrEmpty(item.Observacion) && item.IdEstadoAnterior != null)
                                                                {
                                                                    <div class="mt-2 p-2 bg-blue-50 rounded border border-blue-100">
                                                                        <p class="text-xs text-blue-900">@item.Observacion</p>
                                                                    </div>
                                                                }

                                                                @if (esUltimo && tiempoTotalCalculado.TotalMinutes > 0)
                                                                {
                                                                    <p class="text-xs text-emerald-600 font-bold mt-2">
                                                                        🏁 Tiempo total de atención: @FormatearTiempo(tiempoTotalCalculado)
                                                                    </p>
                                                                }
                                                            </div>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <p class="text-sm text-gray-500 italic">No hay historial disponible</p>
                                                }
                                            </div>

                                            <!-- Columna Derecha: Detalles -->
                                            <div class="space-y-4">
                                                <h3 class="text-sm font-bold text-gray-900 flex items-center gap-2">
                                                    <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                                                    </svg>
                                                    Detalles de la Atención
                                                </h3>

                                            <!-- Información del Trámite -->
                                            <div class="bg-white rounded-lg p-3 border border-gray-200">
                                                <p class="text-xs text-gray-500 mb-1">Tipo de Trámite</p>
                                                <p class="text-sm font-semibold text-gray-900">@atencion.NombreTramite</p>
                                                @if (!string.IsNullOrEmpty(atencion.DescripcionTramite))
                                                {
                                                    <p class="text-xs text-gray-600 mt-1">@atencion.DescripcionTramite</p>
                                                }
                                            </div>

                                            <!-- Atención Preferencial -->
                                            @if (atencion.EsPreferencial && !string.IsNullOrEmpty(atencion.NombreTipoPreferencial))
                                            {
                                                <div class="bg-amber-50 rounded-lg p-3 border border-amber-100">
                                                    <p class="text-xs text-amber-700 mb-1">Atención Preferencial</p>
                                                    <p class="text-sm font-semibold text-amber-900">@atencion.NombreTipoPreferencial</p>
                                                </div>
                                            }

                                            <!-- Observaciones -->
                                            @if (!string.IsNullOrEmpty(atencion.Observacion))
                                            {
                                                <div class="bg-white rounded-lg p-3 border border-gray-200">
                                                    <p class="text-xs text-gray-500 mb-1">Observación Inicial (Administrado)</p>
                                                    <p class="text-sm text-gray-700 italic">@atencion.Observacion</p>
                                                </div>
                                            }

                                             <!-- Tipo de Trabajo -->
                                            @if (!string.IsNullOrEmpty(atencion.NombreTipoTrabajo))
                                            {
                                                <div class="bg-white rounded-lg p-3 border border-gray-200">
                                                    <p class="text-xs text-gray-500 mb-1">Tipo de Trabajo</p>
                                                    <p class="text-sm font-semibold text-gray-900">@atencion.NombreTipoTrabajo</p>
                                                </div>
                                            }

                                            
                                            <!-- Detalle de Actividad -->
                                            @if (!string.IsNullOrEmpty(atencion.NombreActividad))
                                            {
                                                <div class="bg-white rounded-lg p-3 border border-gray-200">
                                                    <p class="text-xs text-gray-500 mb-1">Detalle de Actividad</p>
                                                    <p class="text-sm font-semibold text-gray-900">@atencion.NombreActividad</p>
                                                </div>
                                            }

                                            <!-- Número de Expediente -->
                                            @if (!string.IsNullOrEmpty(atencion.NumeroExpediente))
                                            {
                                                <div class="bg-indigo-50 rounded-lg p-3 border border-indigo-100">
                                                    <p class="text-xs text-indigo-700 mb-1">Número de Expediente</p>
                                                    <p class="text-sm font-bold text-indigo-900">@atencion.NumeroExpediente</p>
                                                </div>
                                            }

                                            @if (!string.IsNullOrEmpty(atencion.ObservacionAtencion))
                                            {
                                                <div class="bg-blue-50 rounded-lg p-3 border border-blue-100">
                                                    <p class="text-xs text-blue-700 mb-1">Observación de Ventanilla</p>
                                                    <p class="text-sm text-blue-900 font-medium">@atencion.ObservacionAtencion</p>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Paginación -->
                <div class="flex items-center justify-between mt-6 px-6 py-3 border-t border-gray-200 bg-gray-50">
                    <!-- Items por página -->
                    <div class="flex items-center gap-2 text-sm text-gray-700 flex-shrink-0">
                        <span class="whitespace-nowrap">Mostrar</span>
                        <select @bind="itemsPorPagina" @bind:after="OnItemsPorPaginaChanged"
                                class="min-w-[70px] px-3 py-2 border border-gray-300 rounded-md text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500">
                            <option value="6">6</option>
                            <option value="12">12</option>
                            <option value="24">24</option>
                            <option value="48">48</option>
                        </select>
                        <span class="whitespace-nowrap">por página</span>
                    </div>

                    <!-- Paginación -->
                    <div class="flex items-center gap-2 flex-shrink-0">
                        <span class="text-sm text-gray-700 mr-4 whitespace-nowrap">
                            @((paginaActual - 1) * itemsPorPagina + 1)-@Math.Min(paginaActual * itemsPorPagina, AtencionesFiltradas.Count()) de @AtencionesFiltradas.Count()
                        </span>

                        <button @onclick="@(() => CambiarPagina(1))"
                                disabled="@(paginaActual == 1)"
                                class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 19l-7-7 7-7m8 14l-7-7 7-7"></path>
                            </svg>
                        </button>

                        <button @onclick="@(() => CambiarPagina(paginaActual - 1))"
                                disabled="@(paginaActual == 1)"
                                class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                            </svg>
                        </button>

                        <button class="px-3 py-1 bg-blue-600 text-white text-sm font-medium rounded-lg min-w-[40px]">
                            @paginaActual
                        </button>

                        <button @onclick="@(() => CambiarPagina(paginaActual + 1))"
                                disabled="@(paginaActual == totalPaginas)"
                                class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                            </svg>
                        </button>

                        <button @onclick="@(() => CambiarPagina(totalPaginas))"
                                disabled="@(paginaActual == totalPaginas)"
                                class="p-2 text-gray-600 hover:bg-gray-200 rounded-lg disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 5l7 7-7 7M5 5l7 7-7 7"></path>
                            </svg>
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="text-center py-16">
                    <svg class="mx-auto h-16 w-16 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    <h3 class="mt-4 text-lg font-medium text-gray-900">No hay atenciones en el historial</h3>
                    <p class="mt-2 text-sm text-gray-500">No se encontraron atenciones con los filtros seleccionados</p>
                </div>
            }
        </div>
    </div>
</div>

<!-- Toast Component -->
<Toast @ref="toast" />

<style>
    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(-10px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .animate-fadeIn {
        animation: fadeIn 0.3s ease-out;
    }
</style>

@code {
    private List<AtencionDto> atenciones = new();
    private List<TipoTramiteDto> tiposTramite = new();
    private Dictionary<int, List<HistorialAtencionDto>> historialesPorAtencion = new();
    private string searchText = "";
    private string estadoFiltro = "";
    private string preferencialFiltro = "";
    private string usuarioFiltro = "";
    private bool isLoading = false;
    private int? atencionExpandida = null;
    private bool cargandoHistorial = false;
    private bool esAdministrador = false;
    private int? usuarioActualId = null;

    // Paginación
    private int paginaActual = 1;
    private int itemsPorPagina = 12;
    private int AtencionesFiltradasCount => AtencionesFiltradas.Count();
    private int totalPaginas => (int)Math.Ceiling((double)AtencionesFiltradasCount / itemsPorPagina);

    private Toast? toast;

    protected override async Task OnInitializedAsync()
    {
        await VerificarPermisos();
        await CargarDatos();

        // Asegurar que SignalR esté conectado
        if (!SignalRService.IsConnected)
        {
            Console.WriteLine("Atendidos: SignalR no conectado, iniciando conexión...");
            await SignalRService.IniciarConexionAsync();
        }

        Console.WriteLine($"Atendidos: Estado de conexión SignalR: {SignalRService.IsConnected}");

        // Suscribirse a eventos de SignalR para actualizar cuando se finaliza o cancela una atención
        SignalRService.OnCambioEstadoAtencion += async (idAtencion) =>
        {
            Console.WriteLine($"Atendidos: Evento OnCambioEstadoAtencion recibido para ID: {idAtencion}");
            await InvokeAsync(async () =>
            {
                await CargarDatos();
                StateHasChanged();
            });
        };
    }

    private async Task VerificarPermisos()
    {
        try
        {
            // Obtener el ID del usuario actual
            var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            var userIdClaim = user.FindFirst("UsuarioId");
            
            if (userIdClaim != null && int.TryParse(userIdClaim.Value, out int userId))
            {
                usuarioActualId = userId;
            }

            // Obtener accesos del usuario
            var accesos = await AuthService.GetAccesosAsync();
            
            if (accesos != null && accesos.Modulos != null)
            {
                // Verificar si tiene acceso al dashboard de administrador
                esAdministrador = accesos.Modulos.Any(m => 
                    m.Menus?.Any(menu => 
                        menu.SubMenus?.Any(sm => 
                            sm.Ruta != null && sm.Ruta.Contains("/dashboard/admin")
                        ) ?? false
                    ) ?? false
                );
            }

            // Establecer filtro según permisos
            if (esAdministrador)
            {
                // Si es administrador, NO filtrar por usuario (mostrar todos)
                usuarioFiltro = "";
            }
            else if (usuarioActualId.HasValue)
            {
                // Si NO es administrador, filtrar solo por su usuario
                usuarioFiltro = usuarioActualId.Value.ToString();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al verificar permisos: {ex.Message}");
            // Por defecto, si hay error, asumir que no es admin y filtrar por usuario actual
            esAdministrador = false;
            if (usuarioActualId.HasValue)
            {
                usuarioFiltro = usuarioActualId.Value.ToString();
            }
        }
        
        Console.WriteLine($"VerificarPermisos: esAdministrador={esAdministrador}, usuarioActualId={usuarioActualId}, usuarioFiltro='{usuarioFiltro}'");
    }

    private async Task CargarDatos()
    {
        try
        {
            isLoading = true;
            StateHasChanged();

            atenciones = await AtencionService.GetAtencionesHistorialAsync();
            tiposTramite = await AtencionService.GetTiposTramiteAsync();
            
            // Cargar historial de todas las atenciones para mostrar tiempo correcto en badges
            await CargarHistorialTodasAtenciones();
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Error al cargar datos: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private IEnumerable<AtencionDto> AtencionesFiltradas
    {
        get
        {
            var resultado = atenciones.AsEnumerable();

            // Filtro de búsqueda
            if (!string.IsNullOrWhiteSpace(searchText))
            {
                var search = searchText.ToLower();
                resultado = resultado.Where(a =>
                    a.Nombres.ToLower().Contains(search) ||
                    a.Apellidos.ToLower().Contains(search) ||
                    a.NumeroDocumento.Contains(search)
                );
            }

            // Filtro por estado
            if (!string.IsNullOrEmpty(estadoFiltro))
            {
                resultado = resultado.Where(a => a.NombreEstado == estadoFiltro);
            }

            // Filtro preferencial
            if (preferencialFiltro == "preferencial")
            {
                resultado = resultado.Where(a => a.EsPreferencial);
            }
            else if (preferencialFiltro == "normal")
            {
                resultado = resultado.Where(a => !a.EsPreferencial);
            }

            // Filtro por usuario atendedor
            if (!string.IsNullOrEmpty(usuarioFiltro) && int.TryParse(usuarioFiltro, out int idUsuario))
            {
                resultado = resultado.Where(a => a.IdUsuarioActualiza == idUsuario);
            }

            // Ordenar por fecha de atención descendente
            return resultado.OrderByDescending(a => a.FechaActualizacion ?? a.FechaRegistro);
        }
    }

    private List<(int Id, string Nombre)> UsuariosQueAtendieron
    {
        get
        {
            return atenciones
                .Where(a => a.IdUsuarioActualiza.HasValue && !string.IsNullOrEmpty(a.NombreUsuarioActualiza))
                .GroupBy(a => new { a.IdUsuarioActualiza, a.NombreUsuarioActualiza })
                .Select(g => (Id: g.Key.IdUsuarioActualiza!.Value, Nombre: g.Key.NombreUsuarioActualiza!))
                .OrderBy(u => u.Nombre)
                .ToList();
        }
    }

    private IEnumerable<AtencionDto> AtencionesFiltradasPaginadas
    {
        get
        {
            return AtencionesFiltradas
                .Skip((paginaActual - 1) * itemsPorPagina)
                .Take(itemsPorPagina);
        }
    }

    private async Task ToggleExpand(int idAtencion)
    {
        if (atencionExpandida == idAtencion)
        {
            atencionExpandida = null;
        }
        else
        {
            atencionExpandida = idAtencion;
            
            // Cargar el historial si no lo tenemos ya
            if (!historialesPorAtencion.ContainsKey(idAtencion))
            {
                await CargarHistorial(idAtencion);
            }
        }
    }

    private async Task CargarHistorial(int idAtencion)
    {
        try
        {
            cargandoHistorial = true;
            StateHasChanged();

            var historial = await AtencionService.GetHistorialAtencionAsync(idAtencion);
            historialesPorAtencion[idAtencion] = historial;
        }
        catch (Exception ex)
        {
            NotificationService.ShowError($"Error al cargar historial: {ex.Message}");
        }
        finally
        {
            cargandoHistorial = false;
            StateHasChanged();
        }
    }

    private async Task CargarHistorialTodasAtenciones()
    {
        try
        {
            // Cargar historial de todas las atenciones (en paralelo para mejor performance)
            var tareasHistorial = atenciones.Select(async atencion =>
            {
                try
                {
                    var historial = await AtencionService.GetHistorialAtencionAsync(atencion.IdAtencion);
                    return (atencion.IdAtencion, historial);
                }
                catch
                {
                    return (atencion.IdAtencion, new List<HistorialAtencionDto>());
                }
            });

            var resultados = await Task.WhenAll(tareasHistorial);
            
            foreach (var (idAtencion, historial) in resultados)
            {
                historialesPorAtencion[idAtencion] = historial;
            }
            
            // Forzar re-render para actualizar badges con tiempo correcto
            StateHasChanged();
        }
        catch (Exception ex)
        {
            // Silenciar error pero registrar en consola
            Console.WriteLine($"Error al cargar historiales: {ex.Message}");
        }
    }

