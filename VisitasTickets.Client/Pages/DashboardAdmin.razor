@page "/dashboard/admin"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@layout MainLayout
@inject AuthService AuthService
@inject AtencionService AtencionService
@using VisitasTickets.Client.Services
@using VisitasTickets.Domain.Dtos

<PageTitle>Dashboard - Administrador</PageTitle>

<div class="space-y-6 animate-fadeIn">
    <!-- Header del Dashboard -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-gray-900">Dashboard</h1>
            <p class="text-gray-600 mt-1">Bienvenido, <span class="font-semibold">@nombreUsuario</span></p>
        </div>
        <div class="flex items-center gap-4">
            <div class="flex items-center gap-2 text-sm text-gray-500 bg-white px-4 py-2 rounded-lg shadow">
                <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                <span class="font-medium">@DateTime.Now.ToString("dddd, dd MMMM yyyy")</span>
            </div>
            <button @onclick="RefreshData" class="flex items-center gap-2 px-4 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors shadow-lg hover:shadow-xl">
                <svg class="w-5 h-5 @(isRefreshing ? "animate-spin" : "")" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                <span>Actualizar</span>
            </button>
        </div>
    </div>

    <!-- Tarjetas de Estadísticas Principales -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1: Total Usuarios -->
        <div class="bg-gradient-to-br from-blue-50 to-blue-100 rounded-xl shadow-lg p-6 border-l-4 border-blue-600 hover:shadow-2xl hover:scale-105 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                        <p class="text-sm font-semibold text-blue-800 uppercase tracking-wide">Total Usuarios</p>
                    </div>
                    <p class="text-4xl font-bold text-gray-900 mb-3">@(estadisticas?.TotalUsuarios ?? 0)</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1 text-sm font-medium text-blue-700 bg-blue-200 px-2 py-1 rounded-full">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM12.93 17c.046-.327.07-.66.07-1a6.97 6.97 0 00-1.5-4.33A5 5 0 0119 16v1h-6.07zM6 11a5 5 0 015 5v1H1v-1a5 5 0 015-5z"></path>
                            </svg>
                            Sistema
                        </span>
                        <span class="text-xs text-gray-600">usuarios registrados</span>
                    </div>
                </div>
                <div class="w-20 h-20 bg-blue-600 rounded-2xl flex items-center justify-center shadow-lg transform hover:rotate-6 transition-transform">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 2: Atenciones Pendientes -->
        <div class="bg-gradient-to-br from-amber-50 to-amber-100 rounded-xl shadow-lg p-6 border-l-4 border-amber-600 hover:shadow-2xl hover:scale-105 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                        <p class="text-sm font-semibold text-amber-800 uppercase tracking-wide">Atenciones Pendientes</p>
                    </div>
                    <p class="text-4xl font-bold text-gray-900 mb-3">@(estadisticas?.AtencionesPendientes ?? 0)</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1 text-sm font-medium text-amber-700 bg-amber-200 px-2 py-1 rounded-full">
                            <svg class="w-4 h-4 animate-pulse" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                            </svg>
                            En espera
                        </span>
                        <span class="text-xs text-gray-600">@(estadisticas?.AtencionesPreferenciales ?? 0) preferencial(es)</span>
                    </div>
                </div>
                <div class="w-20 h-20 bg-amber-600 rounded-2xl flex items-center justify-center shadow-lg transform hover:rotate-6 transition-transform">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 3: Atenciones en Ventanilla -->
        <div class="bg-gradient-to-br from-green-50 to-green-100 rounded-xl shadow-lg p-6 border-l-4 border-green-600 hover:shadow-2xl hover:scale-105 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                        <p class="text-sm font-semibold text-green-800 uppercase tracking-wide">En Ventanilla</p>
                    </div>
                    <p class="text-4xl font-bold text-gray-900 mb-3">@(estadisticas?.AtencionesEnVentanilla ?? 0)</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1 text-sm font-medium text-orange-700 bg-orange-100 px-2 py-1 rounded-full">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"></path>
                            </svg>
                            @(estadisticas?.AtencionesEnPausa ?? 0) en pausa
                        </span>
                    </div>
                </div>
                <div class="w-20 h-20 bg-green-600 rounded-2xl flex items-center justify-center shadow-lg transform hover:rotate-6 transition-transform">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Card 4: Atenciones del Mes -->
        <div class="bg-gradient-to-br from-purple-50 to-purple-100 rounded-xl shadow-lg p-6 border-l-4 border-purple-600 hover:shadow-2xl hover:scale-105 transition-all duration-300 cursor-pointer">
            <div class="flex items-center justify-between">
                <div class="flex-1">
                    <div class="flex items-center gap-2 mb-2">
                        <p class="text-sm font-semibold text-purple-800 uppercase tracking-wide">Atenciones del Mes</p>
                    </div>
                    <p class="text-4xl font-bold text-gray-900 mb-3">@(estadisticas?.AtencionesMes ?? 0)</p>
                    <div class="flex items-center gap-2">
                        <span class="inline-flex items-center gap-1 text-sm font-medium text-purple-700 bg-purple-200 px-2 py-1 rounded-full">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                <path d="M2 11a1 1 0 011-1h2a1 1 0 011 1v5a1 1 0 01-1 1H3a1 1 0 01-1-1v-5zM8 7a1 1 0 011-1h2a1 1 0 011 1v9a1 1 0 01-1 1H9a1 1 0 01-1-1V7zM14 4a1 1 0 011-1h2a1 1 0 011 1v12a1 1 0 01-1 1h-2a1 1 0 01-1-1V4z"></path>
                            </svg>
                            Hoy: @(estadisticas?.AtencionesHoy ?? 0)
                        </span>
                    </div>
                </div>
                <div class="w-20 h-20 bg-purple-600 rounded-2xl flex items-center justify-center shadow-lg transform hover:rotate-6 transition-transform">
                    <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Sección de Gr�ficos y Actividad -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Actividad Reciente con Timeline -->
        <div class="lg:col-span-2 bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Actividad Reciente
                </h2>
                <a href="/atenciones/atendidos" class="text-sm text-blue-600 hover:text-blue-800 font-medium flex items-center gap-1 hover:gap-2 transition-all">
                    Ver todo
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                    </svg>
                </a>
            </div>
            
            <div class="relative">
                <!-- L�nea vertical del timeline -->
                <div class="absolute left-6 top-0 bottom-0 w-0.5 bg-gray-200"></div>
                
                <div class="space-y-6">
                    @foreach (var actividad in actividadesRecientes)
                    {
                        <div class="relative flex items-start gap-4 group">
                            <!-- Punto del timeline -->
                            <div class="relative z-10 w-12 h-12 rounded-full @GetColorClass(actividad.Tipo) flex items-center justify-center flex-shrink-0 shadow-lg group-hover:scale-110 transition-transform">
                                @if (actividad.Tipo == "usuario")
                                {
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                    </svg>
                                }
                                else if (actividad.Tipo == "ticket")
                                {
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z"></path>
                                    </svg>
                                }
                                else if (actividad.Tipo == "visita")
                                {
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
                                    </svg>
                                }
                                else
                                {
                                    <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                }
                            </div>
                            
                            <!-- Contenido -->
                            <div class="flex-1 bg-gray-50 rounded-lg p-4 group-hover:bg-gray-100 group-hover:shadow-md transition-all">
                                <div class="flex items-start justify-between gap-4">
                                    <div class="flex-1">
                                        <p class="text-sm font-bold text-gray-900">@actividad.Usuario</p>
                                        <p class="text-sm text-gray-700 mt-1">@actividad.Descripcion</p>
                                        <div class="flex items-center gap-3 mt-2">
                                            <span class="text-xs text-gray-500 flex items-center gap-1">
                                                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                                                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                                                </svg>
                                                @actividad.TiempoTranscurrido
                                            </span>
                                            <span class="text-xs text-gray-400">�</span>
                                            <span class="text-xs text-gray-500">@actividad.Fecha.ToString("dd/MM/yyyy HH:mm")</span>
                                        </div>
                                    </div>
                                    <span class="@GetBadgeClass(actividad.Estado) text-xs px-3 py-1 rounded-full font-semibold whitespace-nowrap">
                                        @actividad.Estado
                                    </span>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>

            @if (!actividadesRecientes.Any())
            {
                <div class="text-center py-12">
                    <svg class="w-16 h-16 text-gray-300 mx-auto mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                    </svg>
                    <p class="text-gray-500">No hay actividad reciente</p>
                </div>
            }
        </div>

        <!-- Accesos Rápidos -->
        <div class="bg-white rounded-xl shadow-lg p-6 hover:shadow-xl transition-shadow">
            <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
                <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Accesos Rápidos
            </h2>
            <div class="space-y-3">
                @foreach (var acceso in accesosRapidos)
                {
                    <a href="@acceso.Ruta" class="flex items-center gap-4 p-4 rounded-xl @acceso.ColorHover transition-all group border-2 border-transparent hover:border-current shadow-sm hover:shadow-md">
                        <div class="w-12 h-12 rounded-xl @acceso.ColorFondo flex items-center justify-center group-hover:scale-110 transition-transform shadow">
                            <svg class="w-6 h-6 @acceso.ColorIcono" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="@acceso.IconoPath"></path>
                            </svg>
                        </div>
                        <div class="flex-1">
                            <p class="text-sm font-bold text-gray-900 group-hover:@acceso.ColorTexto transition-colors">@acceso.Nombre</p>
                            <p class="text-xs text-gray-500">@acceso.Descripcion</p>
                        </div>
                        <svg class="w-5 h-5 text-gray-400 group-hover:text-gray-700 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                        </svg>
                    </a>
                }
            </div>
        </div>
    </div>  
</div>

<!-- Estilos personalizados -->
<style>
    @@keyframes fadeIn {
        from { opacity: 0; transform: translateY(10px); }
        to { opacity: 1; transform: translateY(0); }
    }

    @@keyframes slideInUp {
        from { opacity: 0; transform: translateY(20px); }
        to { opacity: 1; transform: translateY(0); }
    }

    .animate-fadeIn {
        animation: fadeIn 0.5s ease-out;
    }

    .animate-slideInUp {
        animation: slideInUp 0.5s ease-out;
    }
</style>

@code {
    private string nombreUsuario = "Administrador";
    private bool isRefreshing = false;

    private EstadisticasDashboardDto? estadisticas;
    private List<ActividadRecienteModel> actividadesRecientes = new();
    private List<AccesoRapidoModel> accesosRapidos = new();

    protected override async Task OnInitializedAsync()
    {
        await CargarDatos();
        CargarAccesosRapidos();
    }

    private async Task CargarDatos()
    {
        try
        {
            // Cargar estad�sticas desde la API
            estadisticas = await AtencionService.GetEstadisticasDashboardAsync();

            // Cargar actividades recientes (�ltimas atenciones completadas)
            await CargarActividadesRecientes();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar datos del dashboard: {ex.Message}");
        }
    }

    private async Task CargarActividadesRecientes()
    {
        try
        {
            // Obtener las �ltimas 6 atenciones completadas
            var atenciones = await AtencionService.GetAtencionesHistorialAsync();
            
            actividadesRecientes = atenciones
                .Where(a => a.NombreEstado == "Atendido")
                .OrderByDescending(a => a.FechaRegistro)
                .Take(3)
                .Select(a => new ActividadRecienteModel
                {
                    Usuario = a.NombreCompleto ?? "Usuario",
                    Descripcion = $"Atención de {a.NombreTramite ?? "trámite"} finalizada",
                    Fecha = a.FechaRegistro,
                    Estado = "Atendido",
                    Tipo = a.EsPreferencial ? "preferencial" : "ticket",
                    TiempoTranscurrido = CalcularTiempoTranscurrido(a.FechaRegistro)
                })
                .ToList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar actividades recientes: {ex.Message}");
            actividadesRecientes = new List<ActividadRecienteModel>();
        }
    }

    private void CargarAccesosRapidos()
    {
        accesosRapidos = new List<AccesoRapidoModel>
        {
            new() { Nombre = "Gestión de Usuarios", Descripcion = "Administrar usuarios del sistema", Ruta = "/usuarios", ColorFondo = "bg-blue-100", ColorIcono = "text-blue-600", ColorHover = "hover:bg-blue-50", ColorTexto = "text-blue-600", IconoPath = "M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" },
            new() { Nombre = "Atenciones Pendientes", Descripcion = "Ver atenciones en espera", Ruta = "/atenciones/pendientes", ColorFondo = "bg-amber-100", ColorIcono = "text-amber-600", ColorHover = "hover:bg-amber-50", ColorTexto = "text-amber-600", IconoPath = "M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" },
            new() { Nombre = "Atenciones Completadas", Descripcion = "Historial de atenciones", Ruta = "/atenciones/atendidos", ColorFondo = "bg-green-100", ColorIcono = "text-green-600", ColorHover = "hover:bg-green-50", ColorTexto = "text-green-600", IconoPath = "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
        };
    }

    private async Task RefreshData()
    {
        isRefreshing = true;
        StateHasChanged();

        await CargarDatos();

        isRefreshing = false;
        StateHasChanged();
    }

    private string CalcularTiempoTranscurrido(DateTime fecha)
    {
        var diferencia = DateTime.Now - fecha;
        
        if (diferencia.TotalMinutes < 1)
            return "Hace unos segundos";
        if (diferencia.TotalMinutes < 60)
            return $"Hace {(int)diferencia.TotalMinutes} minuto{((int)diferencia.TotalMinutes != 1 ? "s" : "")}";
        if (diferencia.TotalHours < 24)
            return $"Hace {(int)diferencia.TotalHours} hora{((int)diferencia.TotalHours != 1 ? "s" : "")}";
        if (diferencia.TotalDays < 7)
            return $"Hace {(int)diferencia.TotalDays} día{((int)diferencia.TotalDays != 1 ? "s" : "")}";
        
        return fecha.ToString("dd/MM/yyyy");
    }

    private string GetColorClass(string tipo) => tipo switch
    {
        "usuario" => "bg-blue-600",
        "ticket" => "bg-amber-600",
        "preferencial" => "bg-purple-600",
        "visita" => "bg-green-600",
        "reporte" => "bg-indigo-600",
        _ => "bg-gray-600"
    };

    private string GetBadgeClass(string estado) => estado switch
    {
        "Completado" => "bg-green-100 text-green-800",
        "En Proceso" => "bg-blue-100 text-blue-800",
        "Pendiente" => "bg-amber-100 text-amber-800",
        _ => "bg-gray-100 text-gray-800"
    };

    private class ActividadRecienteModel
    {
        public string Usuario { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public DateTime Fecha { get; set; }
        public string Estado { get; set; } = string.Empty;
        public string Tipo { get; set; } = string.Empty;
        public string TiempoTranscurrido { get; set; } = string.Empty;
    }

    private class AccesoRapidoModel
    {
        public string Nombre { get; set; } = string.Empty;
        public string Descripcion { get; set; } = string.Empty;
        public string Ruta { get; set; } = string.Empty;
        public string ColorFondo { get; set; } = string.Empty;
        public string ColorIcono { get; set; } = string.Empty;
        public string ColorHover { get; set; } = string.Empty;
        public string ColorTexto { get; set; } = string.Empty;
        public string IconoPath { get; set; } = string.Empty;
