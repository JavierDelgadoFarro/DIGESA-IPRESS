@page "/admin/generar-qr"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@inject NavigationManager NavManager

<PageTitle>Generar QR - DIGESA</PageTitle>

<div class="p-6">
    <div class="max-w-4xl mx-auto">
        <!-- Header -->
        <div class="mb-8">
            <h1 class="text-3xl font-bold text-gray-900 mb-2">📱 Generar Código QR</h1>
            <p class="text-gray-600">Código QR para registro de atenciones</p>
        </div>

        <!-- Tarjeta del QR -->
        <div class="bg-white rounded-2xl shadow-xl p-8">
            
            <!-- Información -->
            <div class="bg-blue-50 border-l-4 border-blue-500 p-6 mb-8 rounded-r-lg">
                <h3 class="font-semibold text-blue-900 mb-2">ℹ️ Instrucciones</h3>
                <ul class="text-sm text-blue-800 space-y-1">
                    <li>• Este código QR lleva al formulario público de registro de atenciones</li>
                    <li>• Los visitantes pueden escanear el código con su celular</li>
                    <li>• Imprima este código y colóquelo en un lugar visible en la entrada</li>
                    <li>• El enlace funciona para cualquier visitante sin necesidad de autenticación</li>
                </ul>
            </div>

            <!-- QR Code centrado -->
            <div class="text-center mb-8">
                <div class="inline-block bg-white p-8 rounded-2xl shadow-lg border-4 border-blue-600">
                    <!-- QR generado con API de Google Charts -->
                    <img src="@GetQRCodeUrl()" alt="Código QR" class="w-80 h-80" />
                </div>
                <p class="mt-6 text-lg font-semibold text-gray-700">Escanea para registrar tu atención</p>
                <p class="text-sm text-gray-500 mt-2">@GetFullUrl()</p>
            </div>

            <!-- Botones de acción -->
            <div class="flex flex-wrap gap-4 justify-center">
                <button @onclick="ImprimirQR" class="bg-blue-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-blue-700 transition flex items-center gap-2">
                    <span>🖨️</span>
                    <span>Imprimir QR</span>
                </button>
                
                <button @onclick="DescargarQR" class="bg-emerald-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-emerald-700 active:scale-95 transition-all flex items-center gap-2">
                    <span>💾</span>
                    <span>Descargar Imagen</span>
                </button>

                <a href="@GetFullUrl()" target="_blank" class="bg-slate-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-slate-700 active:scale-95 transition-all flex items-center gap-2">
                    <span>🔗</span>
                    <span>Abrir Enlace</span>
                </a>
            </div>

            <!-- Vista previa para impresión -->
            <div class="mt-12 border-t pt-8">
                <h3 class="font-semibold text-gray-900 mb-4 text-center">Vista Previa para Impresión</h3>
                <div class="bg-gray-50 rounded-xl p-8 text-center">
                    <div class="max-w-md mx-auto bg-white p-8 rounded-2xl shadow-inner border-4 border-dashed border-gray-300" style="print:border-solid">
                        <h2 class="text-2xl font-bold text-blue-900 mb-4">📝 REGISTRO DE ATENCIÓN</h2>
                        <p class="text-gray-700 mb-6">Escanea el código QR para<br />registrar tu atención</p>
                        <img src="@GetQRCodeUrl()" alt="Código QR" class="w-64 h-64 mx-auto mb-4" />
                        <p class="text-sm text-gray-600">DIGESA - Dirección General de Salud Ambiental e Inocuidad Alimentaria</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@media print {
        .no-print {
            display: none;
        }
        
        body {
            margin: 0;
            padding: 0;
        }
        
        .print-container {
            width: 100%;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
        }
    }
</style>

@code {
    private string GetFullUrl()
    {
        var baseUrl = NavManager.BaseUri.TrimEnd('/');
        return $"{baseUrl}/registro-publico";
    }

    private string GetQRCodeUrl()
    {
        var url = GetFullUrl();
        // Usar API de Google Charts para generar QR (alternativa: qrcode.js o similar)
        return $"https://api.qrserver.com/v1/create-qr-code/?size=400x400&data={Uri.EscapeDataString(url)}";
    }

    private void ImprimirQR()
    {
        // Usar JS Interop para abrir diálogo de impresión
        // Por ahora, simplemente refrescamos con CSS print
        // En el futuro, se puede usar IJSRuntime para window.print()
        Console.WriteLine("Imprimir QR");
    }

    private void DescargarQR()
    {
        // Descargar la imagen del QR
        NavManager.NavigateTo(GetQRCodeUrl(), true);
    }
}
